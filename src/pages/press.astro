<title>Press kit — Tayyub Yaqoob</title>
<meta name="description" content="Press kit for journalists, podcast producers and panel organisers. Bios in three lengths, ready-to-quote pull paragraphs, fact sheet, expert topics and direct press contact." />
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600&family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<style>
.press-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:32px;align-items:start}
@media (max-width:980px){.press-grid{grid-template-columns:1fr}}

/* Bio cards with copy buttons */
.bio{position:relative;background:#fff;border:1px solid var(--line);border-radius:var(--r-lg);padding:24px 26px;display:flex;flex-direction:column;gap:12px;transition:border-color .25s,box-shadow .25s}
.bio:hover{border-color:var(--line-2);box-shadow:var(--shadow-1)}
.bio-head{display:flex;align-items:baseline;justify-content:space-between;gap:14px;border-bottom:1px dashed var(--line);padding-bottom:10px}
.bio-head .lbl{font-family:var(--mono);font-size:10.5px;letter-spacing:.08em;text-transform:uppercase;color:var(--terra);font-weight:600}
.bio-head .wc{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:.04em}
.bio-body{font-family:var(--serif);font-size:16.5px;line-height:1.55;color:var(--ink);text-wrap:pretty;letter-spacing:-.005em}
.bio-body b{color:var(--terra);font-weight:500}
.bio-foot{display:flex;justify-content:flex-end;margin-top:6px}
.copy-btn{display:inline-flex;align-items:center;gap:6px;padding:7px 12px;border-radius:999px;border:1px solid var(--line);background:#fff;font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-2);cursor:pointer;transition:background .2s,color .2s,border-color .2s}
.copy-btn:hover{background:var(--ink);color:#fff;border-color:var(--ink)}
.copy-btn.copied{background:var(--sage-soft);color:var(--moss);border-color:var(--moss)}

/* Fact sheet panel */
.facts{background:linear-gradient(160deg,#fff,var(--bg-soft));border:1px solid var(--line);border-radius:var(--r-lg);padding:24px 28px;box-shadow:var(--shadow-1)}
.facts h3{font-family:var(--serif);font-size:22px;letter-spacing:-.01em;margin-bottom:14px}
.facts h3 em{font-style:italic;color:var(--terra)}
.facts ul{list-style:none;padding:0;display:flex;flex-direction:column;gap:9px}
.facts li{display:flex;align-items:flex-start;gap:10px;font-size:14px;line-height:1.5;color:var(--ink-2)}
.facts li::before{content:"›";color:var(--terra);font-weight:600;font-size:16px;line-height:1.4;flex-shrink:0}
.facts li b{color:var(--ink);font-weight:600}

/* Pull-quote paragraph blocks */
.pull-list{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px}
.pull{position:relative;background:#fff;border-left:3px solid var(--terra);border-radius:var(--r-md);padding:22px 24px;box-shadow:var(--shadow-1);transition:transform .25s,box-shadow .25s}
.pull:hover{transform:translateY(-2px);box-shadow:var(--shadow-2)}
.pull-tag{font-family:var(--mono);font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:var(--terra);margin-bottom:8px}
.pull blockquote{margin:0;font-family:var(--serif);font-style:italic;font-size:17px;line-height:1.45;color:var(--ink);letter-spacing:-.005em}
.pull blockquote b{font-style:normal;color:var(--terra);font-weight:500}
.pull-attr{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-top:14px;padding-top:10px;border-top:1px dashed var(--line);font-family:var(--mono);font-size:10px;letter-spacing:.04em;color:var(--muted);text-transform:uppercase}
.pull-attr b{color:var(--ink-2)}
@media (max-width:880px){.pull-list{grid-template-columns:1fr}}

/* Topics chips */
.topic-chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px}
.topic-chip{padding:7px 13px;border-radius:999px;background:var(--ochre-soft);color:#8a5e15;border:1px solid #f0d690;font-family:var(--mono);font-size:11px;letter-spacing:.04em;text-transform:uppercase;font-weight:600}
.topic-chip.t2{background:var(--terra-soft);color:var(--terra);border-color:#f6cdbb}
.topic-chip.t3{background:var(--sage-soft);color:var(--moss);border-color:#cfe0b1}

/* Asset download card */
.asset-card{background:#fff;border:1px solid var(--line);border-radius:var(--r-md);padding:18px 20px;display:flex;flex-direction:column;gap:8px;transition:transform .25s,border-color .25s,box-shadow .25s}
.asset-card:hover{transform:translateY(-2px);border-color:var(--terra);box-shadow:var(--shadow-1)}
.asset-card h5{font-family:var(--sans);font-weight:600;font-size:14px;color:var(--ink);letter-spacing:-.005em}
.asset-card .desc{font-size:12.5px;color:var(--ink-2);line-height:1.45}
.asset-card .meta{font-family:var(--mono);font-size:10px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);margin-top:auto;padding-top:6px;border-top:1px dashed var(--line)}
.asset-card .meta a{color:var(--terra);font-weight:600;border-bottom:1px solid currentColor}
.asset-headshot{background:var(--bg-soft);aspect-ratio:1/1;border-radius:var(--r-md);overflow:hidden;border:1px solid var(--line);position:relative}
.asset-headshot img{width:100%;height:100%;object-fit:cover;filter:sepia(.05) saturate(.95)}
.asset-headshot .dl{position:absolute;bottom:8px;right:8px;font-family:var(--mono);font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;padding:5px 9px;border-radius:999px;background:rgba(255,255,255,.95);color:var(--ink);border:1px solid var(--line);text-decoration:none;backdrop-filter:blur(8px);box-shadow:var(--shadow-1)}
.asset-headshot .dl:hover{background:var(--ink);color:#fff;border-color:var(--ink)}

/* Press-route hero */
.press-eyebrow{display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border-radius:999px;background:var(--terra-soft);border:1px solid var(--terra);font-family:var(--mono);font-size:10.5px;color:var(--terra);letter-spacing:.06em;text-transform:uppercase;font-weight:600;margin-bottom:14px}
.press-eyebrow::before{content:"●";color:var(--terra)}

/* Section dividers within press page */
.press-block{margin-bottom:48px}
.press-block h2{font-family:var(--serif);font-weight:400;font-size:clamp(28px,3.4vw,40px);letter-spacing:-.018em;line-height:1.05;margin-bottom:8px}
