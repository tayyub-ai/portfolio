---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
import { site } from "../data/site";
---

<SiteLayout
  title="Press"
  description="Press page with bios, fact sheet, expert topics, and direct contact for interviews and commentary."
  pathname="/press"
  crumbs={[{ label: "Home", href: "/" }, { label: "Press" }]}
>
  <style slot="head">
    .press-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:32px;align-items:start}
    .press-eyebrow{display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border-radius:999px;background:var(--terra-soft);border:1px solid var(--terra);font-family:var(--mono);font-size:10.5px;color:var(--terra);letter-spacing:.06em;text-transform:uppercase;font-weight:600;margin-bottom:14px}
    .press-eyebrow::before{content:"●";color:var(--terra)}
    .bio,.facts,.asset-card{background:#fff;border:1px solid var(--line);border-radius:var(--r-lg);padding:24px 26px;box-shadow:var(--shadow-1)}
    .bio{display:flex;flex-direction:column;gap:12px}
    .bio-head{display:flex;align-items:baseline;justify-content:space-between;gap:14px;border-bottom:1px dashed var(--line);padding-bottom:10px}
    .bio-head .lbl{font-family:var(--mono);font-size:10.5px;letter-spacing:.08em;text-transform:uppercase;color:var(--terra);font-weight:600}
    .bio-head .wc{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:.04em}
    .bio-body{font-family:var(--serif);font-size:16.5px;line-height:1.55;color:var(--ink);letter-spacing:-.005em}
    .bio-body b{color:var(--terra);font-weight:500}
    .facts h3,.asset-card h5,.press-block h2{font-family:var(--serif);font-weight:400}
    .facts h3 em,.press-block h2 em{font-style:italic;color:var(--terra)}
    .facts ul{list-style:none;display:flex;flex-direction:column;gap:9px;margin-top:12px}
    .facts li{font-size:14px;line-height:1.55;color:var(--ink-2)}
    .facts li b{color:var(--ink)}
    .asset-card{display:flex;flex-direction:column;gap:8px}
    .asset-card .desc{font-size:13px;color:var(--ink-2);line-height:1.5}
    .asset-card .meta{font-family:var(--mono);font-size:10px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);margin-top:auto;padding-top:6px;border-top:1px dashed var(--line)}
    .asset-card .meta a{color:var(--terra);border-bottom:1px solid currentColor}
    .press-block{margin-bottom:48px}
    .press-block h2{font-size:clamp(28px,3.4vw,40px);letter-spacing:-.018em;line-height:1.05;margin-bottom:8px}
    .press-block .lead{font-size:15.5px;color:var(--ink-2);line-height:1.55;margin-bottom:22px;max-width:60ch}
    .topic-chips{display:flex;flex-wrap:wrap;gap:8px}
    .topic-chip{padding:7px 13px;border-radius:999px;background:var(--ochre-soft);color:#8a5e15;border:1px solid #f0d690;font-family:var(--mono);font-size:11px;letter-spacing:.04em;text-transform:uppercase;font-weight:600}
    .topic-chip.t2{background:var(--terra-soft);color:var(--terra);border-color:#f6cdbb}
    .topic-chip.t3{background:var(--sage-soft);color:var(--moss);border-color:#cfe0b1}
    @media (max-width:980px){.press-grid{grid-template-columns:1fr}}
  </style>

  <PageHeader
    title="Press and <em>expert commentary</em>."
    subtitle="Bios, fact sheet, expert topics, and direct contact for journalists, producers, and panel organisers. Bios below are reusable; topics list areas with on-record public work or technical experience."
    crumbs={[{ label: "Home", href: "/" }, { label: "Press" }]}
    eyebrow="For journalists · producers · panel organisers"
  />

  <section class="section wrap first press-block" data-screen-label="Bios">
    <h2>Bios and <em>fact sheet</em>.</h2>
    <p class="lead">Short bio for panel intros and captions; medium bio for podcast notes and programmes. Both can be copied verbatim.</p>

    <div class="press-grid">
      <div style="display:flex;flex-direction:column;gap:14px">
        <article class="bio rv">
          <header class="bio-head"><span class="lbl">Short bio</span><span class="wc">Panel intros, captions</span></header>
          <div class="bio-body">Tayyub Yaqoob is a UK-based <b>Senior Digital Analyst at 8 Million Stories</b>, where he builds AI-assisted analytics, automation, and measurement systems for digital and analyst teams. He has published technical writing for Cointelegraph and AlphaWire, been cited as an expert source by CCN, and completed three peer reviews for IGI Global.</div>
        </article>
        <article class="bio rv d1">
          <header class="bio-head"><span class="lbl">Medium bio</span><span class="wc">Podcast notes, programmes</span></header>
          <div class="bio-body">Tayyub Yaqoob is a <b>Senior Digital Analyst at 8 Million Stories</b> in Stirling, UK, where he builds analytics systems, reporting automation, and AI-assisted measurement workflows for analyst and client teams. His public record includes technical writing for Cointelegraph and AlphaWire, expert commentary cited by CCN, and three completed chapter reviews for IGI Global. Current focus: AI-assisted analytics workflows, measurement QA automation, consent and reporting transparency, and AI-search visibility research.</div>
        </article>
      </div>

      <aside class="facts rv">
        <h3>Fact <em>sheet</em>.</h3>
        <ul>
          <li><b>Role.</b> Senior Digital Analyst, 8 Million Stories. Stirling, United Kingdom.</li>
          <li><b>Focus.</b> AI-assisted analytics, automation, and digital measurement engineering.</li>
          <li><b>Publications.</b> Cointelegraph, AlphaWire. Live URLs plus PDF archive.</li>
          <li><b>Recognition.</b> Expert citations in CCN; three completed chapter reviews for IGI Global.</li>
          <li><b>Evidence index.</b> <a href="/evidence" style="color:var(--terra);border-bottom:1px solid currentColor">/evidence</a></li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section wrap press-block" data-screen-label="Topics">
    <h2>Expert <em>topics</em>.</h2>
    <p class="lead">Areas with on-record public work or hands-on technical experience.</p>
    <div class="topic-chips">
      <span class="topic-chip">AI systems</span>
      <span class="topic-chip">Measurement engineering</span>
      <span class="topic-chip">Analytics automation</span>
      <span class="topic-chip t2">AI-search visibility</span>
      <span class="topic-chip t2">Consent and measurement transparency</span>
      <span class="topic-chip t2">LLM-assisted analytics workflows</span>
      <span class="topic-chip t3">Crypto-security commentary</span>
      <span class="topic-chip t3">Quantum and blockchain explainers</span>
    </div>
  </section>

  <section class="section wrap press-block" data-screen-label="Assets">
    <h2>Assets and <em>contact</em>.</h2>
    <div class="press-grid">
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="asset-card rv">
          <h5>Evidence index</h5>
          <div class="desc">Sources for role, case studies, publications, recognition, and public code.</div>
          <div class="meta"><a href="/evidence">Open evidence ↗</a></div>
        </div>
        <div class="asset-card rv d1">
          <h5>Publications</h5>
          <div class="desc">Live article URLs plus PDF archive of older Cointelegraph pieces.</div>
          <div class="meta"><a href="/publications">Open publications ↗</a></div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="asset-card rv d2">
          <h5>Direct press contact</h5>
          <div class="desc">For interviews, commentary, panels, or deadline-driven requests.</div>
          <div class="meta"><a href={`mailto:${site.email}`}>{site.email} →</a></div>
        </div>
        <div class="asset-card rv d3">
          <h5>Linked profiles</h5>
          <div class="desc">Use these for baseline profile verification.</div>
          <div class="meta"><a href={site.social.linkedin} target="_blank" rel="noreferrer">LinkedIn ↗</a> · <a href={site.social.github} target="_blank" rel="noreferrer">GitHub ↗</a></div>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
