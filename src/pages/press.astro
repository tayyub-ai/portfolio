---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
import { site } from "../data/site";

const shortBio = "Tayyub Yaqoob is a UK-based Senior Digital Analyst at 8 Million Stories, where he builds AI-assisted analytics, automation, and measurement systems for digital and analyst teams. He has published technical writing for Cointelegraph and AlphaWire, been cited as an expert source by CCN, and completed three peer reviews for IGI Global.";
const mediumBio = "Tayyub Yaqoob is a Senior Digital Analyst at 8 Million Stories in Stirling, UK, where he builds analytics systems, reporting automation, and AI-assisted measurement workflows for analyst and client teams. His public record includes technical writing for Cointelegraph and AlphaWire, expert commentary cited by CCN, and three completed chapter reviews for IGI Global. Current focus: AI-assisted analytics workflows, measurement QA automation, consent and reporting transparency, and AI-search visibility research.";

const shortWords = shortBio.split(/\s+/).length;
const mediumWords = mediumBio.split(/\s+/).length;
---

<SiteLayout
  title="Press"
  description="Press page with bios, fact sheet, expert topics, and direct contact for interviews and commentary."
  pathname="/press"
  crumbs={[{ label: "Home", href: "/" }, { label: "Press" }]}
>
  <style slot="head">
    /* ── Press kit panels ── */
    .pk-grid{display:grid;grid-template-columns:1.5fr 1fr;gap:24px;margin-top:8px}
    @media (max-width:980px){.pk-grid{grid-template-columns:1fr}}

    .pkpanel{position:relative;background:#fff;border:1px solid var(--line);border-radius:12px;overflow:hidden;box-shadow:var(--shadow-1);transition:transform .35s cubic-bezier(.2,.7,.1,1),box-shadow .35s,border-color .25s}
    .pkpanel:hover{transform:translateY(-3px);box-shadow:var(--shadow-2);border-color:var(--line-2)}
    .pkpanel-h{display:grid;grid-template-columns:1fr auto;gap:14px;padding:12px 18px;background:linear-gradient(180deg,#fafaf5,#f5f3ee);border-bottom:1px dashed var(--line);font-family:var(--mono);align-items:center}
    .pkpanel-h .lbl{font-size:10px;letter-spacing:.16em;color:var(--terra);text-transform:uppercase;font-weight:700;display:flex;align-items:center;gap:8px}
    .pkpanel-h .lbl::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--terra)}
    .pkpanel-h .meter{display:flex;align-items:center;gap:8px;font-size:9.5px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
    .pkpanel-h .meter .bar{position:relative;width:80px;height:3px;background:var(--line);border-radius:2px;overflow:hidden}
    .pkpanel-h .meter .bar i{display:block;height:100%;background:linear-gradient(90deg,var(--moss),var(--terra));transform:scaleX(0);transform-origin:left;transition:transform 1.2s cubic-bezier(.4,0,.2,1)}
    .pkpanel.rv.in .pkpanel-h .meter .bar i{transform:scaleX(var(--w,.5))}
    .pkpanel-h .meter b{color:var(--ink);font-family:'Inter',sans-serif;font-size:11px;font-weight:600;letter-spacing:0;text-transform:none}
    .pkpanel-body{padding:22px 24px 18px;font-family:'Instrument Serif',Georgia,serif;font-size:16px;line-height:1.65;color:var(--ink);letter-spacing:-.003em;font-style:italic}
    .pkpanel-body.mono{font-family:var(--mono);font-style:normal;font-size:13.5px;line-height:1.75;color:var(--ink-2);background:linear-gradient(180deg,#fafaf5,#fff);border-top:1px dashed var(--line)}
    .pkpanel-body b{color:var(--terra);font-weight:500;font-style:normal}
    .pkpanel-foot{display:flex;justify-content:space-between;align-items:center;padding:10px 18px;background:#fafaf5;border-top:1px dashed var(--line);font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
    .pkpanel-copy{display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border-radius:999px;background:#fff;border:1px solid var(--line);color:var(--ink);font-family:'Inter',sans-serif;font-size:11px;font-weight:600;letter-spacing:0;text-transform:none;cursor:pointer;transition:background .25s,color .25s,border-color .25s}
    .pkpanel-copy:hover{background:var(--terra);color:#fff;border-color:var(--terra)}
    .pkpanel-copy.copied{background:var(--moss);color:#fff;border-color:var(--moss)}
    .pkpanel-copy::before{content:"⎘"}
    .pkpanel-copy.copied::before{content:"✓"}

    /* ── Index card (fact sheet) ── */
    .indexcard{position:relative;background:linear-gradient(170deg,#fffdf8,#fcf3df);border:1px solid #d8c79c;border-radius:6px;padding:22px 24px 20px;box-shadow:0 12px 30px rgba(60,40,20,.12);transition:transform .35s cubic-bezier(.2,.7,.1,1),box-shadow .35s}
    .indexcard:hover{transform:rotate(-1deg) translateY(-3px);box-shadow:0 18px 40px rgba(60,40,20,.2)}
    .indexcard::before{content:"";position:absolute;left:0;right:0;top:14px;height:1px;background:#d97757;opacity:.4}
    .indexcard::after{content:"";position:absolute;top:0;left:24px;right:24px;height:8px;background:repeating-linear-gradient(90deg,transparent 0,transparent 4px,#d8c79c 4px,#d8c79c 5px);opacity:.7}
    .indexcard-h{font-family:'Caveat',cursive,serif;font-size:24px;color:#3d2c12;margin-bottom:14px;padding-top:8px}
    .indexcard-h em{color:#7c4a16}
    .indexcard-fields{display:flex;flex-direction:column;gap:10px}
    .indexcard-fields .row{display:grid;grid-template-columns:80px 1fr;gap:14px;align-items:baseline;font-family:var(--mono);font-size:11px;padding-bottom:8px;border-bottom:1px dotted #d8c79c}
    .indexcard-fields .row:last-child{border-bottom:0}
    .indexcard-fields .row .k{color:#7c4a16;letter-spacing:.14em;text-transform:uppercase;font-size:9.5px}
    .indexcard-fields .row .v{color:#3d2c12;font-family:'Inter',sans-serif;font-size:13px;letter-spacing:0;text-transform:none;line-height:1.45}
    .indexcard-fields .row .v b{font-weight:600}
    .indexcard-fields .row .v a{color:var(--terra);border-bottom:1px solid currentColor}

    /* ── Tag cloud ── */
    .tagcloud{margin-top:14px;background:linear-gradient(160deg,#fff,var(--bg-soft));border:1px solid var(--line);border-radius:14px;padding:28px;position:relative;overflow:hidden}
    .tagcloud::before{content:"";position:absolute;inset:0;background-image:radial-gradient(rgba(196,77,44,.05) 1px,transparent 1px);background-size:20px 20px;pointer-events:none}
    .tagcloud-h{display:flex;justify-content:space-between;align-items:end;margin-bottom:18px;position:relative;z-index:1}
    .tagcloud-h h3{font-family:var(--serif);font-weight:400;font-size:22px;letter-spacing:-.01em}
    .tagcloud-h h3 em{font-style:italic;color:var(--terra)}
    .tagcloud-h .meta{font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
    .tagcloud-grid{display:flex;flex-wrap:wrap;align-items:center;gap:10px 12px;position:relative;z-index:1;padding:8px 0}
    .tagchip{display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border-radius:999px;font-family:'Inter',sans-serif;font-weight:600;letter-spacing:-.005em;border:1px solid var(--line);background:#fff;color:var(--ink);transition:transform .25s,background .25s,color .25s,box-shadow .25s}
    .tagchip:hover{transform:translateY(-2px);box-shadow:var(--shadow-1)}
    .tagchip.tier-1{font-size:18px;background:linear-gradient(135deg,var(--terra),var(--coral));color:#fff;border-color:transparent;padding:10px 18px}
    .tagchip.tier-1::before{content:"●";color:#fff;opacity:.7}
    .tagchip.tier-2{font-size:15px;background:var(--ochre-soft);color:#8a5e15;border-color:#f0d690}
    .tagchip.tier-2::before{content:"●";color:#8a5e15;opacity:.7;margin-right:-2px}
    .tagchip.tier-3{font-size:13px;background:var(--sage-soft);color:var(--moss);border-color:#cfe0b1}
    .tagchip.tier-3::before{content:"○";color:var(--moss);opacity:.7;margin-right:-2px}
    .tagchip.tier-4{font-size:12px;color:var(--ink-2);background:#fff}
    .tagcloud-legend{display:flex;flex-wrap:wrap;gap:18px;margin-top:18px;padding-top:14px;border-top:1px dashed var(--line);font-family:var(--mono);font-size:9.5px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase;position:relative;z-index:1}
    .tagcloud-legend .lk{display:inline-flex;align-items:center;gap:6px}
    .tagcloud-legend .sw{width:10px;height:10px;border-radius:50%}

    /* ── Assets row (status board style) ── */
    .pkassets{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:18px}
    .pkasset{display:grid;grid-template-columns:auto 1fr auto;gap:14px;padding:16px 18px;background:#fff;border:1px solid var(--line);border-radius:10px;text-decoration:none;color:inherit;font-family:var(--mono);transition:transform .25s,border-color .25s,box-shadow .25s;align-items:center}
    .pkasset:hover{transform:translateY(-2px);border-color:var(--line-2);box-shadow:var(--shadow-1)}
    .pkasset .ic{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;background:var(--terra-soft);color:var(--terra);font-family:var(--serif);font-style:italic;font-size:16px;flex-shrink:0}
    .pkasset.aw-2 .ic{background:var(--ochre-soft);color:#8a5e15}
    .pkasset.aw-3 .ic{background:var(--sage-soft);color:var(--moss)}
    .pkasset.aw-4 .ic{background:#fce5d8;color:var(--coral)}
    .pkasset .text{font-family:'Inter',sans-serif}
    .pkasset .text h5{font-weight:600;font-size:14px;color:var(--ink);letter-spacing:-.005em;line-height:1.2}
    .pkasset .text .desc{font-size:12.5px;color:var(--ink-2);margin-top:2px;line-height:1.45}
    .pkasset .arr{font-family:var(--mono);font-size:11px;color:var(--terra);letter-spacing:.06em;text-transform:uppercase;display:inline-flex;align-items:center;gap:3px}
    .pkasset .arr::after{content:"↗";transition:transform .25s}
    .pkasset:hover .arr::after{transform:translate(2px,-2px)}
    @media (max-width:680px){.pkassets{grid-template-columns:1fr}}
  </style>

  <PageHeader
    title="Press and <em>expert commentary</em>."
    subtitle="Bios, fact sheet, expert topics, and direct contact for journalists, producers, and panel organisers. Bios below are reusable; topics list areas with on-record public work or technical experience."
    crumbs={[{ label: "Home", href: "/" }, { label: "Press" }]}
    eyebrow="For journalists · producers · panel organisers"
  />

  <section class="section wrap first" data-screen-label="Bios">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--terra)"></span>§ Press kit</span>
        <h2>Bios and <em>fact sheet</em>.</h2>
        <p>Short bio for panel intros and captions, medium bio for podcast notes and programmes. Both ready to copy verbatim.</p>
      </div>
      <div class="sec-head-r">/ copy ready</div>
    </div>

    <div class="pk-grid">
      <div style="display:flex;flex-direction:column;gap:18px">
        <article class="pkpanel rv" style={`--w:${Math.min(shortWords / 80, 1)}`}>
          <header class="pkpanel-h">
            <span class="lbl">Short bio · panel intros</span>
            <span class="meter">
              <span class="bar"><i></i></span>
              <b>{shortWords} words</b>
            </span>
          </header>
          <div class="pkpanel-body" id="bio-short">{shortBio}</div>
          <footer class="pkpanel-foot">
            <span>Bio · short</span>
            <button class="pkpanel-copy" data-copy="bio-short">copy</button>
          </footer>
        </article>

        <article class="pkpanel rv d1" style={`--w:${Math.min(mediumWords / 140, 1)}`}>
          <header class="pkpanel-h">
            <span class="lbl">Medium bio · podcast notes</span>
            <span class="meter">
              <span class="bar"><i></i></span>
              <b>{mediumWords} words</b>
            </span>
          </header>
          <div class="pkpanel-body mono" id="bio-medium">{mediumBio}</div>
          <footer class="pkpanel-foot">
            <span>Bio · medium</span>
            <button class="pkpanel-copy" data-copy="bio-medium">copy</button>
          </footer>
        </article>
      </div>

      <aside class="indexcard rv d2">
        <div class="indexcard-h">Fact <em>card</em>.</div>
        <div class="indexcard-fields">
          <div class="row"><span class="k">Role</span><span class="v"><b>Senior Digital Analyst</b><br/>8 Million Stories · Stirling, UK</span></div>
          <div class="row"><span class="k">Focus</span><span class="v">AI-assisted analytics · automation · digital measurement engineering</span></div>
          <div class="row"><span class="k">Pubs</span><span class="v">Cointelegraph · AlphaWire<br/>Live URLs + PDF archive</span></div>
          <div class="row"><span class="k">Cited</span><span class="v">CCN · expert source<br/>3 chapter reviews · IGI Global</span></div>
          <div class="row"><span class="k">Locale</span><span class="v">Stirling · United Kingdom · GMT</span></div>
          <div class="row"><span class="k">Evidence</span><span class="v"><a href="/evidence">/evidence</a></span></div>
          <div class="row"><span class="k">Contact</span><span class="v"><a href={`mailto:${site.email}`}>{site.email}</a></span></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section wrap" data-screen-label="Topics">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--ochre)"></span>§ Expert topics</span>
        <h2>Areas with <em>on-record</em> work.</h2>
        <p>Larger chips have deeper hands-on or published experience. Smaller chips are areas with technical familiarity and adjacent commentary.</p>
      </div>
      <div class="sec-head-r">/ weighted</div>
    </div>

    <div class="tagcloud rv">
      <div class="tagcloud-h">
        <h3>Topic <em>cloud</em>.</h3>
        <span class="meta">/ tier-weighted</span>
      </div>
      <div class="tagcloud-grid">
        <span class="tagchip tier-1">AI-assisted analytics</span>
        <span class="tagchip tier-1">Digital measurement engineering</span>
        <span class="tagchip tier-2">Analytics automation</span>
        <span class="tagchip tier-2">AI-search visibility</span>
        <span class="tagchip tier-2">Consent and tracking quality</span>
        <span class="tagchip tier-2">LLM-assisted reporting</span>
        <span class="tagchip tier-3">Crypto-security commentary</span>
        <span class="tagchip tier-3">AI in trading</span>
        <span class="tagchip tier-3">Quantum and blockchain</span>
        <span class="tagchip tier-4">CBDCs</span>
        <span class="tagchip tier-4">Forecasting</span>
        <span class="tagchip tier-4">BigQuery / GA4 / GTM</span>
        <span class="tagchip tier-4">Reporting QA</span>
        <span class="tagchip tier-4">Agentic AI</span>
      </div>
      <div class="tagcloud-legend">
        <span class="lk"><span class="sw" style="background:linear-gradient(135deg,var(--terra),var(--coral))"></span>Tier 1 · primary expertise</span>
        <span class="lk"><span class="sw" style="background:var(--ochre-soft);border:1px solid #f0d690"></span>Tier 2 · published work</span>
        <span class="lk"><span class="sw" style="background:var(--sage-soft);border:1px solid #cfe0b1"></span>Tier 3 · commentary</span>
        <span class="lk"><span class="sw" style="background:#fff;border:1px solid var(--line)"></span>Tier 4 · familiar</span>
      </div>
    </div>
  </section>

  <section class="section wrap" data-screen-label="Assets">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--moss)"></span>§ Assets and contact</span>
        <h2>Press <em>routes</em>.</h2>
      </div>
      <div class="sec-head-r">/ direct</div>
    </div>

    <div class="pkassets rv">
      <a class="pkasset aw-1" href="/evidence">
        <span class="ic">§</span>
        <div class="text"><h5>Evidence index</h5><span class="desc">Sources for role, case studies, publications, and code.</span></div>
        <span class="arr">Open</span>
      </a>
      <a class="pkasset aw-2" href="/publications">
        <span class="ic">★</span>
        <div class="text"><h5>Publications</h5><span class="desc">Live article URLs plus PDF archive.</span></div>
        <span class="arr">Open</span>
      </a>
      <a class="pkasset aw-3" href={`mailto:${site.email}`}>
        <span class="ic">→</span>
        <div class="text"><h5>Direct press contact</h5><span class="desc">{site.email}</span></div>
        <span class="arr">Email</span>
      </a>
      <a class="pkasset aw-4" href={site.social.linkedin} target="_blank" rel="noreferrer">
        <span class="ic">in</span>
        <div class="text"><h5>LinkedIn</h5><span class="desc">Profile verification and career context.</span></div>
        <span class="arr">Open</span>
      </a>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded',()=>{
      document.querySelectorAll('.pkpanel-copy').forEach(btn=>{
        btn.addEventListener('click',async()=>{
          const id=btn.dataset.copy;
          const el=document.getElementById(id);
          if(!el)return;
          try{await navigator.clipboard.writeText(el.textContent.trim());
            btn.classList.add('copied');
            btn.textContent='copied';
            setTimeout(()=>{btn.classList.remove('copied');btn.textContent='copy';},1800);
          }catch(e){}
        });
      });
    });
  </script>
</SiteLayout>
