---
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="Tayyub Yaqoob · AI analytics systems, publications, and evidence"
  description="UK-based senior digital analyst focused on AI analytics systems, technical publications, recognition, and evidence-backed technical credibility."
  pathname="/"
  footerTitle="Work together or ask for closer detail."
  footerLead="Senior roles, consulting, expert commentary, conference talks, and reference checks. I reply directly from my inbox, usually within 48 hours on weekdays."
>
  <style slot="head">
    /* ── Hero ── */
    .hero-grid{align-items:center}
    .hero-grid h1{font-size:clamp(46px,6vw,86px);line-height:.98;letter-spacing:-.028em}
    .lede.lines{display:flex;flex-direction:column;gap:4px;font-size:16px;line-height:1.5;color:var(--ink-2);max-width:46ch}
    .lede.lines b{color:var(--ink);font-weight:600}
    .outlet-strip{display:flex;flex-wrap:wrap;align-items:center;gap:0;margin-top:28px;padding-top:18px;border-top:1px solid var(--line)}
    .outlet-strip .lab{font-family:var(--mono);font-size:9.5px;letter-spacing:.14em;color:var(--muted);text-transform:uppercase;margin-right:14px}
    .outlet-strip span:not(.lab){font-family:var(--serif);font-style:italic;font-size:17px;color:var(--ink-2);padding:0 14px;border-right:1px solid var(--line);transition:color .25s}
    .outlet-strip span:not(.lab):last-child{border-right:0}
    .outlet-strip span:not(.lab):hover{color:var(--terra)}
    @media (max-width:780px){
      .outlet-strip span:not(.lab){font-size:14px;padding:0 10px}
    }

    /* Portrait card (clean, no gimmicks) */
    .portrait-card{position:relative;aspect-ratio:4/5;max-width:380px;margin-left:auto;border-radius:14px;overflow:hidden;background:var(--bg-soft);border:1px solid var(--line);box-shadow:0 18px 50px rgba(60,40,20,.18)}
    .portrait-card img{width:100%;height:100%;object-fit:cover;filter:saturate(.92) contrast(1.04)}
    .portrait-card::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(26,23,20,.55));pointer-events:none}
    .portrait-cap{position:absolute;left:18px;bottom:18px;right:18px;display:flex;justify-content:space-between;align-items:end;color:#fff;font-family:var(--mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;z-index:2}
    .portrait-cap b{font-family:var(--serif);font-style:italic;font-size:20px;letter-spacing:0;text-transform:none;font-weight:400;color:#fff;display:block;margin-bottom:2px}
    .portrait-cap span.role{display:block;font-size:10.5px;letter-spacing:.04em;color:rgba(255,255,255,.75);text-transform:none;line-height:1.3;font-family:var(--sans);font-weight:500}
    .portrait-cap .yr{font-family:var(--mono);font-size:10px;color:rgba(255,255,255,.65)}
    @media (max-width:880px){.portrait-card{margin:24px auto 0;max-width:100%}}

    /* ── Final CTA section ── */
    .closer{background:linear-gradient(160deg,#fff,var(--bg-soft));border:1px solid var(--line);border-radius:14px;padding:48px 52px;display:grid;grid-template-columns:1.4fr 1fr;gap:32px;align-items:end;box-shadow:var(--shadow-1)}
    .closer h2{font-family:var(--serif);font-weight:400;font-size:clamp(32px,3.8vw,52px);line-height:1.02;letter-spacing:-.02em;text-wrap:balance}
    .closer h2 em{font-style:italic;color:var(--terra)}
    .closer .lead{font-size:15px;color:var(--ink-2);line-height:1.65;margin-top:14px;max-width:54ch}
    .closer .right{display:flex;flex-direction:column;gap:18px;align-items:flex-end}
    .closer .right ul{list-style:none;display:flex;flex-direction:column;gap:6px;text-align:right;font-family:var(--mono);font-size:11px;color:var(--ink-2);letter-spacing:.04em;text-transform:uppercase}
    .closer .right ul li::after{content:"";display:inline-block;width:14px;height:1px;background:var(--terra);margin-left:8px;vertical-align:middle}
    @media (max-width:780px){.closer{grid-template-columns:1fr;padding:32px 26px}.closer .right{align-items:flex-start}.closer .right ul{text-align:left}.closer .right ul li::after{display:none}}

    /* Industry distribution bar */
    .indust-bar{display:flex;width:100%;height:18px;border-radius:9px;overflow:hidden;border:1px solid var(--line);margin-top:18px;background:#fff}
    .indust-bar span{display:block;height:100%;transform:scaleX(0);transform-origin:left;transition:transform 1.2s cubic-bezier(.4,0,.2,1)}
    .indust-bar.in span{transform:scaleX(1)}
    .indust-bar span:nth-child(1){background:#1a1714}
    .indust-bar span:nth-child(2){background:var(--terra)}
    .indust-bar span:nth-child(3){background:var(--ochre)}
    .indust-bar span:nth-child(4){background:var(--moss)}
    .indust-bar span:nth-child(5){background:var(--coral)}
    .indust-bar span:nth-child(1){transition-delay:.05s}
    .indust-bar span:nth-child(2){transition-delay:.15s}
    .indust-bar span:nth-child(3){transition-delay:.25s}
    .indust-bar span:nth-child(4){transition-delay:.35s}
    .indust-bar span:nth-child(5){transition-delay:.45s}
    .indust-key{display:flex;flex-wrap:wrap;gap:14px;margin-top:8px;font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
    .indust-key .k{display:inline-flex;align-items:center;gap:6px}
    .indust-key .sw{width:9px;height:9px;border-radius:2px;display:inline-block}

    /* Radial dial metric strip */
    .dials{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:28px}
    .dial{background:#fff;border:1px solid var(--line);border-radius:var(--r-md);padding:18px;display:flex;flex-direction:column;align-items:center;gap:6px;text-align:center;transition:transform .3s,border-color .3s,box-shadow .3s;position:relative;overflow:hidden}
    .dial::before{content:"";position:absolute;top:0;left:50%;transform:translateX(-50%);width:40%;height:2px;background:linear-gradient(90deg,transparent,var(--terra),transparent);opacity:0;transition:opacity .35s}
    .dial:hover{transform:translateY(-2px);border-color:var(--line-2);box-shadow:var(--shadow-1)}
    .dial:hover::before{opacity:1}
    .dial-svg{position:relative;width:110px;height:110px}
    .dial-svg svg{width:100%;height:100%}
    .dial .bg-ring{fill:none;stroke:var(--bg-soft);stroke-width:6}
    .dial .fg-ring{fill:none;stroke-width:6;stroke-linecap:round;stroke-dasharray:251;stroke-dashoffset:251;transform:rotate(-90deg);transform-origin:center;transition:stroke-dashoffset 1.6s cubic-bezier(.4,0,.2,1)}
    .dials.in .fg-ring{stroke-dashoffset:var(--off)}
    .dial.d-1 .fg-ring{stroke:var(--terra)}
    .dial.d-2 .fg-ring{stroke:var(--ochre)}
    .dial.d-3 .fg-ring{stroke:var(--moss)}
    .dial.d-4 .fg-ring{stroke:var(--coral)}
    .dial .num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-size:30px;font-style:italic;color:var(--ink);letter-spacing:-.01em;line-height:1}
    .dial .num em{font-style:normal;font-size:18px;color:var(--terra);margin-left:1px}
    .dial .k{font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase;margin-top:4px}
    .dial .sub{font-size:12px;color:var(--ink-2);line-height:1.45;max-width:22ch}
    @media (max-width:880px){.dials{grid-template-columns:1fr 1fr}}

    /* Posters */
    .poster-strip{display:flex;flex-direction:column;gap:14px;margin-top:18px}
    .poster{position:relative;background:#fff;border:1px solid var(--line);border-radius:var(--r-lg);padding:24px;display:grid;grid-template-columns:1.5fr 1fr;gap:24px;align-items:stretch;overflow:hidden;transition:transform .35s cubic-bezier(.2,.7,.1,1),box-shadow .35s,border-color .25s;text-decoration:none;color:inherit}
    .poster:hover{transform:translateY(-3px);box-shadow:var(--shadow-2);border-color:var(--line-2)}
    .poster::before{content:"";position:absolute;left:0;top:0;width:4px;height:100%;background:var(--terra)}
    .poster.p-2::before{background:var(--ochre)}
    .poster.p-3::before{background:var(--moss)}
    .poster .ptag{font-family:var(--mono);font-size:10.5px;letter-spacing:.1em;color:var(--terra);text-transform:uppercase}
    .poster.p-2 .ptag{color:#8a5e15}
    .poster.p-3 .ptag{color:var(--moss)}
    .poster .ph{font-family:var(--serif);font-weight:400;font-size:clamp(22px,2.4vw,32px);line-height:1.05;letter-spacing:-.015em;margin-top:6px;color:var(--ink)}
    .poster .ph em{font-style:italic;color:var(--terra)}
    .poster.p-2 .ph em{color:#8a5e15}
    .poster.p-3 .ph em{color:var(--moss)}
    .poster .pdesc{font-size:14px;color:var(--ink-2);line-height:1.6;margin-top:8px;max-width:50ch}
    .poster-viz{margin-top:14px;background:var(--bg-soft);border:1px solid var(--line);border-radius:12px;padding:14px;position:relative;overflow:hidden}
    .poster-viz svg{width:100%;height:auto;display:block}
    .pgutter{display:flex;flex-direction:column;justify-content:space-between;gap:14px;padding:6px 0}
    .pgutter .pstats{display:flex;flex-direction:column;gap:14px;padding-top:6px;border-top:1px dashed var(--line);margin-top:6px}
    .pstat{display:flex;flex-direction:column;gap:2px}
    .pstat .pv{font-family:var(--serif);font-size:26px;line-height:1;letter-spacing:-.01em;color:var(--ink)}
    .pstat .pv em{font-style:italic;color:var(--terra)}
    .poster.p-2 .pstat .pv em{color:#8a5e15}
    .poster.p-3 .pstat .pv em{color:var(--moss)}
    .pstat .pk{font-family:var(--mono);font-size:9.5px;letter-spacing:.08em;color:var(--muted);text-transform:uppercase}
    .pchips{display:flex;flex-wrap:wrap;gap:5px;margin-top:12px}
    .pchips span{font-family:var(--mono);font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;padding:4px 8px;border-radius:999px;border:1px solid var(--line);background:#fff;color:var(--ink-2)}
    .pcta{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;color:var(--terra);text-transform:uppercase;margin-top:14px}
    .pcta::after{content:"→";transition:transform .25s}
    .poster:hover .pcta::after{transform:translateX(3px)}
    .pv-fc .grid line{stroke:var(--line);stroke-width:1;stroke-dasharray:2 4;opacity:.6}
    .pv-fc .axis-lbl{font-family:var(--mono);font-size:9px;fill:var(--muted);letter-spacing:.06em}
    .pv-fc .hist{stroke:var(--terra);stroke-width:2.4;fill:none;stroke-linecap:round;stroke-dasharray:600;stroke-dashoffset:600}
    .pv-fc .band{fill:var(--ochre);fill-opacity:.22;opacity:0;transition:opacity .9s ease 1s}
    .pv-fc .fc{stroke:var(--ochre);stroke-width:2;fill:none;stroke-dasharray:5 4;stroke-linecap:round;stroke-dashoffset:300}
    .pv-fc .now-line{stroke:var(--ink);stroke-width:1;stroke-dasharray:3 3;opacity:.6}
    .pv-fc .now-lbl{font-family:var(--mono);font-size:9px;fill:var(--ink);letter-spacing:.06em;text-transform:uppercase}
    .poster.in .pv-fc .hist{transition:stroke-dashoffset 1.6s cubic-bezier(.4,0,.2,1);stroke-dashoffset:0}
    .poster.in .pv-fc .fc{transition:stroke-dashoffset 1.4s cubic-bezier(.4,0,.2,1) 1.3s;stroke-dashoffset:0}
    .poster.in .pv-fc .band{opacity:1}
    .pv-rv .layer{fill:var(--line-2);transform-origin:bottom;transform:scaleY(0);transition:transform 1.1s cubic-bezier(.4,0,.2,1)}
    .pv-rv .layer.l-pos{fill:#a8c08a;transition-delay:.5s}
    .pv-rv .layer.l-neu{fill:#e7d6a8;transition-delay:.7s}
    .pv-rv .layer.l-neg{fill:#e8a995;transition-delay:.9s}
    .poster.in .pv-rv .layer{transform:scaleY(1)}
    .pv-rv .axis-lbl{font-family:var(--mono);font-size:9px;fill:var(--muted);letter-spacing:.06em}
    .pv-rv .flag-line{stroke:var(--ink);stroke-width:1;stroke-dasharray:3 3}
    .pv-rv .flag{font-family:var(--mono);font-size:8.5px;fill:var(--ink);letter-spacing:.04em}
    .pv-sp .panel{fill:#fff;stroke:var(--line);stroke-width:1}
    .pv-sp .panel-h{font-family:var(--mono);font-size:9px;fill:var(--muted);letter-spacing:.1em;text-transform:uppercase}
    .pv-sp .result{font-family:var(--sans);font-size:9px;fill:var(--ink-2)}
    .pv-sp .result-hit{fill:var(--moss);font-weight:600}
    .pv-sp .row{fill:#fff;stroke:var(--line);stroke-width:.8}
    .pv-sp .row-hit{fill:#fff5d7;stroke:var(--ochre)}
    .pv-sp .arrow{stroke:var(--terra);stroke-width:1.5;fill:var(--terra);stroke-dasharray:200;stroke-dashoffset:200;animation:none}
    .poster.in .pv-sp .arrow{animation:drawSparkArrow 1.4s cubic-bezier(.4,0,.2,1) .8s forwards}
    @keyframes drawSparkArrow{to{stroke-dashoffset:0}}
    .pv-sp .scrub-line{stroke:var(--line);stroke-width:1}
    .pv-sp .scrub-marker{fill:var(--terra)}
    .pv-sp .scrub-lbl{font-family:var(--mono);font-size:8.5px;fill:var(--muted);letter-spacing:.06em}
    @media (max-width:780px){.poster{grid-template-columns:1fr}.pgutter{flex-direction:row;align-items:end;flex-wrap:wrap}.pgutter .pstats{flex-direction:row;flex-wrap:wrap;border-top:0}}

    /* Press cell legacy styles (used by marquee) */
    .press-cell{padding:22px 16px;min-height:104px;gap:10px;align-items:center;text-align:center}
    .press-cell .pn-fallback{display:flex;align-items:center;justify-content:center;height:34px;line-height:1;letter-spacing:-.02em;font-weight:800;font-size:18px}
    .press-cell .pk{font-family:var(--mono);font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-top:2px}
    .brand-bbc .pn-fallback{font-family:Arial,sans-serif;font-weight:900;color:#000;letter-spacing:-1px}
    .brand-bbc .pn-fallback b{background:#000;color:#fff;padding:5px 6px;margin-right:2px;font-size:15px;display:inline-block;line-height:1}
    .brand-bbc .pn-fallback b:last-child{margin-right:0}
    .brand-tesco .pn-fallback{color:#ee1c2e;font-family:Helvetica,Arial,sans-serif;font-style:italic;font-weight:800;font-size:24px;letter-spacing:-.03em;position:relative;display:inline-flex;padding-bottom:3px}
    .brand-tesco .pn-fallback::after{content:"";position:absolute;left:0;right:0;bottom:0;height:2px;background:#0064b1;border-radius:1px}
    .brand-gm .pn-fallback{color:#0046ad;font-family:Inter,sans-serif;font-weight:800;font-size:17px;letter-spacing:-.02em}
    .brand-royal-london .pn-fallback{color:#1d3a6e;font-family:Georgia,serif;font-weight:600;font-size:18px;letter-spacing:.01em}
    .brand-nerdwallet .pn-fallback{color:#008a05;font-family:Inter,sans-serif;font-weight:800;font-size:18px;letter-spacing:-.01em}
  </style>

  <section class="hero wrap" data-screen-label="01 Intro" id="top">
    <div class="hero-grid">
      <div>
        <div class="eyebrow rv" data-parallax="6">
          <span class="dot"></span>
          Tayyub Yaqoob · Stirling, UK · Open 2026
        </div>
        <h1 class="rv d1">
          Senior <span class="grad">analyst</span>, writer, and <span class="marked">engineer</span> working on AI, analytics, and measurement.
        </h1>
        <p class="lede lines rv d2">
          <span>35+ technical features in <b>Cointelegraph</b> and <b>AlphaWire</b>.</span>
          <span>Cited as expert source by <b>CCN</b>.</span>
          <span>Peer reviewer for <b>IGI Global</b>.</span>
        </p>
        <div class="hero-cta rv d3">
          <a href="/case-studies" class="btn btn-primary" data-magnet>See the work →</a>
          <a href="/publications" class="btn btn-ghost" data-magnet>Read the publications ↗</a>
        </div>
        <div class="outlet-strip rv d4">
          <span class="lab">Published / cited in</span>
          <span>Cointelegraph</span>
          <span>AlphaWire</span>
          <span>CCN</span>
          <span>IGI Global</span>
          <span>8 Million Stories</span>
        </div>
      </div>

      <div class="portrait-card rv d2">
        <img src="/assets/portrait.jpeg" alt="Tayyub Yaqoob" />
        <div class="portrait-cap">
          <div>
            <b>Tayyub Yaqoob</b>
            <span class="role">Senior Digital Analyst · 8 Million Stories</span>
          </div>
          <span class="yr">2026</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section wrap first" data-screen-label="Clients">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--terra)"></span>§ Client environments</span>
        <h2>Built for analyst and <em>client teams</em> at:</h2>
        <p>A selection of named environments where the work has been deployed.</p>
      </div>
      <div class="sec-head-r">/ selected examples</div>
    </div>

    <div class="press-marquee rv">
      <div class="press-marquee-track">
        <div class="press-cell brand-bbc"><span class="pn-fallback"><b>B</b><b>B</b><b>C</b></span><span class="pk">Media · UK</span></div>
        <div class="press-cell brand-tesco"><span class="pn-fallback">Tesco</span><span class="pk">Financial · UK</span></div>
        <div class="press-cell brand-gm"><span class="pn-fallback">General Mills</span><span class="pk">Consumer · global</span></div>
        <div class="press-cell brand-royal-london"><span class="pn-fallback">Royal London</span><span class="pk">Insurance · UK</span></div>
        <div class="press-cell brand-nerdwallet"><span class="pn-fallback">NerdWallet</span><span class="pk">Personal finance</span></div>
        <div class="press-cell brand-bbc" aria-hidden="true"><span class="pn-fallback"><b>B</b><b>B</b><b>C</b></span><span class="pk">Media · UK</span></div>
        <div class="press-cell brand-tesco" aria-hidden="true"><span class="pn-fallback">Tesco</span><span class="pk">Financial · UK</span></div>
        <div class="press-cell brand-gm" aria-hidden="true"><span class="pn-fallback">General Mills</span><span class="pk">Consumer · global</span></div>
        <div class="press-cell brand-royal-london" aria-hidden="true"><span class="pn-fallback">Royal London</span><span class="pk">Insurance · UK</span></div>
        <div class="press-cell brand-nerdwallet" aria-hidden="true"><span class="pn-fallback">NerdWallet</span><span class="pk">Personal finance</span></div>
      </div>
    </div>

    <div class="indust-bar rv">
      <span style="flex:0 0 35%"></span>
      <span style="flex:0 0 22%"></span>
      <span style="flex:0 0 18%"></span>
      <span style="flex:0 0 15%"></span>
      <span style="flex:0 0 10%"></span>
    </div>
    <div class="indust-key rv">
      <span class="k"><span class="sw" style="background:#1a1714"></span>Financial 35%</span>
      <span class="k"><span class="sw" style="background:var(--terra)"></span>Media 22%</span>
      <span class="k"><span class="sw" style="background:var(--ochre)"></span>Consumer 18%</span>
      <span class="k"><span class="sw" style="background:var(--moss)"></span>Insurance 15%</span>
      <span class="k"><span class="sw" style="background:var(--coral)"></span>Personal finance 10%</span>
    </div>

    <div class="dials rv">
      <div class="dial d-1" style="--off:75">
        <div class="dial-svg">
          <svg viewBox="0 0 90 90"><circle class="bg-ring" cx="45" cy="45" r="40"/><circle class="fg-ring" cx="45" cy="45" r="40"/></svg>
          <div class="num"><span data-count="35">0</span><em>+</em></div>
        </div>
        <span class="k">Technical articles</span>
        <span class="sub">Cointelegraph and AlphaWire combined, plus archive.</span>
      </div>
      <div class="dial d-2" style="--off:170">
        <div class="dial-svg">
          <svg viewBox="0 0 90 90"><circle class="bg-ring" cx="45" cy="45" r="40"/><circle class="fg-ring" cx="45" cy="45" r="40"/></svg>
          <div class="num"><span data-count="3">0</span></div>
        </div>
        <span class="k">IGI Global reviews</span>
        <span class="sub">Publisher-led peer-review record.</span>
      </div>
      <div class="dial d-3" style="--off:42">
        <div class="dial-svg">
          <svg viewBox="0 0 90 90"><circle class="bg-ring" cx="45" cy="45" r="40"/><circle class="fg-ring" cx="45" cy="45" r="40"/></svg>
          <div class="num"><span data-count="50">0</span><em>+</em></div>
        </div>
        <span class="k">Teams on systems</span>
        <span class="sub">Operational trust across recurring workflows.</span>
      </div>
      <div class="dial d-4" style="--off:130">
        <div class="dial-svg">
          <svg viewBox="0 0 90 90"><circle class="bg-ring" cx="45" cy="45" r="40"/><circle class="fg-ring" cx="45" cy="45" r="40"/></svg>
          <div class="num"><span data-count="12">0</span><em>+</em></div>
        </div>
        <span class="k">AI / ML credentials</span>
        <span class="sub">Google, AWS, LinkedIn Learning, related training.</span>
      </div>
    </div>
  </section>

  <section class="section wrap" id="featured" data-screen-label="03 Selected work">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--ochre)"></span>§ Production work</span>
        <h2>Three production <em>systems</em>.</h2>
        <p>Each poster shows the technical approach, the visualization that fits the work, and the stack underneath.</p>
      </div>
      <div class="sec-head-r"><a href="/case-studies">All case studies →</a></div>
    </div>

    <div class="poster-strip">
      <a class="poster p-1 rv" href="/case-studies">
        <div>
          <span class="ptag">/ 01 · Forecasting · BigQuery · GA4</span>
          <h3 class="ph">Channel and query <em>forecasting</em>.</h3>
