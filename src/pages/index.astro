---
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="Tayyub Yaqoob · AI analytics systems, publications, and evidence"
  description="UK-based senior digital analyst focused on AI analytics systems, technical publications, recognition, and evidence-backed technical credibility."
  pathname="/"
  footerTitle="Work together or ask for closer detail."
  footerLead="Senior roles, consulting, expert commentary, conference talks, and reference checks. I reply directly from my inbox, usually within 48 hours on weekdays."
>
  <style slot="head">
    /* ── Hero: credentials eyebrow + proof badges + latest-published card ── */
    .hero-grid{align-items:start}

    /* Eyebrow with portrait */
    .eyebrow-rich{display:inline-flex;align-items:center;gap:12px;padding:6px 16px 6px 6px;border-radius:999px;background:#fff;border:1px solid var(--line);box-shadow:var(--shadow-1);font-family:var(--mono);font-size:11px;letter-spacing:.02em;color:var(--ink-2);text-transform:none;line-height:1.3;max-width:100%;flex-wrap:wrap}
    .eyebrow-rich .eb-portrait{width:34px;height:34px;border-radius:50%;object-fit:cover;flex-shrink:0;border:1.5px solid #fff;box-shadow:0 1px 4px rgba(60,40,20,.18);filter:saturate(.92) contrast(1.04)}
    .eyebrow-rich .eb-line{font-weight:500;color:var(--ink)}
    .eyebrow-rich .eb-line b{color:var(--terra);font-weight:600}
    @media (max-width:540px){.eyebrow-rich{font-size:10.5px;padding:6px 14px 6px 6px}.eyebrow-rich .eb-portrait{width:30px;height:30px}}

    /* Proof badges */
    .proof-badges{display:flex;flex-wrap:wrap;gap:8px;margin-top:20px}
    .pb{display:inline-flex;align-items:center;gap:7px;padding:7px 13px;border-radius:999px;background:#fff;border:1px solid var(--line);font-family:'Inter',sans-serif;font-size:12.5px;letter-spacing:-.005em;color:var(--ink-2);transition:border-color .25s,background .25s,transform .25s,box-shadow .25s}
    .pb:hover{border-color:var(--terra);background:var(--terra-soft);transform:translateY(-1px);box-shadow:var(--shadow-1)}
    .pb b{color:var(--ink);font-weight:600}
    .pb .pb-ic{color:var(--ochre);font-size:13px;line-height:1}

    /* Latest published magazine-cover card */
    .latest{position:relative;display:flex;flex-direction:column;background:linear-gradient(170deg,#fff,var(--bg-soft));border:1px solid var(--line);border-radius:14px;overflow:hidden;text-decoration:none;color:inherit;box-shadow:0 18px 50px rgba(60,40,20,.16);max-width:440px;margin-left:auto;transition:transform .4s cubic-bezier(.2,.7,.1,1),box-shadow .4s}
    .latest:hover{transform:translateY(-5px) rotate(-.6deg);box-shadow:0 28px 70px rgba(60,40,20,.26)}
    .latest::before{content:"";position:absolute;left:0;right:0;top:0;height:5px;background:linear-gradient(90deg,var(--terra),var(--coral),var(--ochre));z-index:2}
    .latest-h{display:flex;justify-content:space-between;align-items:end;gap:12px;padding:22px 24px 12px;border-bottom:2px solid var(--ink);position:relative;z-index:1;flex-wrap:wrap}
    .latest-h .outlet{font-family:Georgia,'Instrument Serif',serif;font-weight:900;font-size:30px;letter-spacing:-.045em;color:var(--ink);line-height:.85}
    .latest-h .format{font-family:var(--mono);font-size:9.5px;letter-spacing:.14em;color:var(--terra);text-transform:uppercase;font-weight:600;text-align:right;line-height:1.4}
    .latest-body{padding:18px 24px 14px;display:flex;flex-direction:column;gap:10px;flex:1}
    .latest-tag{font-family:var(--mono);font-size:10px;letter-spacing:.16em;color:var(--terra);text-transform:uppercase;font-weight:700;display:inline-flex;align-items:center;gap:8px}
    .latest-tag::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--terra);animation:pulse 2s infinite;flex-shrink:0}
    .latest-title{font-family:var(--serif);font-weight:400;font-size:clamp(22px,2.4vw,28px);line-height:1.1;letter-spacing:-.015em;color:var(--ink);margin-top:2px}
    .latest-title em{font-style:italic;color:var(--terra)}
    .latest:hover .latest-title em{color:var(--coral)}
    .latest-desc{font-size:13.5px;color:var(--ink-2);line-height:1.6;max-width:50ch;margin-top:2px}
    .latest-foot{display:flex;justify-content:space-between;align-items:center;padding:14px 24px 18px;border-top:1px dashed var(--line);font-family:var(--mono);font-size:11px;letter-spacing:.04em;color:var(--muted);gap:14px;flex-wrap:wrap;background:rgba(232,226,210,.25)}
    .latest-cta{color:var(--terra);font-weight:700;text-transform:uppercase;font-size:10.5px;letter-spacing:.1em;display:inline-flex;align-items:center;gap:5px}
    .latest-cta::after{content:"↗";transition:transform .25s}
    .latest:hover .latest-cta::after{transform:translate(2px,-2px)}
    .latest-more{color:var(--ink-2);font-size:10px;letter-spacing:.08em;text-transform:uppercase;font-weight:500}
    .latest .corner-stamp{position:absolute;top:18px;right:20px;width:54px;height:54px;border:1.5px solid var(--ochre);border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--ochre);font-family:var(--mono);font-size:7.5px;letter-spacing:.12em;line-height:1.3;background:rgba(254,247,237,.85);transform:rotate(-8deg);text-transform:uppercase;text-align:center;z-index:3;pointer-events:none}
    .latest .corner-stamp b{font-family:'Instrument Serif',Georgia,serif;font-style:italic;font-size:13px;letter-spacing:0;text-transform:none;font-weight:400;color:var(--ochre)}
    @media (max-width:880px){.latest{margin:24px auto 0;max-width:100%}.latest .corner-stamp{display:none}}

    /* ── Industry distribution bar ── */
    .indust-bar{display:flex;width:100%;height:18px;border-radius:9px;overflow:hidden;border:1px solid var(--line);margin-top:18px;background:#fff}
    .indust-bar span{display:block;height:100%;transform:scaleX(0);transform-origin:left;transition:transform 1.2s cubic-bezier(.4,0,.2,1)}
    .indust-bar.in span{transform:scaleX(1)}
    .indust-bar span:nth-child(1){background:#1a1714}
    .indust-bar span:nth-child(2){background:var(--terra)}
    .indust-bar span:nth-child(3){background:var(--ochre)}
    .indust-bar span:nth-child(4){background:var(--moss)}
    .indust-bar span:nth-child(5){background:var(--coral)}
    .indust-bar span:nth-child(1){transition-delay:.05s}
    .indust-bar span:nth-child(2){transition-delay:.15s}
    .indust-bar span:nth-child(3){transition-delay:.25s}
    .indust-bar span:nth-child(4){transition-delay:.35s}
    .indust-bar span:nth-child(5){transition-delay:.45s}
    .indust-key{display:flex;flex-wrap:wrap;gap:14px;margin-top:8px;font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
    .indust-key .k{display:inline-flex;align-items:center;gap:6px}
    .indust-key .sw{width:9px;height:9px;border-radius:2px;display:inline-block}

    /* ── Radial dial metric strip ── */
    .dials{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:28px}
    .dial{background:#fff;border:1px solid var(--line);border-radius:var(--r-md);padding:18px;display:flex;flex-direction:column;align-items:center;gap:6px;text-align:center;transition:transform .3s,border-color .3s,box-shadow .3s;position:relative;overflow:hidden}
    .dial::before{content:"";position:absolute;top:0;left:50%;transform:translateX(-50%);width:40%;height:2px;background:linear-gradient(90deg,transparent,var(--terra),transparent);opacity:0;transition:opacity .35s}
    .dial:hover{transform:translateY(-2px);border-color:var(--line-2);box-shadow:var(--shadow-1)}
    .dial:hover::before{opacity:1}
    .dial-svg{position:relative;width:110px;height:110px}
    .dial-svg svg{width:100%;height:100%}
    .dial .bg-ring{fill:none;stroke:var(--bg-soft);stroke-width:6}
    .dial .fg-ring{fill:none;stroke-width:6;stroke-linecap:round;stroke-dasharray:251;stroke-dashoffset:251;transform:rotate(-90deg);transform-origin:center;transition:stroke-dashoffset 1.6s cubic-bezier(.4,0,.2,1)}
    .dials.in .fg-ring{stroke-dashoffset:var(--off)}
    .dial.d-1 .fg-ring{stroke:var(--terra)}
    .dial.d-2 .fg-ring{stroke:var(--ochre)}
    .dial.d-3 .fg-ring{stroke:var(--moss)}
    .dial.d-4 .fg-ring{stroke:var(--coral)}
    .dial .num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-size:30px;font-style:italic;color:var(--ink);letter-spacing:-.01em;line-height:1}
    .dial .num em{font-style:normal;font-size:18px;color:var(--terra);margin-left:1px}
    .dial .k{font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase;margin-top:4px}
    .dial .sub{font-size:12px;color:var(--ink-2);line-height:1.45;max-width:22ch}
    @media (max-width:880px){.dials{grid-template-columns:1fr 1fr}}

    /* ── Network graph ── */
    .netgraph-shell{position:relative;background:linear-gradient(160deg,#fff,var(--bg-soft));border:1px solid var(--line);border-radius:var(--r-lg);overflow:hidden;box-shadow:var(--shadow-1)}
    .netgraph-shell::before{content:"";position:absolute;inset:0;background-image:radial-gradient(rgba(196,77,44,.07) 1px,transparent 1px);background-size:24px 24px;pointer-events:none;opacity:.5}
    .netgraph{display:block;width:100%;height:auto;position:relative;z-index:1}
    .netgraph .edge{stroke:var(--line-2);stroke-width:1.4;fill:none;stroke-dasharray:6 4;stroke-dashoffset:120;animation:flow 3.5s linear infinite;opacity:.65;transition:stroke .3s,opacity .3s,stroke-width .3s}
    .netgraph .edge.primary{stroke:var(--terra);opacity:.85}
    .netgraph .edge.secondary{opacity:.5;stroke-width:1}
    .netgraph g.node{cursor:pointer}
    .netgraph g.node:hover .node-bg{fill:#fff;stroke:var(--terra);stroke-width:2}
    .netgraph g.node:hover .node-label{fill:var(--terra)}
    .netgraph g.node:hover ~ .edge[data-target],
    .netgraph g.node:hover + .edge{stroke:var(--terra);stroke-width:2;opacity:1}
    .netgraph .node-bg{fill:#fff;stroke:var(--line);stroke-width:1.4;transition:fill .25s,stroke .25s,stroke-width .25s;filter:drop-shadow(0 1px 3px rgba(26,23,20,.08))}
    .netgraph .node-bg.primary{stroke:var(--terra);stroke-width:1.6}
    .netgraph .centre-bg{fill:var(--ink);stroke:none}
    .netgraph .centre-bg-halo{fill:none;stroke:var(--terra);stroke-width:1.4;opacity:.4;animation:haloRing 3s ease-in-out infinite}
    .netgraph .centre-label{fill:#fff;font-family:var(--serif);font-style:italic;font-size:18px;text-anchor:middle;dominant-baseline:middle}
    .netgraph .node-label{fill:var(--ink);font-family:var(--sans);font-size:12.5px;font-weight:600;text-anchor:middle;dominant-baseline:middle;transition:fill .25s}
    .netgraph .node-sub{fill:var(--muted);font-family:var(--mono);font-size:9px;letter-spacing:.08em;text-anchor:middle;dominant-baseline:middle;text-transform:uppercase}
    @keyframes flow{to{stroke-dashoffset:0}}
    @keyframes haloRing{0%,100%{transform:scale(1);opacity:.4}50%{transform:scale(1.15);opacity:.15}}
    .netgraph g.node{transform-origin:center;transform-box:fill-box;transition:transform .3s cubic-bezier(.4,0,.2,1)}
    .netgraph g.node:hover{transform:scale(1.08)}
    @media (max-width:720px){.netgraph-shell{padding:10px}.netgraph .node-sub{display:none}}

    /* ── Three case-study posters ── */
    .poster-strip{display:flex;flex-direction:column;gap:14px;margin-top:18px}
    .poster{position:relative;background:#fff;border:1px solid var(--line);border-radius:var(--r-lg);padding:24px;display:grid;grid-template-columns:1.5fr 1fr;gap:24px;align-items:stretch;overflow:hidden;transition:transform .35s cubic-bezier(.2,.7,.1,1),box-shadow .35s,border-color .25s}
    .poster:hover{transform:translateY(-3px);box-shadow:var(--shadow-2);border-color:var(--line-2)}
    .poster::before{content:"";position:absolute;left:0;top:0;width:4px;height:100%;background:var(--terra)}
    .poster.p-2::before{background:var(--ochre)}
    .poster.p-3::before{background:var(--moss)}
    .poster .ptag{font-family:var(--mono);font-size:10.5px;letter-spacing:.1em;color:var(--terra);text-transform:uppercase}
    .poster.p-2 .ptag{color:var(--ochre-deep,#8a5e15)}
    .poster.p-3 .ptag{color:var(--moss)}
    .poster .ph{font-family:var(--serif);font-weight:400;font-size:clamp(22px,2.4vw,32px);line-height:1.05;letter-spacing:-.015em;margin-top:6px;color:var(--ink)}
    .poster .ph em{font-style:italic;color:var(--terra)}
    .poster.p-2 .ph em{color:var(--ochre-deep,#8a5e15)}
    .poster.p-3 .ph em{color:var(--moss)}
    .poster .pdesc{font-size:14px;color:var(--ink-2);line-height:1.6;margin-top:8px;max-width:50ch}
    .poster-viz{margin-top:14px;background:var(--bg-soft);border:1px solid var(--line);border-radius:12px;padding:14px;position:relative;overflow:hidden}
    .poster-viz svg{width:100%;height:auto;display:block}
    .pgutter{display:flex;flex-direction:column;justify-content:space-between;gap:14px;padding:6px 0}
    .pgutter .pstats{display:flex;flex-direction:column;gap:14px;padding-top:6px;border-top:1px dashed var(--line);margin-top:6px}
    .pstat{display:flex;flex-direction:column;gap:2px}
    .pstat .pv{font-family:var(--serif);font-size:26px;line-height:1;letter-spacing:-.01em;color:var(--ink)}
    .pstat .pv em{font-style:italic;color:var(--terra)}
    .poster.p-2 .pstat .pv em{color:var(--ochre-deep,#8a5e15)}
    .poster.p-3 .pstat .pv em{color:var(--moss)}
    .pstat .pk{font-family:var(--mono);font-size:9.5px;letter-spacing:.08em;color:var(--muted);text-transform:uppercase}
    .pchips{display:flex;flex-wrap:wrap;gap:5px;margin-top:12px}
    .pchips span{font-family:var(--mono);font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;padding:4px 8px;border-radius:999px;border:1px solid var(--line);background:#fff;color:var(--ink-2)}
    .pcta{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;color:var(--terra);text-transform:uppercase;margin-top:14px}
    .pcta::after{content:"→";transition:transform .25s}
    .poster:hover .pcta::after{transform:translateX(3px)}
    /* Forecast poster */
    .pv-fc .grid line{stroke:var(--line);stroke-width:1;stroke-dasharray:2 4;opacity:.6}
    .pv-fc .axis-lbl{font-family:var(--mono);font-size:9px;fill:var(--muted);letter-spacing:.06em}
    .pv-fc .hist{stroke:var(--terra);stroke-width:2.4;fill:none;stroke-linecap:round;stroke-dasharray:600;stroke-dashoffset:600}
    .pv-fc .band{fill:var(--ochre);fill-opacity:.22;opacity:0;transition:opacity .9s ease 1s}
    .pv-fc .fc{stroke:var(--ochre);stroke-width:2;fill:none;stroke-dasharray:5 4;stroke-linecap:round;stroke-dashoffset:300}
    .pv-fc .now-line{stroke:var(--ink);stroke-width:1;stroke-dasharray:3 3;opacity:.6}
    .pv-fc .now-lbl{font-family:var(--mono);font-size:9px;fill:var(--ink);letter-spacing:.06em;text-transform:uppercase}
    .poster.in .pv-fc .hist{transition:stroke-dashoffset 1.6s cubic-bezier(.4,0,.2,1);stroke-dashoffset:0}
    .poster.in .pv-fc .fc{transition:stroke-dashoffset 1.4s cubic-bezier(.4,0,.2,1) 1.3s;stroke-dashoffset:0}
    .poster.in .pv-fc .band{opacity:1}
    /* Sentiment river poster */
    .pv-rv .layer{fill:var(--line-2);transform-origin:bottom;transform:scaleY(0);transition:transform 1.1s cubic-bezier(.4,0,.2,1)}
    .pv-rv .layer.l-pos{fill:#a8c08a;transition-delay:.5s}
    .pv-rv .layer.l-neu{fill:#e7d6a8;transition-delay:.7s}
    .pv-rv .layer.l-neg{fill:#e8a995;transition-delay:.9s}
    .poster.in .pv-rv .layer{transform:scaleY(1)}
    .pv-rv .axis-lbl{font-family:var(--mono);font-size:9px;fill:var(--muted);letter-spacing:.06em}
    .pv-rv .flag-line{stroke:var(--ink);stroke-width:1;stroke-dasharray:3 3}
    .pv-rv .flag{font-family:var(--mono);font-size:8.5px;fill:var(--ink);letter-spacing:.04em}
    /* SERP comparison poster */
    .pv-sp .panel{fill:#fff;stroke:var(--line);stroke-width:1}
    .pv-sp .panel-h{font-family:var(--mono);font-size:9px;fill:var(--muted);letter-spacing:.1em;text-transform:uppercase}
    .pv-sp .result{font-family:var(--sans);font-size:9px;fill:var(--ink-2)}
    .pv-sp .result-hit{fill:var(--moss);font-weight:600}
    .pv-sp .row{fill:#fff;stroke:var(--line);stroke-width:.8}
    .pv-sp .row-hit{fill:#fff5d7;stroke:var(--ochre)}
    .pv-sp .arrow{stroke:var(--terra);stroke-width:1.5;fill:var(--terra);stroke-dasharray:200;stroke-dashoffset:200;animation:none}
    .poster.in .pv-sp .arrow{animation:drawSpark 1.4s cubic-bezier(.4,0,.2,1) .8s forwards}
    .pv-sp .scrub-line{stroke:var(--line);stroke-width:1}
    .pv-sp .scrub-marker{fill:var(--terra)}
    .pv-sp .scrub-lbl{font-family:var(--mono);font-size:8.5px;fill:var(--muted);letter-spacing:.06em}
    @media (max-width:780px){.poster{grid-template-columns:1fr}.pgutter{flex-direction:row;align-items:end;flex-wrap:wrap}.pgutter .pstats{flex-direction:row;flex-wrap:wrap;border-top:0}}

    /* ── Envelope CTA ── */
    .env-wrap{position:relative;margin-top:18px}
    .envelope{position:relative;background:#fff;border:1px solid var(--line);border-radius:12px;overflow:hidden;box-shadow:var(--shadow-1)}
    .env-flap{position:absolute;top:0;left:0;width:100%;height:60%;background:linear-gradient(180deg,var(--bg-soft),#fff);border-bottom:1px solid var(--line);transform-origin:top;transform:rotateX(0);transition:transform 1.2s cubic-bezier(.6,.05,.3,1) .25s;z-index:3;clip-path:polygon(0 0,100% 0,50% 100%)}
    .env-wrap.in .env-flap{transform:rotateX(180deg)}
    .env-stamp{position:absolute;top:20px;right:24px;width:78px;height:78px;border:1.5px solid var(--terra);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--terra);font-family:var(--mono);font-size:8.5px;letter-spacing:.1em;text-transform:uppercase;line-height:1.3;background:rgba(254,247,237,.5);transform:rotate(-8deg);z-index:4;opacity:0;transition:opacity .8s ease 1.5s,transform .8s ease 1.5s}
    .env-wrap.in .env-stamp{opacity:1;transform:rotate(-8deg) translateY(-4px)}
    .env-stamp b{font-family:var(--serif);font-size:18px;letter-spacing:0;line-height:1;font-style:italic;text-transform:none;margin-top:2px}
    .env-body{position:relative;padding:90px 40px 38px;display:grid;grid-template-columns:1.5fr 1fr;gap:32px;align-items:end;z-index:1}
    .env-body::before{content:"";position:absolute;inset:18px;border:1px dashed var(--line);border-radius:8px;pointer-events:none;opacity:.6}
    .env-message .typed{font-family:var(--mono);font-size:13px;line-height:1.7;color:var(--ink);max-width:60ch;opacity:0;transition:opacity .8s ease 1.2s;border-left:2px solid var(--terra);padding-left:16px}
    .env-wrap.in .env-message .typed{opacity:1}
    .env-message h2{font-family:var(--serif);font-weight:400;font-size:clamp(28px,3vw,40px);line-height:1.05;letter-spacing:-.018em;margin-top:6px}
    .env-message h2 em{font-style:italic;color:var(--terra)}
    .env-message .from{margin-top:18px;font-family:var(--mono);font-size:10.5px;color:var(--muted);letter-spacing:.06em;text-transform:uppercase}
    .env-cta{display:flex;flex-direction:column;align-items:flex-end;gap:10px}
    .env-cta .reqs{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:.06em;text-transform:uppercase;text-align:right}
    .env-cta .reqs li{list-style:none;padding:3px 0;display:flex;align-items:center;gap:6px;justify-content:flex-end}
    .env-cta .reqs li::after{content:"";width:16px;height:1px;background:var(--terra);opacity:.6}
    @media (max-width:780px){.env-body{grid-template-columns:1fr;padding:84px 24px 28px}.env-cta{align-items:flex-start}.env-cta .reqs li{justify-content:flex-start}.env-cta .reqs li::after{display:none}.env-stamp{top:14px;right:14px;width:64px;height:64px}}
  </style>

  <section class="hero wrap" data-screen-label="01 Intro" id="top">
    <div class="hero-grid">
      <div>
        <div class="eyebrow-rich rv" data-parallax="6">
          <img src="/assets/portrait.jpeg" class="eb-portrait" alt="Tayyub Yaqoob" />
          <span class="eb-line"><b>Published in Cointelegraph</b> · Cited by CCN · Peer reviewer for IGI Global · Senior analyst, 8 Million Stories</span>
        </div>
        <h1 class="rv d1">
          Writing, peer review, and analytics engineering at the intersection of <span class="grad">AI</span>, <span class="marked">measurement</span>, and digital trust.
        </h1>
        <p class="lede rv d2">
          35+ technical features for <b>Cointelegraph</b> and <b>AlphaWire</b> on AI-driven trading, agentic fraud, and quantum-resistant systems. Three completed chapter reviews for <b>IGI Global</b> on CBDCs, IoT-banking consensus, and AI-FinTech. Expert source for <b>CCN</b> on AI-trading risk. Senior Digital Analyst at <b>8 Million Stories</b>, building forecasting, sentiment monitoring, and AI-search visibility systems for client teams.
        </p>
        <div class="proof-badges rv d3">
          <span class="pb"><span class="pb-ic">★</span>Bylined · <b>35+ pieces</b></span>
