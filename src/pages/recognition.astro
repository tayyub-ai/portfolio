---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
import { publicationArchive } from "../data/publications";
---

<SiteLayout
  title="Recognition"
  description="External recognition, peer review, expert-source citations, and supporting context for the public record."
  pathname="/recognition"
  crumbs={[{ label: "Home", href: "/" }, { label: "Recognition" }]}
>
  <style slot="head">
    /* ── Three clean evidence cards ── */
    .rec-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:8px}
    @media (max-width:980px){.rec-grid{grid-template-columns:1fr;gap:16px}}

    .rec{position:relative;background:#fff;border:1px solid var(--line);border-radius:12px;padding:28px 30px;display:flex;flex-direction:column;gap:14px;box-shadow:var(--shadow-1);transition:transform .35s cubic-bezier(.2,.7,.1,1),box-shadow .35s,border-color .25s;text-decoration:none;color:inherit;overflow:hidden}
    .rec:hover{transform:translateY(-3px);box-shadow:var(--shadow-2);border-color:var(--line-2)}
    .rec::before{content:"";position:absolute;left:0;top:0;width:4px;height:100%;background:var(--terra)}
    .rec.r-2::before{background:var(--ochre)}
    .rec.r-3::before{background:var(--moss)}
    .rec .rtag{display:flex;justify-content:space-between;align-items:center;gap:10px;font-family:var(--mono);font-size:10.5px;letter-spacing:.1em;color:var(--terra);text-transform:uppercase;font-weight:600}
    .rec.r-2 .rtag{color:#8a5e15}
    .rec.r-3 .rtag{color:var(--moss)}
    .rec .rtag .count{padding:3px 9px;border-radius:999px;background:var(--terra-soft);color:var(--terra);border:1px solid #f6cdbb;font-size:10px;letter-spacing:.06em;font-weight:700}
    .rec.r-2 .rtag .count{background:var(--ochre-soft);color:#8a5e15;border-color:#f0d690}
    .rec.r-3 .rtag .count{background:var(--sage-soft);color:var(--moss);border-color:#cfe0b1}
    .rec h3{font-family:var(--serif);font-weight:400;font-size:26px;line-height:1.05;letter-spacing:-.015em;color:var(--ink)}
    .rec h3 em{font-style:italic;color:var(--terra)}
    .rec.r-2 h3 em{color:#8a5e15}
    .rec.r-3 h3 em{color:var(--moss)}
    .rec p{font-size:14px;color:var(--ink-2);line-height:1.65;flex:1}
    .rec ul{list-style:none;display:flex;flex-direction:column;gap:8px;margin-top:4px;padding-top:14px;border-top:1px dashed var(--line)}
    .rec ul li{font-size:13.5px;color:var(--ink);line-height:1.4;display:flex;align-items:flex-start;gap:8px;padding-left:0}
    .rec ul li::before{content:"";display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--terra);margin-top:7px;flex-shrink:0}
    .rec.r-2 ul li::before{background:var(--ochre)}
    .rec.r-3 ul li::before{background:var(--moss)}
    .rec .rmeta{display:flex;justify-content:space-between;align-items:center;padding-top:12px;border-top:1px dashed var(--line);font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
    .rec .rmeta .cta{color:var(--terra);font-weight:600}
    .rec.r-2 .rmeta .cta{color:#8a5e15}
    .rec.r-3 .rmeta .cta{color:var(--moss)}
    .rec .rmeta .cta::after{content:"↗";margin-left:3px;transition:transform .25s}
    .rec:hover .rmeta .cta::after{transform:translate(2px,-2px)}

    /* ── CCN quote block (clean, keeps the columns) ── */
    .ccn{margin-top:14px;background:#fff;border:1px solid var(--line);border-radius:14px;overflow:hidden;box-shadow:var(--shadow-1)}
    .ccn-h{display:flex;justify-content:space-between;align-items:end;padding:24px 30px 16px;border-bottom:2px solid var(--ink)}
    .ccn-h h3{font-family:var(--serif);font-weight:400;font-size:28px;letter-spacing:-.015em;line-height:1}
    .ccn-h h3 em{font-style:italic;color:var(--terra)}
    .ccn-h .meta{font-family:var(--mono);font-size:10px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;text-align:right;line-height:1.5}
    .ccn-body{padding:24px 30px;display:grid;grid-template-columns:1fr 1fr;gap:28px}
    @media (max-width:780px){.ccn-body{grid-template-columns:1fr;gap:18px}}
    .ccn-quote{display:flex;flex-direction:column;gap:10px}
    .ccn-quote .ql{font-family:var(--mono);font-size:10px;letter-spacing:.1em;color:var(--terra);text-transform:uppercase;font-weight:600}
    .ccn-quote blockquote{font-family:var(--serif);font-style:italic;font-size:18px;line-height:1.5;color:var(--ink);position:relative;padding-left:14px}
    .ccn-quote blockquote::before{content:"";position:absolute;left:0;top:4px;bottom:4px;width:2px;background:var(--terra)}
    .ccn-quote blockquote b{font-style:normal;color:var(--ink);font-weight:600;background:linear-gradient(180deg,transparent 65%,rgba(200,153,66,.32) 65%);padding:0 2px}
    .ccn-foot{padding:14px 30px 18px;border-top:1px dashed var(--line);display:flex;justify-content:space-between;font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}

    /* ── IGI peer review record (clean table) ── */
    .igi{margin-top:14px;background:#fff;border:1px solid var(--line);border-radius:14px;overflow:hidden;box-shadow:var(--shadow-1)}
    .igi-h{display:flex;justify-content:space-between;align-items:end;padding:24px 30px 14px;border-bottom:1px solid var(--line);gap:14px}
    .igi-h .ttl h3{font-family:var(--serif);font-weight:400;font-size:26px;letter-spacing:-.015em;line-height:1}
    .igi-h .ttl h3 em{font-style:italic;color:var(--moss)}
    .igi-h .ttl .sub{font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--moss);text-transform:uppercase;margin-top:4px;font-weight:600}
    .igi-h .count{display:flex;flex-direction:column;align-items:flex-end;gap:2px;text-align:right}
    .igi-h .count .v{font-family:var(--serif);font-style:italic;font-size:30px;color:var(--moss);line-height:1}
    .igi-h .count .k{font-family:var(--mono);font-size:9.5px;letter-spacing:.08em;color:var(--muted);text-transform:uppercase}
    .igi-list{display:flex;flex-direction:column}
    .igi-row{display:grid;grid-template-columns:auto 1fr auto;gap:20px;align-items:center;padding:18px 30px;border-bottom:1px solid var(--line);transition:background .25s,padding-left .25s cubic-bezier(.2,.7,.1,1)}
    .igi-row:last-child{border-bottom:0}
    .igi-row:hover{background:rgba(122,143,94,.05);padding-left:36px}
    .igi-row .num{font-family:var(--mono);font-size:10px;letter-spacing:.14em;color:var(--moss);text-transform:uppercase;font-weight:700}
    .igi-row .ttl{font-family:var(--serif);font-size:17px;font-weight:400;line-height:1.25;color:var(--ink);letter-spacing:-.005em}
    .igi-row .ttl b{font-weight:600}
    .igi-row .yr{font-family:var(--mono);font-size:11px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
    .igi-foot{padding:18px 30px;border-top:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;background:var(--bg-soft);font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase;flex-wrap:wrap;gap:10px}
    .igi-foot .pill{display:inline-flex;align-items:center;gap:6px;padding:5px 11px;border-radius:999px;background:var(--sage-soft);color:var(--moss);border:1px solid #cfe0b1;font-weight:700}
    .igi-foot .pill::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--moss)}
  </style>

  <PageHeader
    title="External <em>recognition</em>."
    subtitle="External signals around the work: publisher activity, expert-source citations, and peer-review record."
    crumbs={[{ label: "Home", href: "/" }, { label: "Recognition" }]}
  />

  <section class="section wrap first" data-screen-label="Signals">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--terra)"></span>§ External signals</span>
        <h2>Where the work is <em>cited</em> or <em>reviewed</em>.</h2>
        <p>Three surfaces: technical publishing, expert citation, and publisher-led peer review.</p>
      </div>
      <div class="sec-head-r">/ three sources</div>
    </div>

    <div class="rec-grid">
      <a class="rec r-1 rv" href="/publications">
        <div class="rtag">
          <span>Publication record</span>
          <span class="count">35+ pieces</span>
        </div>
        <h3>Bylined in <em>Cointelegraph</em> and <em>AlphaWire</em>.</h3>
        <p>Technical features on AI-driven trading, agentic fraud, crypto-security, and quantum-resistant systems. Plus an archived PDF record where author pages were restructured.</p>
        <ul>
          <li>Crypto-security and threat models</li>
          <li>AI trading systems and agent risk</li>
          <li>Quantum and blockchain explainers</li>
        </ul>
        <div class="rmeta">
          <span>2022 to 2026</span>
          <span class="cta">Open publications</span>
        </div>
      </a>

      <a class="rec r-2 rv d1" href="#ccn-quotes">
        <div class="rtag">
          <span>Expert source</span>
          <span class="count">CCN</span>
        </div>
        <h3>Cited by <em>CCN</em>.</h3>
        <p>Quoted as an expert source on AI-driven trading risk and crypto-security threat models. Two excerpts below; full archived pages available on request.</p>
        <ul>
          <li>AI-driven trading risk</li>
          <li>Seed-phrase threat model</li>
        </ul>
        <div class="rmeta">
          <span>Markets desk · AI</span>
          <span class="cta">Read excerpts</span>
        </div>
      </a>

      <a class="rec r-3 rv d2" href="#igi-record">
        <div class="rtag">
          <span>Peer review</span>
          <span class="count">3 reviews</span>
        </div>
        <h3>Reviewer for <em>IGI Global</em>.</h3>
        <p>Three completed publisher-led chapter reviews across CBDCs and financial stability, IoT-banking consensus, and AI-FinTech. Portal record and certificates on file.</p>
        <ul>
          <li>CBDCs and Financial Stability</li>
          <li>Blockchain · IoT Banking</li>
          <li>AI-Enabled Agile IoT for FinTech</li>
        </ul>
        <div class="rmeta">
          <span>2022 to 2023</span>
          <span class="cta">See review record</span>
        </div>
      </a>
    </div>
  </section>

  <section class="section wrap" id="ccn-quotes" data-screen-label="CCN quotes">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--rust)"></span>§ Expert-source excerpts</span>
        <h2>Two lines from the <em>CCN</em> coverage.</h2>
        <p>Excerpted from the published CCN pieces. Full archived pages available on request.</p>
      </div>
      <div class="sec-head-r"><a href="/evidence">Evidence index →</a></div>
    </div>

    <div class="ccn rv">
      <header class="ccn-h">
        <h3>CCN · <em>Markets desk</em>.</h3>
        <div class="meta">Expert source · AI<br/>Two extracts</div>
      </header>
      <div class="ccn-body">
        <div class="ccn-quote">
          <span class="ql">On trading-bot architecture</span>
          <blockquote>Trading bot architectures must be built to <b>fail safely</b> before they are built to win.</blockquote>
        </div>
        <div class="ccn-quote">
          <span class="ql">On the actual threat model</span>
          <blockquote>Most users lose funds at the <b>seed phrase, not the smart contract</b>. The threat model is often human, not cryptographic.</blockquote>
        </div>
      </div>
      <footer class="ccn-foot">
        <span>Source · CCN expert citation</span>
        <span>Archived · on request</span>
      </footer>
    </div>
  </section>

  <section class="section wrap" id="igi-record" data-screen-label="Peer review">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--moss)"></span>§ Peer review</span>
        <h2>Three completed <em>chapter reviews</em>.</h2>
        <p>Invited review activity for IGI Global across blockchain, IoT, CBDCs, and AI-FinTech-adjacent material between 2022 and 2023.</p>
      </div>
      <div class="sec-head-r">/ on file</div>
    </div>

    <div class="igi rv">
      <header class="igi-h">
        <div class="ttl">
          <h3>IGI Global <em>Review Record</em>.</h3>
          <div class="sub">Publisher-led peer review · 2022 to 2023</div>
        </div>
        <div class="count">
          <span class="v">3</span>
          <span class="k">completed</span>
        </div>
      </header>
      <div class="igi-list">
        <div class="igi-row">
          <span class="num">/ 01</span>
          <span class="ttl"><b>CBDCs and Financial Stability</b> · review of central-bank-digital-currency macro-impact chapter</span>
          <span class="yr">2022</span>
        </div>
        <div class="igi-row">
          <span class="num">/ 02</span>
          <span class="ttl"><b>Blockchain and Consensus for IoT-Based Banking</b> · review of consensus-protocol chapter</span>
          <span class="yr">2022</span>
        </div>
        <div class="igi-row">
          <span class="num">/ 03</span>
          <span class="ttl"><b>AI-Enabled Agile IoT for FinTech</b> · review of edge-AI / FinTech-architecture chapter</span>
          <span class="yr">2023</span>
        </div>
      </div>
      <footer class="igi-foot">
        <span>Tayyub Yaqoob · invited reviewer</span>
        <span class="pill">Verified · IGI Global</span>
      </footer>
    </div>
  </section>
</SiteLayout>
