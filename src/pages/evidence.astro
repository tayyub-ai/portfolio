---
import SiteLayout from "../components/SiteLayout.astro";
import { publicationArchive } from "../data/publications";

const crumbs = [{ label: "Home", href: "/" }, { label: "Evidence" }];
const evidenceSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Evidence",
  url: "https://www.tayyubyaqoob.com/evidence",
  description:
    "Evidence index for role, systems, publications, recognition, peer review, client impact, and public code.",
};
---

<SiteLayout
  title="Evidence"
  description="Evidence index for role, systems, publications, recognition, peer review, client impact, and public code."
  pathname="/evidence"
  crumbs={crumbs}
  structuredData={[evidenceSchema]}
>
  <style slot="head">
    .ev-shell{padding:32px 0 120px;position:relative}
    .ev-head{display:grid;grid-template-columns:1.35fr 1fr;gap:48px;align-items:end;padding:48px 0 36px;border-bottom:1px solid var(--line);margin-bottom:48px}
    .ev-head h1{font-family:var(--serif);font-weight:400;font-size:clamp(48px,7vw,108px);line-height:.95;letter-spacing:-.028em;text-wrap:balance}
    .ev-head h1 em{font-style:italic;color:var(--terra)}
    .ev-head p{font-size:17px;color:var(--ink-2);line-height:1.6;max-width:54ch}
    .ev-meta{font-family:var(--mono);font-size:11px;color:var(--muted);letter-spacing:.06em;text-transform:uppercase;display:flex;flex-direction:column;gap:6px;text-align:right}
    .ev-meta b{color:var(--ink);font-family:var(--sans);font-size:13px;letter-spacing:0;text-transform:none;font-weight:600}
    .ev-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
    .ev-item{background:#fff;border:1px solid var(--line);border-radius:var(--r-lg);padding:24px 26px 22px;display:grid;grid-template-columns:1fr;gap:10px;transition:transform .25s,box-shadow .35s,border-color .25s}
    .ev-item:hover{transform:translateY(-2px);box-shadow:var(--shadow-1);border-color:var(--line-2)}
    .ev-item .hd{display:flex;align-items:flex-start;justify-content:space-between;gap:12px}
    .ev-item h3{font-family:var(--serif);font-size:22px;font-weight:400;line-height:1.15;letter-spacing:-.01em;flex:1}
    .ev-item h3 em{font-style:italic;color:var(--terra)}
    .strength{font-family:var(--mono);font-size:10px;letter-spacing:.06em;text-transform:uppercase;padding:3px 8px;border-radius:999px;white-space:nowrap;border:1px solid var(--line)}
    .primary{background:var(--sage-soft);color:var(--moss);border-color:#cfe0b1}
    .strong{background:var(--terra-soft);color:var(--terra);border-color:#f6cdbb}
    .support{background:var(--ochre-soft);color:#8a5e15;border-color:#f0d690}
    .progress{background:#fce5d8;color:var(--rust);border-color:#f6c8b1}
    .ev-item p{font-size:14px;color:var(--ink-2);line-height:1.6}
    .ev-row{display:grid;grid-template-columns:auto 1fr;gap:8px 14px;font-family:var(--mono);font-size:11.5px;color:var(--muted);letter-spacing:.02em;margin-top:6px;padding-top:12px;border-top:1px dashed var(--line)}
    .ev-row dt{color:var(--muted);text-transform:uppercase;font-size:10.5px;letter-spacing:.06em}
    .ev-row dd{color:var(--ink);font-family:var(--sans);font-size:13px;letter-spacing:0;font-weight:500}
    .ev-row dd a{color:var(--terra);border-bottom:1px solid currentColor}
    .ev-block{margin-bottom:64px}
    .ev-block h2{font-family:var(--serif);font-weight:400;font-size:clamp(28px,3.4vw,44px);line-height:1.05;letter-spacing:-.018em;margin-bottom:8px}
    .ev-block h2 em{font-style:italic;color:var(--terra)}
    .ev-block .lead{font-size:15px;color:var(--ink-2);margin-bottom:24px;max-width:60ch}
    @media (max-width:880px){.ev-head,.ev-grid{grid-template-columns:1fr}.ev-meta{text-align:left}}
  </style>

  <div class="wrap ev-shell">
    <header class="ev-head">
      <div>
        <span class="sec-tag" style="margin-bottom:18px"><span class="dot" style="background:var(--terra)"></span>§ Sources · what each claim links to</span>
        <h1>Evidence <em>index</em>.</h1>
        <p>Source list for the rest of the site. Public, clickable items are linked directly. Confidential or archived items are named and described, with the underlying document available on request.</p>
      </div>
      <div class="ev-meta">
        <span>Last updated · <b>2026-05-14</b></span>
        <span>Custodian · <b>tayyabyaqoob.1@gmail.com</b></span>
        <span>Locale · <b>Stirling, UK</b></span>
      </div>
    </header>

    <section class="ev-block">
      <h2>Role and shipped <em>systems</em>.</h2>
      <p class="lead">Role and engagement record. Most artefacts are private to the client; the supporting documents listed here are available on request.</p>
      <div class="ev-grid">
        <article class="ev-item">
          <div class="hd"><h3>Senior Digital Analyst at <em>8 Million Stories</em></h3><span class="strength primary">Primary</span></div>
          <p>Current senior role spanning analytics implementation, reporting automation, client insights, data pipelines, and AI-assisted measurement workflows.</p>
          <dl class="ev-row"><dt>Proof type</dt><dd>Employment confirmation · recommendation context</dd><dt>Status</dt><dd>Current</dd></dl>
        </article>
        <article class="ev-item">
          <div class="hd"><h3>Case studies and <em>approved outputs</em></h3><span class="strength strong">Strong</span></div>
          <p>Forecasting, sentiment monitoring, AI-mention tracking, and reporting automation are supported through anonymised outputs, deck samples, and diagrams rather than public repos.</p>
          <dl class="ev-row"><dt>Proof type</dt><dd>Approved screenshots · diagrams · before/after outputs</dd><dt>Route</dt><dd><a href="/case-studies">/case-studies ↗</a></dd></dl>
        </article>
      </div>
    </section>

    <section class="ev-block">
      <h2>Publications and <em>archive continuity</em>.</h2>
      <p class="lead">Live article URLs are linked directly. Where a publisher has restructured author pages, a PDF archive preserves the historical record.</p>
      <div class="ev-grid">
        <article class="ev-item">
          <div class="hd"><h3>Live article record</h3><span class="strength primary">Primary</span></div>
          <p>Selected Cointelegraph and AlphaWire articles resolving at their original URLs. Linked directly from the publications page.</p>
          <dl class="ev-row"><dt>Proof type</dt><dd>Direct live URLs</dd><dt>Route</dt><dd><a href="/publications">/publications ↗</a></dd></dl>
        </article>
        <article class="ev-item">
          <div class="hd"><h3>Cointelegraph archive <em>PDF</em></h3><span class="strength strong">Strong</span></div>
          <p>{publicationArchive.description}</p>
          <dl class="ev-row"><dt>Proof type</dt><dd>PDF archive</dd><dt>Asset</dt><dd><a href={publicationArchive.url}>Open archive ↗</a></dd></dl>
        </article>
      </div>
    </section>

    <section class="ev-block">
      <h2>Recognition and <em>peer review</em>.</h2>
      <p class="lead">External signals around the work: expert citations, peer reviews, and publisher activity.</p>
      <div class="ev-grid">
        <article class="ev-item">
          <div class="hd"><h3>CCN expert-source citations</h3><span class="strength strong">Strong</span></div>
          <p>Cited by CCN as an expert source on AI-driven trading risk and crypto-security threat models. Archived excerpts available on request.</p>
          <dl class="ev-row"><dt>Proof type</dt><dd>Archived citation context · excerpts</dd><dt>Route</dt><dd><a href="/recognition">/recognition ↗</a></dd></dl>
        </article>
        <article class="ev-item">
          <div class="hd"><h3>IGI Global chapter reviews</h3><span class="strength primary">Primary</span></div>
          <p>Three completed IGI Global chapter reviews across CBDCs, blockchain consensus for IoT banking, and AI-enabled IoT for FinTech.</p>
          <dl class="ev-row"><dt>Proof type</dt><dd>Portal record · invitation correspondence · certificates</dd><dt>Window</dt><dd>2022 to 2023</dd></dl>
        </article>
      </div>
    </section>

    <section class="ev-block">
      <h2>Public code and <em>labs</em>.</h2>
      <p class="lead">Public repositories are listed only when they are real and current. In-development product work is held separately under Labs so it is not mistaken for shipped systems.</p>
      <div class="ev-grid">
        <article class="ev-item">
          <div class="hd"><h3>Public GitHub repositories</h3><span class="strength strong">Strong</span></div>
          <p>Public repositories on GitHub: utilities, audit modules, and exploratory work that sits outside client engagements.</p>
          <dl class="ev-row"><dt>Proof type</dt><dd>Live public repositories</dd><dt>Route</dt><dd><a href="/open-source">/open-source ↗</a></dd></dl>
        </article>
        <article class="ev-item">
          <div class="hd"><h3>Labs and product R&amp;D</h3><span class="strength progress">In progress</span></div>
          <p>Independent product and audit-module work in active development. Architecture and scope are documented; ship dates are not promised.</p>
          <dl class="ev-row"><dt>Proof type</dt><dd>Architecture notes · roadmap context</dd><dt>Route</dt><dd><a href="/labs">/labs ↗</a></dd></dl>
        </article>
      </div>
    </section>
  </div>
</SiteLayout>
