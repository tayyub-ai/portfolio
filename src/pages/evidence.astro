---
import SiteLayout from "../components/SiteLayout.astro";
import { publicationArchive } from "../data/publications";

const crumbs = [{ label: "Home", href: "/" }, { label: "Evidence" }];
const evidenceSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Evidence",
  url: "https://www.tayyubyaqoob.com/evidence",
  description:
    "Evidence index for role, systems, publications, recognition, peer review, client impact, and public code.",
};
---

<SiteLayout
  title="Evidence"
  description="Evidence index for role, systems, publications, recognition, peer review, client impact, and public code."
  pathname="/evidence"
  crumbs={crumbs}
  structuredData={[evidenceSchema]}
>
  <style slot="head">
    /* ── Audit-trail header ── */
    .audit-head{display:grid;grid-template-columns:1.4fr 1fr;gap:36px;align-items:end;padding:56px 0 32px;border-bottom:1px solid var(--line);margin-bottom:40px;position:relative}
    .audit-head::after{content:"";position:absolute;left:0;right:0;bottom:-1px;height:6px;background:repeating-linear-gradient(90deg,var(--line) 0,var(--line) 6px,transparent 6px,transparent 12px);opacity:.5}
    .audit-head h1{font-family:var(--serif);font-weight:400;font-size:clamp(48px,7vw,108px);line-height:.95;letter-spacing:-.028em;text-wrap:balance;margin-top:16px}
    .audit-head h1 em{font-style:italic;color:var(--terra)}
    .audit-head .lede{font-size:17px;color:var(--ink-2);line-height:1.6;max-width:54ch;margin-top:14px}
    .audit-stamp{position:relative;background:#fff;border:1.5px dashed var(--line-2);border-radius:14px;padding:22px 24px;display:grid;grid-template-columns:1fr;gap:10px;font-family:var(--mono);font-size:11px;letter-spacing:.06em;color:var(--ink-2);text-transform:uppercase}
    .audit-stamp::before{content:"AUDIT TRAIL";position:absolute;top:-9px;left:18px;padding:0 8px;background:#fff;font-size:10px;letter-spacing:.16em;color:var(--terra);font-weight:600}
    .audit-stamp .r{display:flex;justify-content:space-between;align-items:center;gap:14px;padding-bottom:8px;border-bottom:1px dotted var(--line)}
    .audit-stamp .r:last-child{border-bottom:0;padding-bottom:0}
    .audit-stamp .r .k{color:var(--muted)}
    .audit-stamp .r .v{color:var(--ink);font-family:var(--sans);font-size:13px;letter-spacing:0;text-transform:none;font-weight:600}
    .audit-stamp .seal{position:absolute;bottom:-22px;right:-12px;width:80px;height:80px;border:1.5px solid var(--terra);border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--terra);font-family:var(--mono);font-size:8px;letter-spacing:.12em;line-height:1.3;background:#fff;transform:rotate(-12deg);text-transform:uppercase}
    .audit-stamp .seal b{font-family:var(--serif);font-style:italic;font-size:13px;letter-spacing:0;text-transform:none}

    /* ── Ledger blocks ── */
    .ev-block{margin-bottom:64px}
    .ev-block-h{display:flex;justify-content:space-between;align-items:end;gap:16px;margin-bottom:18px;padding-bottom:14px;border-bottom:2px solid var(--ink)}
    .ev-block-h .lab{font-family:var(--mono);font-size:10px;letter-spacing:.16em;color:var(--terra);text-transform:uppercase;margin-bottom:4px}
    .ev-block-h h2{font-family:var(--serif);font-weight:400;font-size:clamp(28px,3.4vw,44px);line-height:1.05;letter-spacing:-.018em}
    .ev-block-h h2 em{font-style:italic;color:var(--terra)}
    .ev-block-h .lead{font-size:14.5px;color:var(--ink-2);max-width:50ch;line-height:1.55;margin-top:4px}
    .ev-block-h .count{font-family:var(--mono);font-size:10px;letter-spacing:.08em;color:var(--muted);text-transform:uppercase;text-align:right;line-height:1.5}
    .ev-block-h .count b{font-family:var(--serif);font-style:italic;font-size:24px;color:var(--ink);letter-spacing:-.01em;display:block}

    .ledger{background:#fff;border:1px solid var(--line);border-radius:14px;overflow:hidden;box-shadow:var(--shadow-1)}
    .ledger-h{display:grid;grid-template-columns:1.8fr 1.3fr .7fr 1fr;gap:14px;padding:12px 22px;background:#fafaf5;border-bottom:1px solid var(--line);font-family:var(--mono);font-size:9.5px;letter-spacing:.14em;color:var(--muted);text-transform:uppercase}
    .ledger-row{display:grid;grid-template-columns:1.8fr 1.3fr .7fr 1fr;gap:14px;padding:18px 22px;border-bottom:1px solid var(--line);align-items:center;transition:background .25s,padding-left .25s cubic-bezier(.2,.7,.1,1);position:relative;text-decoration:none;color:inherit}
    .ledger-row:last-child{border-bottom:0}
    .ledger-row::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;background:transparent;transition:background .25s}
    .ledger-row:hover{background:rgba(196,77,44,.04);padding-left:28px}
    .ledger-row:hover::before{background:var(--terra)}
    .ledger-row.primary:hover::before{background:var(--moss)}
    .ledger-row.strong:hover::before{background:var(--terra)}
    .ledger-row.support:hover::before{background:var(--ochre-deep,#8a5e15)}
    .ledger-row.progress:hover::before{background:var(--coral)}
    .ledger-row .ltitle{display:flex;flex-direction:column;gap:4px}
    .ledger-row .ltitle b{font-family:var(--serif);font-size:17px;font-weight:400;letter-spacing:-.005em;line-height:1.25;color:var(--ink)}
    .ledger-row .ltitle b em{font-style:italic;color:var(--terra)}
    .ledger-row .ltitle .desc{font-size:12.5px;color:var(--ink-2);line-height:1.5}
    .ledger-row .type{font-family:var(--mono);font-size:11px;color:var(--ink-2);letter-spacing:.02em;line-height:1.45}
    .ledger-row .status{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:9.5px;letter-spacing:.08em;text-transform:uppercase;padding:5px 10px;border-radius:999px;width:max-content;font-weight:600}
    .ledger-row .status.primary{background:var(--sage-soft);color:var(--moss);border:1px solid #cfe0b1}
    .ledger-row .status.strong{background:var(--terra-soft);color:var(--terra);border:1px solid #f6cdbb}
    .ledger-row .status.support{background:var(--ochre-soft);color:#8a5e15;border:1px solid #f0d690}
    .ledger-row .status.progress{background:#fce5d8;color:var(--coral);border:1px solid #f6c8b1}
    .ledger-row .access{font-family:var(--mono);font-size:11px;color:var(--terra);letter-spacing:.02em;display:inline-flex;align-items:center;gap:4px}
    .ledger-row .access::after{content:"→";transition:transform .25s}
    .ledger-row:hover .access::after{transform:translateX(3px)}
    @media (max-width:880px){
      .audit-head{grid-template-columns:1fr;gap:18px;padding-top:40px}
      .audit-stamp .seal{display:none}
      .ledger-h{display:none}
      .ledger-row{grid-template-columns:1fr;gap:8px;padding:18px 22px}
      .ev-block-h{flex-direction:column;align-items:flex-start;gap:8px}
      .ev-block-h .count{text-align:left}
    }
  </style>

  <div class="wrap">
    <header class="audit-head rv">
      <div>
        <span class="lab" style="font-family:var(--mono);font-size:10px;letter-spacing:.16em;color:var(--terra);text-transform:uppercase;font-weight:600">§ Sources · what each claim links to</span>
        <h1>Evidence <em>index</em>.</h1>
        <p class="lede">Source list for the rest of the site. Public, clickable items are linked directly. Confidential or archived items are named and described, with the underlying document available on request.</p>
      </div>
      <div class="audit-stamp">
        <div class="r"><span class="k">Updated</span><span class="v">14 May 2026</span></div>
        <div class="r"><span class="k">Custodian</span><span class="v" style="font-size:11px">tayyabyaqoob.1@gmail.com</span></div>
        <div class="r"><span class="k">Locale</span><span class="v">Stirling · UK</span></div>
        <div class="r"><span class="k">File no.</span><span class="v">AR-2026-001</span></div>
        <div class="seal">Verified<b>2026</b>tayyub-ai</div>
      </div>
    </header>

    <!-- 01 Role and systems -->
    <section class="ev-block rv">
      <div class="ev-block-h">
        <div>
          <span class="lab">§ 01 / four</span>
          <h2>Role and shipped <em>systems</em>.</h2>
          <p class="lead">Role and engagement record. Most artefacts are private to the client; supporting documents listed here are available on request.</p>
        </div>
        <div class="count">Entries<b>2</b></div>
      </div>
      <div class="ledger">
        <div class="ledger-h">
          <span>Source</span><span>Type</span><span>Status</span><span>Access</span>
        </div>
        <a class="ledger-row primary" href="/about">
          <div class="ltitle">
            <b>Senior Digital Analyst at <em>8 Million Stories</em></b>
            <span class="desc">Current senior role spanning analytics implementation, reporting automation, client insights, data pipelines, and AI-assisted measurement workflows.</span>
          </div>
          <div class="type">Employment record · recommendation context</div>
          <span class="status primary">Primary</span>
          <span class="access">On request</span>
        </a>
        <a class="ledger-row strong" href="/case-studies">
          <div class="ltitle">
            <b>Case studies and <em>approved outputs</em></b>
            <span class="desc">Forecasting, sentiment monitoring, AI-mention tracking, and reporting automation supported through anonymised outputs, deck samples, and diagrams.</span>
          </div>
          <div class="type">Approved screenshots · diagrams · before/after</div>
          <span class="status strong">Strong</span>
          <span class="access">Open route ↗</span>
        </a>
      </div>
    </section>

    <!-- 02 Publications -->
    <section class="ev-block rv">
      <div class="ev-block-h">
        <div>
          <span class="lab">§ 02 / four</span>
          <h2>Publications and <em>archive continuity</em>.</h2>
          <p class="lead">Live article URLs linked directly. Where a publisher restructured author pages, a PDF archive preserves the historical record.</p>
        </div>
        <div class="count">Entries<b>2</b></div>
      </div>
      <div class="ledger">
        <div class="ledger-h">
          <span>Source</span><span>Type</span><span>Status</span><span>Access</span>
        </div>
        <a class="ledger-row primary" href="/publications">
          <div class="ltitle">
            <b>Live article <em>record</em></b>
            <span class="desc">Selected Cointelegraph and AlphaWire articles resolving at their original URLs.</span>
          </div>
          <div class="type">Direct live URLs · verified 2026-05-14</div>
          <span class="status primary">Primary</span>
          <span class="access">Open route ↗</span>
        </a>
        <a class="ledger-row strong" href={publicationArchive.url}>
          <div class="ltitle">
            <b>Cointelegraph archive <em>PDF</em></b>
            <span class="desc">{publicationArchive.description}</span>
          </div>
          <div class="type">PDF archive · publisher restructure</div>
          <span class="status strong">Strong</span>
          <span class="access">Open archive ↗</span>
        </a>
      </div>
    </section>

    <!-- 03 Recognition -->
    <section class="ev-block rv">
      <div class="ev-block-h">
        <div>
          <span class="lab">§ 03 / four</span>
          <h2>Recognition and <em>peer review</em>.</h2>
          <p class="lead">External signals around the work: expert citations, peer reviews, and publisher activity.</p>
        </div>
        <div class="count">Entries<b>2</b></div>
      </div>
      <div class="ledger">
        <div class="ledger-h">
          <span>Source</span><span>Type</span><span>Status</span><span>Access</span>
        </div>
        <a class="ledger-row strong" href="/recognition">
          <div class="ltitle">
            <b>CCN expert-source <em>citations</em></b>
            <span class="desc">Cited as an expert source on AI-driven trading risk and crypto-security threat models.</span>
          </div>
          <div class="type">Archived citation context · excerpts</div>
          <span class="status strong">Strong</span>
          <span class="access">Open route ↗</span>
        </a>
        <a class="ledger-row primary" href="/recognition">
          <div class="ltitle">
            <b>IGI Global <em>chapter reviews</em></b>
            <span class="desc">Three completed reviews across CBDCs, blockchain consensus for IoT banking, and AI-enabled IoT for FinTech.</span>
          </div>
          <div class="type">Portal record · correspondence · certificates</div>
          <span class="status primary">Primary</span>
          <span class="access">On request</span>
        </a>
      </div>
    </section>

    <!-- 04 Public code -->
    <section class="ev-block rv">
      <div class="ev-block-h">
        <div>
          <span class="lab">§ 04 / four</span>
          <h2>Public code and <em>labs</em>.</h2>
          <p class="lead">Public repositories listed only when real and current. In-development work is held separately under Labs so it is not mistaken for shipped systems.</p>
        </div>
        <div class="count">Entries<b>2</b></div>
      </div>
      <div class="ledger">
        <div class="ledger-h">
          <span>Source</span><span>Type</span><span>Status</span><span>Access</span>
        </div>
        <a class="ledger-row strong" href="/open-source">
          <div class="ltitle">
            <b>Public GitHub <em>repositories</em></b>
            <span class="desc">Utilities, audit modules, and exploratory work outside client engagements.</span>
          </div>
          <div class="type">Live repositories · github.com/tayyub-ai</div>
          <span class="status strong">Strong</span>
          <span class="access">Open route ↗</span>
        </a>
        <a class="ledger-row progress" href="/labs">
          <div class="ltitle">
            <b>Labs and product <em>R&amp;D</em></b>
            <span class="desc">Independent product and audit-module work in active development.</span>
          </div>
          <div class="type">Architecture notes · roadmap context</div>
          <span class="status progress">In progress</span>
          <span class="access">Open route ↗</span>
        </a>
      </div>
    </section>
  </div>
</SiteLayout>
