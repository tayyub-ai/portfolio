---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="Case Studies"
  description="Production analytics systems, automation workflows, and internal tools architected in live client environments."
  pathname="/case-studies"
  crumbs={[{ label: "Home", href: "/" }, { label: "Case Studies" }]}
>
  <style slot="head">
    /* ── Case-study posters (full width) ── */
    .cs-strip{display:flex;flex-direction:column;gap:20px;margin-top:8px}
    .cs{position:relative;background:#fff;border:1px solid var(--line);border-radius:20px;padding:0;display:grid;grid-template-columns:minmax(0,1.75fr) 308px;gap:0;align-items:stretch;overflow:hidden;transition:transform .4s cubic-bezier(.2,.7,.1,1),box-shadow .4s,border-color .25s}
    .cs:hover{transform:translateY(-3px);box-shadow:var(--shadow-2);border-color:var(--line-2)}
    .cs::before{content:"";position:absolute;left:0;top:0;width:4px;height:100%;background:var(--terra)}
    .cs-main{padding:30px 30px 28px}
    .cs-tag{font-family:var(--mono);font-size:10.5px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;display:flex;align-items:center;gap:10px}
    .cs h3{font-family:var(--serif);font-weight:400;font-size:clamp(26px,2.6vw,38px);line-height:1.05;letter-spacing:-.018em;margin-top:8px;color:var(--ink)}
    .cs h3 em{font-style:italic;color:var(--ink)}

    /* Inline client quote inside cs-gutter */
    .cs-quote{margin-top:auto;padding:14px 0 0;border-top:1px dashed rgba(214,206,187,.9)}
    .cs-quote p{font-family:var(--serif);font-style:italic;font-size:14.5px;line-height:1.55;color:var(--ink);margin:0}
    .cs-quote cite{display:block;margin-top:8px;font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase;font-style:normal}
    .cs-desc{font-size:14.5px;color:var(--ink-2);line-height:1.65;margin-top:10px;max-width:52ch}
    .cs-viz{margin-top:18px;background:linear-gradient(180deg,#fff,var(--bg-soft));border:1px solid var(--line);border-radius:16px;padding:18px;position:relative;overflow:hidden}
    .cs-viz svg{width:100%;height:auto;display:block}
    .cs-gutter{display:flex;flex-direction:column;justify-content:space-between;gap:18px;padding:28px 24px;background:linear-gradient(180deg,rgba(255,255,255,.82),rgba(244,240,230,.96));border-left:1px solid var(--line)}
    .cs-chips{display:flex;flex-wrap:wrap;gap:6px}
    .cs-chips span{font-family:var(--mono);font-size:9px;letter-spacing:.08em;text-transform:uppercase;padding:6px 8px;border-radius:999px;border:1px solid rgba(214,206,187,.9);background:rgba(255,255,255,.8);color:var(--ink-2)}
    .cs-stats{display:flex;flex-direction:column;gap:14px;padding:14px 0;border-top:1px dashed rgba(214,206,187,.9);border-bottom:1px dashed rgba(214,206,187,.9)}
    .cs-stats .row{display:flex;justify-content:space-between;align-items:baseline;gap:10px}
    .cs-stats .row .label{font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
    .cs-stats .row .v{font-family:var(--serif);font-size:22px;font-style:italic;color:var(--ink);line-height:1}
    .cs-cta::after{content:"→";transition:transform .25s}
    .cs:hover .cs-cta::after{transform:translateX(3px)}

    /* Forecast viz */
    .v-fc .grid line{stroke:var(--line);stroke-width:1;stroke-dasharray:2 4;opacity:.6}
    .v-fc .axis-lbl{font-family:var(--mono);font-size:9.5px;fill:var(--muted);letter-spacing:.06em}
    .v-fc .hist{stroke:var(--terra);stroke-width:2.4;fill:none;stroke-linecap:round;stroke-dasharray:600;stroke-dashoffset:600}
    .v-fc .band{fill:var(--ochre);fill-opacity:.22;opacity:0;transition:opacity 1s ease 1.2s}
    .v-fc .fc{stroke:var(--ochre);stroke-width:2;fill:none;stroke-dasharray:5 4;stroke-linecap:round;stroke-dasharray:300;stroke-dashoffset:300}
    .v-fc .now-line{stroke:var(--ink);stroke-width:1;stroke-dasharray:3 3;opacity:.6}
    .v-fc .now-lbl{font-family:var(--mono);font-size:9px;fill:var(--ink);letter-spacing:.06em;text-transform:uppercase}
    .cs.in .v-fc .hist{transition:stroke-dashoffset 1.8s cubic-bezier(.4,0,.2,1);stroke-dashoffset:0}
    .cs.in .v-fc .fc{transition:stroke-dashoffset 1.4s cubic-bezier(.4,0,.2,1) 1.4s;stroke-dashoffset:0}
    .cs.in .v-fc .band{opacity:1}

    /* Sentiment river viz */
    .v-rv .layer{transform-origin:bottom;transform:scaleY(0);transition:transform 1.2s cubic-bezier(.4,0,.2,1)}
    .v-rv .layer.l-pos{fill:#a8c08a}
    .v-rv .layer.l-neu{fill:#e7d6a8;transition-delay:.15s}
    .v-rv .layer.l-neg{fill:#e8a995;transition-delay:.3s}
    .cs.in .v-rv .layer{transform:scaleY(1)}
    .v-rv .axis-lbl{font-family:var(--mono);font-size:9.5px;fill:var(--muted);letter-spacing:.06em}
    .v-rv .flag-line{stroke:var(--ink);stroke-width:1;stroke-dasharray:3 3}
    .v-rv .flag{font-family:var(--mono);font-size:9px;fill:var(--ink);letter-spacing:.04em;text-transform:uppercase}
    .v-rv .legend{font-family:var(--mono);font-size:9.5px;letter-spacing:.06em}

    /* SERP comparison viz */
    .v-sp .panel{fill:#fff;stroke:var(--line);stroke-width:1}
    .v-sp .panel-h{font-family:var(--mono);font-size:9.5px;fill:var(--muted);letter-spacing:.1em;text-transform:uppercase}
    .v-sp .result{font-family:var(--sans);font-size:10px;fill:var(--ink-2)}
    .v-sp .result-hit{fill:var(--moss);font-weight:600}
    .v-sp .row{fill:#fff;stroke:var(--line);stroke-width:.8}
    .v-sp .row-hit{fill:#fff5d7;stroke:var(--ochre)}
    .v-sp .arrow{stroke:var(--coral);stroke-width:2;fill:none;stroke-dasharray:240;stroke-dashoffset:240}
    .cs.in .v-sp .arrow{transition:stroke-dashoffset 1.6s cubic-bezier(.4,0,.2,1) 1s;stroke-dashoffset:0}
    .v-sp .scrub-line{stroke:var(--line-2);stroke-width:1}
    .v-sp .scrub-marker{fill:var(--coral)}
    .v-sp .scrub-lbl{font-family:var(--mono);font-size:9px;fill:var(--muted);letter-spacing:.06em}

    /* Before/after viz */
    .v-ba .row-lbl{font-family:var(--mono);font-size:11px;fill:var(--muted);letter-spacing:.1em;text-transform:uppercase}
    .v-ba .seg{transform-origin:left;transform:scaleX(0);transition:transform 1s cubic-bezier(.4,0,.2,1)}
    .cs.in .v-ba .seg{transform:scaleX(1)}
    .cs.in .v-ba .seg.s1{transition-delay:.05s}
    .cs.in .v-ba .seg.s2{transition-delay:.4s}
    .cs.in .v-ba .seg.s3{transition-delay:.7s}
    .cs.in .v-ba .seg.s4{transition-delay:1s}
    .cs.in .v-ba .seg.s5{transition-delay:1.3s}
    .cs.in .v-ba .seg.s-fast{transition-delay:1.6s}
    .v-ba .seg-lbl{font-family:var(--mono);font-size:9px;fill:#fff;letter-spacing:.06em}
    .v-ba .ttl{font-family:var(--serif);font-style:italic;font-size:18px;fill:var(--ink)}
    .v-ba .axis{font-family:var(--mono);font-size:9.5px;fill:var(--muted);letter-spacing:.06em}
    .v-ba .axis-tick{stroke:var(--line);stroke-width:1;stroke-dasharray:2 3;opacity:.5}
    .v-ba .vs{font-family:var(--serif);font-style:italic;font-size:14px;fill:var(--muted);text-anchor:middle}

    @media (max-width:780px){.cs{grid-template-columns:1fr}.cs-main{padding:24px 22px 22px}.cs-gutter{padding:22px;border-left:0;border-top:1px solid var(--line)}}

    /* ── Supporting docs tiles (clean) ── */
    .docs-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:8px}
    .doc-tile{display:flex;flex-direction:column;background:#fff;border:1px solid var(--line);border-radius:10px;padding:18px 20px;text-decoration:none;color:inherit;transition:transform .25s,box-shadow .25s,border-color .25s;position:relative;overflow:hidden}
    .doc-tile::before{content:"";position:absolute;left:0;top:0;width:3px;height:100%;background:var(--terra);transition:width .25s}
    .doc-tile:hover{transform:translateY(-3px);box-shadow:var(--shadow-1);border-color:var(--line-2)}
    .doc-tile:hover::before{width:5px}
    .doc-tile .doc-tag{font-family:var(--mono);font-size:9.5px;letter-spacing:.1em;color:var(--terra);text-transform:uppercase;margin-bottom:8px;font-weight:600}
    .doc-tile h4{font-family:var(--serif);font-size:18px;font-weight:400;line-height:1.2;letter-spacing:-.005em;color:var(--ink);margin-bottom:6px}
    .doc-tile h4 em{font-style:italic;color:var(--terra)}
    .doc-tile p{font-size:12.5px;color:var(--ink-2);line-height:1.55;flex:1}
    .doc-tile .doc-cta{margin-top:12px;font-family:var(--mono);font-size:10px;letter-spacing:.08em;color:var(--terra);text-transform:uppercase;padding-top:10px;border-top:1px dashed var(--line);display:flex;align-items:center;gap:4px;font-weight:600}
    .doc-tile .doc-cta::after{content:"↗";transition:transform .25s}
    .doc-tile:hover .doc-cta::after{transform:translate(2px,-2px)}
    @media (max-width:880px){.docs-grid{grid-template-columns:1fr 1fr}}
    @media (max-width:520px){.docs-grid{grid-template-columns:1fr}}
  </style>

  <PageHeader
    title="Case studies."
    subtitle="The problem, the approach, the stack, and a short note from the team it shipped to."
    crumbs={[{ label: "Home", href: "/" }, { label: "Case Studies" }]}
  />

  <section class="section wrap first" data-screen-label="Case studies">

    <div class="cs-strip">
      <!-- 01 Forecasting -->
      <article class="cs cs-1 rv">
        <div class="cs-main">
          <div class="cs-tag"><span>Forecasting · BigQuery · GA4</span></div>
          <h3>Channel and query <em>forecasting</em>.</h3>
          <p class="cs-desc">Forecasting workflows in BigQuery covering GSC query trends, channel traffic, and monthly reporting cycles. Used by analyst and account teams to flag variance against forecast inside the cycle rather than after it. Forecast confidence bands surface the range, not just the point estimate.</p>
          <div class="cs-viz">
            <svg class="v-fc" viewBox="0 0 700 240" preserveAspectRatio="xMidYMid meet">
              <g class="grid">
                <line x1="0" y1="60" x2="700" y2="60"/>
                <line x1="0" y1="120" x2="700" y2="120"/>
                <line x1="0" y1="180" x2="700" y2="180"/>
              </g>
              <text class="axis-lbl" x="6" y="58">120k</text>
              <text class="axis-lbl" x="6" y="118">90k</text>
              <text class="axis-lbl" x="6" y="178">60k</text>
              <path class="band" d="M380 110 Q450 90 520 86 T700 70 L700 142 Q630 150 560 152 T380 134 Z"/>
              <path class="hist" d="M30 180 Q90 168 150 160 T270 142 T380 122"/>
              <path class="fc" d="M380 122 Q450 102 520 92 T700 74"/>
              <line class="now-line" x1="380" y1="30" x2="380" y2="220"/>
              <text class="now-lbl" x="386" y="42">NOW</text>
              <circle cx="380" cy="122" r="4" fill="#c44d2c"/>
              <text class="axis-lbl" x="30" y="232">Jan</text>
              <text class="axis-lbl" x="380" y="232">Jun</text>
              <text class="axis-lbl" x="670" y="232">Dec</text>
            </svg>
          </div>
        </div>
        <div class="cs-gutter">
          <div class="cs-chips">
            <span>BigQuery</span><span>Python</span><span>GSC API</span><span>GA4</span><span>Forecasting</span><span>Reporting</span>
          </div>
          <div class="cs-stats">
            <div class="row"><span class="label">Median MAPE</span><span class="v">5.4%</span></div>
            <div class="row"><span class="label">Runs / month</span><span class="v">12</span></div>
            <div class="row"><span class="label">Channels</span><span class="v">4</span></div>
          </div>
          <blockquote class="cs-quote">
            <p>"The tool is working fully, and we've been able to share the update with wider teams."</p>
            <cite>BBC, project stakeholder</cite>
          </blockquote>
        </div>
      </article>

      <!-- 02 Sentiment river -->
      <article class="cs cs-2 rv d1">
        <div class="cs-main">
          <div class="cs-tag"><span>Sentiment · LLM-assisted</span></div>
          <h3>Sentiment and topic <em>river</em>.</h3>
          <p class="cs-desc">LLM-assisted classification across press, review, and social. The system classifies, deduplicates, and surfaces shifts; nothing is auto-published. Annotated bands track positive, neutral, and negative coverage over time so analysts can interpret context, not just deltas.</p>
          <div class="cs-viz">
            <svg class="v-rv" viewBox="0 0 700 240" preserveAspectRatio="xMidYMid meet">
              <path class="layer l-neg" d="M0 240 L0 180 Q70 170 140 174 T280 162 T420 168 T560 158 T700 162 L700 240 Z"/>
              <path class="layer l-neu" d="M0 180 L0 116 Q70 110 140 118 T280 104 T420 110 T560 100 T700 104 L700 162 Q630 160 560 158 T420 168 T280 162 T140 174 T0 180 Z"/>
              <path class="layer l-pos" d="M0 116 L0 54 Q70 46 140 50 T280 36 T420 44 T560 32 T700 36 L700 104 Q630 100 560 100 T420 110 T280 104 T140 118 T0 116 Z"/>
              <line class="flag-line" x1="280" y1="22" x2="280" y2="218"/>
              <text class="flag" x="286" y="36">Coverage spike · Q2</text>
              <line class="flag-line" x1="560" y1="22" x2="560" y2="218"/>
              <text class="flag" x="566" y="36">Topic shift · Q4</text>
              <text class="axis-lbl" x="6" y="232">Jan</text>
              <text class="axis-lbl" x="346" y="232">Jun</text>
              <text class="axis-lbl" x="670" y="232">Dec</text>
              <g class="legend" transform="translate(540 218)">
                <rect width="10" height="10" fill="#a8c08a"/><text x="14" y="9" fill="var(--moss)">positive</text>
                <rect x="64" width="10" height="10" fill="#e7d6a8"/><text x="78" y="9" fill="#8a5e15">neutral</text>
                <rect x="124" width="10" height="10" fill="#e8a995"/><text x="138" y="9" fill="var(--coral)">negative</text>
              </g>
            </svg>
          </div>
        </div>
        <div class="cs-gutter">
          <div class="cs-chips">
            <span>Python</span><span>LLM API</span><span>BigQuery</span><span>NLP</span><span>Structured outputs</span>
          </div>
          <div class="cs-stats">
            <div class="row"><span class="label">Surfaces tracked</span><span class="v">11</span></div>
            <div class="row"><span class="label">Mentions / week</span><span class="v">~3k</span></div>
            <div class="row"><span class="label">Alert classes</span><span class="v">4</span></div>
          </div>
          <blockquote class="cs-quote">
            <p>"The feedback was very positive. Overall they are happy with the first go at this. I appreciate all your help and of course passed on high praise of your work."</p>
            <cite>General Mills, account team on Blue Buffalo</cite>
          </blockquote>
        </div>
      </article>

      <!-- 03 SERP comparison -->
      <article class="cs cs-3 rv d2">
        <div class="cs-main">
          <div class="cs-tag"><span>AI visibility · AI Overviews</span></div>
          <h3>AI vs traditional <em>search</em>.</h3>
          <p class="cs-desc">Tracking how brands and queries surface across AI Overviews, ChatGPT, Perplexity, and conventional search. Each change captured with date, prompt, and rendered citation so visibility shifts can be reviewed weeks later, not just observed in real time.</p>
          <div class="cs-viz">
            <svg class="v-sp" viewBox="0 0 700 240" preserveAspectRatio="xMidYMid meet">
              <defs><marker id="caarrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="var(--coral)"/></marker></defs>
              <rect class="panel" x="24" y="32" width="280" height="148" rx="6"/>
              <text class="panel-h" x="36" y="52">Google · organic</text>
              <rect class="row" x="36" y="62" width="256" height="20" rx="3"/>
              <text class="result" x="44" y="76">competitor a · category guide</text>
              <rect class="row" x="36" y="88" width="256" height="20" rx="3"/>
              <text class="result" x="44" y="102">competitor b · review hub</text>
              <rect class="row row-hit" x="36" y="114" width="256" height="20" rx="3"/>
              <text class="result result-hit" x="44" y="128">your brand · category page</text>
              <rect class="row" x="36" y="140" width="256" height="20" rx="3"/>
              <text class="result" x="44" y="154">forum · long-tail thread</text>

              <rect class="panel" x="396" y="32" width="280" height="148" rx="6"/>
              <text class="panel-h" x="408" y="52">AI Overviews · cited</text>
              <rect class="row row-hit" x="408" y="62" width="256" height="20" rx="3"/>
              <text class="result result-hit" x="416" y="76">your brand · cited 1/3</text>
              <rect class="row" x="408" y="88" width="256" height="20" rx="3"/>
              <text class="result" x="416" y="102">competitor a · cited 2/3</text>
              <rect class="row" x="408" y="114" width="256" height="20" rx="3"/>
              <text class="result" x="416" y="128">trade outlet · cited 3/3</text>
              <text class="result" x="408" y="158" style="fill:var(--muted)">prompt: "best [category] tool · 2026"</text>

              <path class="arrow" d="M292 124 Q344 124 396 72" stroke="currentColor" fill="none" marker-end="url(#caarrow)"/>

              <line class="scrub-line" x1="24" y1="206" x2="676" y2="206"/>
              <text class="scrub-lbl" x="24" y="224">Jan</text>
              <text class="scrub-lbl" x="346" y="224">Jun</text>
              <text class="scrub-lbl" x="660" y="224">Dec</text>
              <circle class="scrub-marker" cx="84" cy="206" r="3"/>
              <circle class="scrub-marker" cx="190" cy="206" r="3"/>
              <circle class="scrub-marker" cx="290" cy="206" r="4"/>
              <circle class="scrub-marker" cx="412" cy="206" r="3"/>
              <circle class="scrub-marker" cx="528" cy="206" r="3"/>
              <circle class="scrub-marker" cx="618" cy="206" r="3"/>
            </svg>
          </div>
        </div>
        <div class="cs-gutter">
          <div class="cs-chips">
            <span>AI Overviews</span><span>ChatGPT</span><span>Perplexity</span><span>SERP</span><span>Research</span>
          </div>
          <div class="cs-stats">
            <div class="row"><span class="label">Queries tracked</span><span class="v">140+</span></div>
            <div class="row"><span class="label">Platforms</span><span class="v">4</span></div>
            <div class="row"><span class="label">Cadence</span><span class="v">Weekly</span></div>
          </div>
        </div>
      </article>

      <!-- 04 Reporting automation -->
      <article class="cs cs-4 rv d3">
        <div class="cs-main">
          <div class="cs-tag"><span>Reporting automation</span></div>
          <h3>Manual reporting → <em>automated assembly</em>.</h3>
          <p class="cs-desc">Automated assembly of recurring reports and decks from GA4, GSC, and ad-platform data. Replaces a multi-hour manual build with a short analyst review pass. Each step on the before bar is a real stage; the after bar shows what remains.</p>
          <div class="cs-viz">
            <svg class="v-ba" viewBox="0 0 700 220" preserveAspectRatio="xMidYMid meet">
              <line class="axis-tick" x1="100" y1="20" x2="100" y2="200"/>
              <line class="axis-tick" x1="220" y1="20" x2="220" y2="200"/>
              <line class="axis-tick" x1="340" y1="20" x2="340" y2="200"/>
              <line class="axis-tick" x1="460" y1="20" x2="460" y2="200"/>
              <line class="axis-tick" x1="580" y1="20" x2="580" y2="200"/>
              <text class="axis" x="100" y="14">0h</text>
              <text class="axis" x="220" y="14">1h</text>
              <text class="axis" x="340" y="14">2h</text>
              <text class="axis" x="460" y="14">3h</text>
              <text class="axis" x="580" y="14">4h</text>

              <text class="row-lbl" x="4" y="68">Manual</text>
              <g transform="translate(100 40)">
                <rect class="seg s1" width="120" height="48" rx="4" fill="#d97757"/>
                <text class="seg-lbl" x="10" y="20">Gather</text>
                <text class="seg-lbl" x="10" y="36" opacity=".75">~60 min</text>
                <rect class="seg s2" x="120" width="100" height="48" rx="4" fill="#c44d2c"/>
                <text class="seg-lbl" x="130" y="20">Clean</text>
                <text class="seg-lbl" x="130" y="36" opacity=".75">~50 min</text>
                <rect class="seg s3" x="220" width="120" height="48" rx="4" fill="#c89942"/>
                <text class="seg-lbl" x="230" y="20">Build deck</text>
                <text class="seg-lbl" x="230" y="36" opacity=".75">~60 min</text>
                <rect class="seg s4" x="340" width="80" height="48" rx="4" fill="#7a8f5e"/>
                <text class="seg-lbl" x="350" y="20">Review</text>
                <text class="seg-lbl" x="350" y="36" opacity=".75">~40 min</text>
                <rect class="seg s5" x="420" width="60" height="48" rx="4" fill="#1a1714"/>
                <text class="seg-lbl" x="430" y="20">Send</text>
                <text class="seg-lbl" x="430" y="36" opacity=".75">~30 min</text>
              </g>
              <text class="ttl" x="588" y="74">4h · manual</text>

              <text class="vs" x="350" y="124">vs</text>

              <text class="row-lbl" x="4" y="170">Automated</text>
              <g transform="translate(100 142)">
                <rect class="seg s-fast" width="40" height="48" rx="4" fill="#7a8f5e"/>
                <text class="seg-lbl" x="10" y="20">Review</text>
                <text class="seg-lbl" x="10" y="36" opacity=".75">~20 min</text>
              </g>
              <text class="ttl" x="588" y="176" style="fill:var(--moss)">20m · review</text>
            </svg>
          </div>
        </div>
        <div class="cs-gutter">
          <div class="cs-chips">
            <span>Python</span><span>Google Slides API</span><span>BigQuery</span><span>Automation</span><span>Client delivery</span>
          </div>
          <div class="cs-stats">
            <div class="row"><span class="label">Reports / month</span><span class="v">36</span></div>
