---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
import { site } from "../data/site";
---

<SiteLayout
  title="About"
  description="Profile page for Tayyub Yaqoob covering role, focus, training, and the operating principles behind the work."
  pathname="/about"
  crumbs={[{ label: "Home", href: "/" }, { label: "About" }]}
  pageType="about"
>
  <style slot="head">
    /* ── Clean profile layout ── */
    .about-layout{display:grid;grid-template-columns:340px 1fr;gap:48px;align-items:start}
    @media (max-width:880px){.about-layout{grid-template-columns:1fr;gap:32px}}

    .profile-card{position:sticky;top:96px;background:#fff;border:1px solid var(--line);border-radius:14px;overflow:hidden;box-shadow:var(--shadow-1)}
    .profile-photo{width:100%;aspect-ratio:4/5;background:var(--bg-soft);position:relative;overflow:hidden}
    .profile-photo img{width:100%;height:100%;object-fit:cover;filter:saturate(.92) contrast(1.04)}
    .profile-meta{padding:22px 24px 24px}
    .profile-meta .name{font-family:var(--serif);font-style:italic;font-size:26px;font-weight:400;color:var(--ink);letter-spacing:-.012em;line-height:1}
    .profile-meta .role{font-family:'Inter',sans-serif;font-size:13.5px;font-weight:600;color:var(--ink-2);margin-top:6px;letter-spacing:-.005em}
    .profile-meta .role b{color:var(--terra)}
    .profile-meta dl{margin-top:18px;padding-top:18px;border-top:1px dashed var(--line);display:grid;grid-template-columns:auto 1fr;gap:8px 18px}
    .profile-meta dt{font-family:var(--mono);font-size:9.5px;letter-spacing:.12em;color:var(--muted);text-transform:uppercase;line-height:1.5}
    .profile-meta dd{font-family:'Inter',sans-serif;font-size:13px;color:var(--ink);line-height:1.5}
    .profile-meta dd b{font-weight:600}
    .profile-status{margin-top:18px;padding-top:14px;border-top:1px dashed var(--line);display:flex;justify-content:space-between;align-items:center;font-family:var(--mono);font-size:10px;letter-spacing:.08em;color:var(--moss);text-transform:uppercase}
    .profile-status::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--moss);animation:pulse 2s infinite}
    .profile-status .yr{color:var(--muted)}

    /* Bio block */
    .bio-block{display:flex;flex-direction:column;gap:28px}
    .bio-h{font-family:var(--serif);font-size:clamp(32px,3.6vw,48px);font-weight:400;letter-spacing:-.02em;line-height:1.02}
    .bio-h em{font-style:italic;color:var(--terra)}
    .bio-prose{display:flex;flex-direction:column;gap:18px}
    .bio-prose p{font-size:16px;line-height:1.75;color:var(--ink-2)}
    .bio-prose p b{color:var(--ink);font-weight:600}

    /* Venn (keep, it's data viz) */
    .venn-wrap{background:var(--bg-soft);border:1px solid var(--line);border-radius:14px;padding:24px;position:relative;overflow:hidden}
    .venn-wrap::before{content:"";position:absolute;top:0;left:0;width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--terra),transparent)}
    .venn-lab{font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--terra);text-transform:uppercase;margin-bottom:8px}
    .venn{width:100%;height:auto;display:block;margin-top:8px}
    .venn .circle{fill-opacity:.18;stroke-width:1.5;mix-blend-mode:multiply;transition:fill-opacity .6s ease}
    .venn .c1{fill:var(--terra);stroke:var(--terra);opacity:0;transition:opacity 1s ease}
    .venn .c2{fill:var(--ochre);stroke:var(--ochre);opacity:0;transition:opacity 1s ease .3s}
    .venn .c3{fill:var(--moss);stroke:var(--moss);opacity:0;transition:opacity 1s ease .6s}
    .venn-wrap.rv.in .venn .c1,.venn-wrap.rv.in .venn .c2,.venn-wrap.rv.in .venn .c3{opacity:1}
    .venn .c-label{font-family:var(--serif);font-style:italic;font-size:22px;font-weight:400}
    .venn .c-label.l1{fill:var(--terra)}
    .venn .c-label.l2{fill:#8a5e15}
    .venn .c-label.l3{fill:var(--moss)}
    .venn .overlap-label{font-family:var(--mono);font-size:11px;letter-spacing:.04em;fill:var(--ink);text-anchor:middle;opacity:0;transition:opacity .8s ease 1.2s}
    .venn-wrap.rv.in .venn .overlap-label{opacity:1}
    .venn .overlap-label.center{font-family:var(--serif);font-style:italic;font-size:14px;font-weight:400}

    /* Credentials grid (clean, not bookshelf) */
    .creds-wrap{margin-top:8px}
    .creds-h{display:flex;justify-content:space-between;align-items:end;padding-bottom:10px;border-bottom:1px solid var(--line);margin-bottom:16px}
    .creds-h h3{font-family:var(--serif);font-weight:400;font-size:26px;letter-spacing:-.01em}
    .creds-h h3 em{font-style:italic;color:var(--terra)}
    .creds-h .meta{font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
    .creds{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
    .cred{background:#fff;border:1px solid var(--line);border-radius:10px;padding:16px 18px;display:flex;gap:14px;align-items:flex-start;transition:transform .25s,border-color .25s,box-shadow .25s}
    .cred:hover{transform:translateY(-2px);border-color:var(--line-2);box-shadow:var(--shadow-1)}
    .cred-issuer{width:40px;height:40px;border-radius:9px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:'Inter',sans-serif;font-weight:800;font-size:14px;letter-spacing:-.02em;color:#fff}
    .cred-issuer.google{background:linear-gradient(135deg,#4285f4,#34a853 33%,#fbbc05 66%,#ea4335)}
    .cred-issuer.linkedin{background:#0a66c2}
    .cred-issuer.aws{background:#ff9900;color:#1a1714}
    .cred-body{flex:1;min-width:0}
    .cred-body h5{font-family:'Inter',sans-serif;font-weight:600;font-size:14px;line-height:1.3;color:var(--ink);letter-spacing:-.005em;margin-bottom:4px}
    .cred-body .cred-meta{font-family:var(--mono);font-size:10px;letter-spacing:.04em;color:var(--muted);text-transform:uppercase}
    .cred-body .cred-skills{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px}
    .cred-body .cred-skills span{font-family:var(--mono);font-size:9px;letter-spacing:.04em;text-transform:uppercase;padding:2px 7px;border-radius:999px;background:var(--bg-soft);color:var(--ink-2);border:1px solid var(--line)}
    @media (max-width:680px){.creds{grid-template-columns:1fr}}

    /* Principles (simple typographic, no notebook) */
    .principles-wrap{margin-top:32px;padding-top:24px;border-top:1px solid var(--line)}
    .principles-h{font-family:var(--mono);font-size:10px;letter-spacing:.14em;color:var(--terra);text-transform:uppercase;margin-bottom:18px;font-weight:600}
    .principles{display:grid;grid-template-columns:1fr 1fr;gap:24px 36px}
    .ppl{display:flex;flex-direction:column;gap:6px;padding:14px 0;border-top:1px solid var(--line)}
    .ppl .num{font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--muted);text-transform:uppercase}
    .ppl h4{font-family:var(--serif);font-size:20px;font-weight:400;color:var(--ink);line-height:1.15;letter-spacing:-.01em}
    .ppl h4 em{font-style:italic;color:var(--terra)}
    .ppl p{font-size:14px;color:var(--ink-2);line-height:1.65;margin-top:4px}
    @media (max-width:680px){.principles{grid-template-columns:1fr;gap:0}}
  </style>

  <PageHeader
    title="About the <em>work</em>."
    subtitle="Senior Digital Analyst working across <b>AI-assisted analytics</b>, <b>data automation</b>, and <b>digital measurement</b>. The pages below cover what I build, where it has been published, and who has cited or relied on it."
    crumbs={[{ label: "Home", href: "/" }, { label: "About" }]}
  />

  <section class="section wrap first" data-screen-label="Bio">
    <div class="about-layout">
      <aside class="profile-card rv">
        <div class="profile-photo">
          <img src={site.image} alt={site.name} />
        </div>
        <div class="profile-meta">
          <div class="name">{site.name}</div>
          <div class="role"><b>{site.role}</b><br/>8 Million Stories · Stirling, UK</div>
          <dl>
            <dt>Focus</dt><dd>AI-assisted analytics, automation, measurement engineering</dd>
            <dt>Edu</dt><dd>MSc Computing Science · University of Stirling</dd>
            <dt>Based</dt><dd>Stirling · United Kingdom · GMT</dd>
            <dt>Stack</dt><dd>BigQuery · Python · GA4 · GTM · LLM APIs</dd>
          </dl>
          <div class="profile-status">
            <span>Open · 2026</span>
            <span class="yr">2026</span>
          </div>
        </div>
      </aside>

      <div class="bio-block rv d1">
        <h3 class="bio-h">I build analytics workflows teams <em>trust</em>.</h3>

        <div class="venn-wrap rv">
          <div class="venn-lab">§ Where the work sits</div>
          <svg class="venn" viewBox="0 0 600 360" preserveAspectRatio="xMidYMid meet">
            <circle class="circle c1" cx="220" cy="160" r="120"/>
            <circle class="circle c2" cx="380" cy="160" r="120"/>
            <circle class="circle c3" cx="300" cy="270" r="120"/>
            <text class="c-label l1" x="130" y="90">AI</text>
            <text class="c-label l2" x="430" y="90" text-anchor="end">Automation</text>
            <text class="c-label l3" x="300" y="350" text-anchor="middle">Measurement</text>
            <text class="overlap-label" x="300" y="130">LLM-assisted analytics</text>
            <text class="overlap-label" x="220" y="240">AI-search visibility</text>
            <text class="overlap-label" x="380" y="240">Reporting QA</text>
            <text class="overlap-label center" x="300" y="200">Day-to-day</text>
          </svg>
        </div>

        <div class="bio-prose">
          <p>My day-to-day spans <b>AI-assisted analytics</b>, <b>automation in BigQuery and Python</b>, <b>GA4 and GTM measurement engineering</b>, <b>consent and tracking quality</b>, and <b>AI-search visibility research</b>. The work shows up in three places: production systems inside client environments, technical articles for outlets like Cointelegraph and AlphaWire, and chapter reviews for IGI Global.</p>
          <p>Each section of the site links to a primary source: live article URLs, employer record, peer-review certificates, public repositories, and named client engagements. Confidential work is named but not exposed; supporting documents are available on request.</p>
        </div>

        <div class="creds-wrap">
          <div class="creds-h">
            <h3>Training and <em>credentials</em>.</h3>
            <span class="meta">/ 6 selected · 2024 to 26</span>
          </div>
          <div class="creds">
            <div class="cred"><div class="cred-issuer google">G</div><div class="cred-body"><h5>5-Day AI Agents Intensive Course</h5><div class="cred-meta">Google · Dec 2025</div><div class="cred-skills"><span>AI Agents</span><span>Python</span></div></div></div>
            <div class="cred"><div class="cred-issuer linkedin">in</div><div class="cred-body"><h5>Vertex AI: MLOps with Google Cloud</h5><div class="cred-meta">LinkedIn · Jun 2025</div><div class="cred-skills"><span>Vertex AI</span><span>MLOps</span></div></div></div>
            <div class="cred"><div class="cred-issuer linkedin">in</div><div class="cred-body"><h5>Model Context Protocol: Hands-On with Agentic AI</h5><div class="cred-meta">LinkedIn · Jun 2025</div><div class="cred-skills"><span>MCP</span><span>AI Agents</span></div></div></div>
            <div class="cred"><div class="cred-issuer aws">AWS</div><div class="cred-body"><h5>AWS Certified Machine Learning: Specialty Prep</h5><div class="cred-meta">LinkedIn · Jun 2025</div><div class="cred-skills"><span>ML</span><span>AWS</span></div></div></div>
            <div class="cred"><div class="cred-issuer linkedin">in</div><div class="cred-body"><h5>Agentic AI for Developers</h5><div class="cred-meta">LinkedIn · Jun 2025</div><div class="cred-skills"><span>Agents</span><span>Enterprise AI</span></div></div></div>
            <div class="cred"><div class="cred-issuer linkedin">in</div><div class="cred-body"><h5>Generative AI with OpenAI API</h5><div class="cred-meta">LinkedIn · Jun 2025</div><div class="cred-skills"><span>OpenAI</span><span>Generative AI</span></div></div></div>
          </div>
        </div>

        <div class="principles-wrap">
          <div class="principles-h">§ How I work</div>
          <div class="principles">
            <div class="ppl">
              <span class="num">/ 01</span>
              <h4>Reporting before <em>automation</em>.</h4>
              <p>New automation only lands after the manual version of the same report has been stress-tested across a few cycles.</p>
            </div>
            <div class="ppl">
              <span class="num">/ 02</span>
              <h4>AI is <em>assistive</em>, not authoritative.</h4>
              <p>LLMs accelerate triage, classification, and summarisation. The analyst owns the call and the interpretation.</p>
            </div>
            <div class="ppl">
              <span class="num">/ 03</span>
              <h4>Consent and tracking quality <em>matter</em>.</h4>
              <p>Measurement that is technically clever but legally fragile is worse than no measurement.</p>
            </div>
            <div class="ppl">
              <span class="num">/ 04</span>
              <h4>Documentation travels with the <em>system</em>.</h4>
              <p>Every workflow ships with a written rationale, an owner, and a rollback path.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
