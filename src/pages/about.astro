---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
import { site } from "../data/site";
---

<SiteLayout
  title="About"
  description="Profile page for Tayyub Yaqoob covering role, focus, training, and the operating principles behind the work."
  pathname="/about"
  crumbs={[{ label: "Home", href: "/" }, { label: "About" }]}
  pageType="about"
>
  <style slot="head">
    .about-layout{display:grid;grid-template-columns:360px minmax(0,1fr);gap:48px;align-items:start}
    @media (max-width:920px){.about-layout{grid-template-columns:1fr;gap:32px}}

    .archive-id{position:sticky;top:96px;background:#fff;border:1px solid var(--line);border-radius:18px;overflow:hidden;box-shadow:var(--shadow-1)}
    .archive-top{display:flex;justify-content:space-between;align-items:center;padding:14px 18px;border-bottom:1px dashed var(--line);background:linear-gradient(180deg,#fff,var(--bg-soft))}
    .archive-code,.archive-strip,.archive-foot,.press-h,.memo-stamp,.recog-h,.creds-meta,.note-index,.note-ref{font-family:var(--mono)}
    .archive-code{font-size:10px;letter-spacing:.16em;color:var(--muted);text-transform:uppercase}
    .archive-stamp{font-family:var(--mono);font-size:10px;letter-spacing:.18em;color:rgba(196,77,44,.5);text-transform:uppercase;border:1px solid rgba(196,77,44,.28);padding:4px 8px;transform:rotate(-8deg)}
    .archive-photo{padding:20px 20px 0}
    .archive-photo img{width:100%;aspect-ratio:4/5;object-fit:cover;border-radius:12px;filter:saturate(.92) contrast(1.04)}
    .archive-meta{padding:18px 20px 20px}
    .archive-meta h3{font-family:var(--serif);font-style:italic;font-weight:400;font-size:30px;line-height:1;color:var(--ink);letter-spacing:-.015em}
    .archive-role{font-size:13px;font-weight:600;color:var(--ink-2);margin-top:8px;line-height:1.5}
    .archive-strip{display:inline-flex;align-items:center;gap:8px;margin-top:14px;padding:6px 10px;border-radius:999px;background:var(--bg-soft);border:1px solid var(--line);font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--terra)}
    .archive-strip::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--signal);box-shadow:0 0 0 0 rgba(90,138,74,.55);animation:pulse 2s infinite}
    .archive-meta dl{margin-top:18px;padding-top:16px;border-top:1px dashed var(--line);display:grid;grid-template-columns:auto 1fr;gap:10px 18px}
    .archive-meta dt{font-size:9px;letter-spacing:.14em;color:var(--muted);text-transform:uppercase}
    .archive-meta dd{font-size:13px;line-height:1.55;color:var(--ink)}
    .archive-foot{display:flex;justify-content:space-between;align-items:center;margin-top:18px;padding-top:14px;border-top:1px dashed var(--line);font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
    .archive-foot a{color:var(--terra)}

    .bio-block{display:flex;flex-direction:column;gap:28px}
    .bio-h{font-family:var(--serif);font-size:clamp(34px,4vw,54px);font-weight:400;letter-spacing:-.02em;line-height:1.02;max-width:12ch}
    .bio-prose{display:flex;flex-direction:column;gap:18px}
    .bio-prose p{font-size:16px;line-height:1.78;color:var(--ink-2)}
    .bio-prose p b{color:var(--ink);font-weight:600}

    .overlap-map{background:linear-gradient(180deg,#fff,var(--bg-soft));border:1px solid var(--line);border-radius:18px;padding:22px 24px}
    .overlap-meta{display:flex;justify-content:space-between;gap:12px;align-items:end;padding-bottom:16px;border-bottom:1px solid var(--line);margin-bottom:18px}
    .overlap-meta h4{font-family:var(--serif);font-size:26px;font-weight:400;letter-spacing:-.01em}
    .overlap-meta span{font-size:10px;letter-spacing:.12em;color:var(--muted);text-transform:uppercase}
    .overlap-svg{width:100%;height:auto}
    .overlap-svg .ring{fill:rgba(255,255,255,.7);stroke:var(--line-2);stroke-width:1.2}
    .overlap-svg .ring.ai{fill:rgba(217,119,87,.18)}
    .overlap-svg .ring.auto{fill:rgba(200,153,66,.18)}
    .overlap-svg .ring.meas{fill:rgba(122,143,94,.18)}
    .overlap-svg .label{font-family:var(--mono);font-size:11px;letter-spacing:.08em;fill:var(--ink);text-transform:uppercase}
    .overlap-svg .detail{font-family:var(--sans);font-size:12px;fill:var(--ink-2)}
    .overlap-svg .center{font-family:var(--serif);font-size:21px;font-style:italic;fill:var(--ink)}

    .recog{padding:22px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
    .recog-h{font-size:10px;letter-spacing:.16em;color:var(--muted);text-transform:uppercase;margin-bottom:14px}
    .recog-list{list-style:none;display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
    .recog-list li{padding-right:14px;border-right:1px dashed var(--line);font-size:14px;line-height:1.65;color:var(--ink-2)}
    .recog-list li:last-child{border-right:0;padding-right:0}
    .recog-list li b{display:block;color:var(--ink);font-weight:600;margin-bottom:4px}
    @media (max-width:820px){.recog-list{grid-template-columns:1fr}.recog-list li{border-right:0;padding-right:0;padding-bottom:12px;border-bottom:1px dashed var(--line)}.recog-list li:last-child{padding-bottom:0;border-bottom:0}}

    .creds-wrap{display:flex;flex-direction:column;gap:16px}
    .creds-head{display:flex;justify-content:space-between;align-items:end;gap:16px}
    .creds-head h3{font-family:var(--serif);font-size:28px;font-weight:400;letter-spacing:-.01em}
    .creds-meta{font-size:10px;letter-spacing:.12em;color:var(--muted);text-transform:uppercase}
    .cred-shelf{position:relative;display:flex;gap:14px;align-items:flex-end;padding:18px 0 14px;border-bottom:2px solid var(--line)}
    .cred-shelf::before{content:"";position:absolute;left:0;right:0;bottom:14px;height:1px;background:linear-gradient(90deg,var(--line-2),transparent)}
    .cred-spine{position:relative;flex:1;min-height:240px;padding:18px 12px 16px;border:1px solid var(--line);border-bottom:0;border-radius:16px 16px 6px 6px;background:#fff;display:flex;flex-direction:column;justify-content:space-between;box-shadow:var(--shadow-1);transform-origin:bottom center;transition:transform .25s,border-color .25s}
    .cred-spine:hover{transform:translateY(-6px) rotate(-1deg);border-color:var(--line-2)}
    .cred-spine.google{background:linear-gradient(180deg,#fff,#f7f3ea)}
    .cred-spine.aws{background:linear-gradient(180deg,#fff,#f6efe0)}
    .cred-spine.linkedin{background:linear-gradient(180deg,#fff,#f3f1ea)}
    .cred-year{font-size:9.5px;letter-spacing:.16em;color:var(--muted);text-transform:uppercase}
    .cred-spine h4{font-family:var(--serif);font-size:22px;font-weight:400;line-height:1.02;letter-spacing:-.015em;writing-mode:vertical-rl;transform:rotate(180deg);min-height:150px}
    .cred-spine p{font-size:11px;letter-spacing:.12em;color:var(--terra);text-transform:uppercase}
    .creds-also{font-size:13.5px;line-height:1.7;color:var(--muted)}
    @media (max-width:720px){.cred-shelf{flex-direction:column;align-items:stretch}.cred-shelf::before{display:none}.cred-spine{min-height:unset;border-bottom:1px solid var(--line)}.cred-spine h4{writing-mode:unset;transform:none;min-height:unset}}

    .memo{position:relative;background:#fffdf8;border:1px solid var(--line-2);border-radius:18px;padding:24px 24px 22px;box-shadow:var(--shadow-1)}
    .memo::before{content:"";position:absolute;left:24px;right:24px;top:56px;height:1px;background:linear-gradient(90deg,var(--line-2),transparent)}
    .memo-stamp{position:absolute;top:18px;right:24px;font-size:11px;letter-spacing:.18em;color:rgba(196,77,44,.38);text-transform:uppercase;transform:rotate(-9deg)}
    .press-h{font-size:10px;letter-spacing:.16em;color:var(--muted);text-transform:uppercase;margin-bottom:18px}
    .press-bio{font-size:14.5px;line-height:1.72;color:var(--ink-2);padding-top:12px}
    .press-contact{margin-top:14px;font-size:13.5px;line-height:1.65;color:var(--ink-2)}

    .principles-wrap{display:flex;flex-direction:column;gap:16px}
    .principles-head{display:flex;justify-content:space-between;align-items:end;gap:16px}
    .principles-head h3{font-family:var(--serif);font-size:28px;font-weight:400;letter-spacing:-.01em}
    .principles-note{font-size:10px;letter-spacing:.12em;color:var(--muted);text-transform:uppercase}
    .principles-sheet{background:linear-gradient(180deg,#fff,var(--bg-soft));border:1px solid var(--line);border-radius:18px;padding:18px 22px;background-image:linear-gradient(rgba(214,206,187,.45) 1px,transparent 1px);background-size:100% 40px}
    .principles-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px 24px}
    .note-entry{padding:14px 0 12px;border-top:1px solid rgba(214,206,187,.85)}
    .note-entry:first-child,.note-entry:nth-child(2){border-top:0}
    .note-index{display:inline-block;font-size:10px;letter-spacing:.16em;color:var(--muted);text-transform:uppercase;margin-bottom:6px}
    .note-entry h4{font-family:var(--serif);font-size:22px;font-weight:400;line-height:1.12;letter-spacing:-.01em}
    .note-entry p{font-size:14px;line-height:1.68;color:var(--ink-2);margin-top:8px}
    .note-ref{display:inline-block;margin-top:10px;font-size:9px;letter-spacing:.14em;color:var(--terra);text-transform:uppercase}
    @media (max-width:720px){.principles-grid{grid-template-columns:1fr}.note-entry:nth-child(2){border-top:1px solid rgba(214,206,187,.85)}}
  </style>

  <PageHeader
    title="About."
    subtitle="Senior Digital Analyst working on AI-assisted analytics, automation, and digital measurement."
    crumbs={[{ label: "Home", href: "/" }, { label: "About" }]}
  />

  <section class="section wrap first" data-screen-label="Bio">
    <div class="about-layout">
      <aside class="archive-id rv">
        <div class="archive-top">
          <span class="archive-code">AR-2026-001</span>
          <span class="archive-stamp">Reviewed</span>
        </div>
        <div class="archive-photo">
          <img src={site.image} alt={site.name} />
        </div>
        <div class="archive-meta">
          <h3>{site.name}</h3>
          <p class="archive-role">{site.role}<br />8 Million Stories · Stirling, UK</p>
          <span class="archive-strip">Available for direct contact</span>
          <dl>
            <dt>Focus</dt><dd>AI-assisted analytics, automation, measurement engineering</dd>
            <dt>Edu</dt><dd>MSc Computing Science · University of Stirling</dd>
            <dt>Based</dt><dd>Stirling · United Kingdom · GMT</dd>
            <dt>Stack</dt><dd>BigQuery · Python · GA4 · GTM · LLM APIs</dd>
          </dl>
          <div class="archive-foot">
            <span>Valid 2026</span>
            <span><a href="/contact">Contact →</a></span>
          </div>
        </div>
      </aside>

      <div class="bio-block rv d1">
        <h3 class="bio-h">I build analytics workflows teams use.</h3>

        <div class="overlap-map rv d1">
          <div class="overlap-meta">
            <h4>Where the work overlaps.</h4>
            <span>AI · Automation · Measurement</span>
          </div>
          <svg class="overlap-svg" viewBox="0 0 520 260" aria-label="Overlap between AI, automation, and measurement">
            <circle class="ring ai" cx="170" cy="150" r="86"></circle>
            <circle class="ring auto" cx="350" cy="150" r="86"></circle>
            <circle class="ring meas" cx="260" cy="82" r="86"></circle>
            <text class="label" x="112" y="154">AI</text>
            <text class="label" x="318" y="154">Automation</text>
            <text class="label" x="214" y="42">Measurement</text>
            <text class="detail" x="190" y="102">AI-search visibility</text>
            <text class="detail" x="132" y="184">Reporting QA</text>
            <text class="detail" x="296" y="184">LLM-assisted analytics</text>
            <text class="center" x="221" y="145">Day-to-day</text>
          </svg>
        </div>

        <div class="bio-prose">
          <p>I'm a Senior Digital Analyst at 8 Million Stories in Stirling. Day-to-day I build reporting systems in BigQuery and Python, measurement pipelines in GA4 and GTM, and LLM-assisted workflows for classification, summarisation, and reporting QA. Most of the strongest work is private to clients. Recent engagements have been in media, financial services, consumer brands, insurance, pharma, and personal finance.</p>
          <p>Outside that I write for Cointelegraph and AlphaWire, mostly on AI-driven trading and crypto-security. A few of those pieces have been cited as expert commentary, and I've peer-reviewed three book chapters for IGI Global. The writing page has the full record.</p>
          <p>I studied computer science at Stirling and have worked in analytics since. Most of the job is judgement: what the numbers can tell you and where they need an asterisk. LLMs make parts of it faster; they don't change what counts as a good answer. I'd rather ship one reporting workflow a team trusts than three they don't.</p>
        </div>

        <aside class="recog rv">
          <h4 class="recog-h">Selected recognition</h4>
          <ul class="recog-list">
            <li><b>Cointelegraph and AlphaWire.</b> 35+ technical articles on AI, crypto-security, and quantum-resistant systems, 2022 to 2026. <a href="/publications">See writing →</a></li>
            <li><b>CCN and Inside Higher Ed.</b> Cited as an expert source across four pieces: agent wallets, AI trading bots, AI-generated code risk, and Auto-GPT autonomous agents. <a href="/publications#cited">Read the citations →</a></li>
            <li><b>IGI Global.</b> Invited peer reviewer for three book chapters on CBDCs, blockchain-IoT banking, and AI-FinTech, 2022 to 2023. <a href="/publications#peer-review">See review record →</a></li>
          </ul>
        </aside>

        <div class="creds-wrap">
          <div class="creds-head">
            <h3>Training and credentials.</h3>
            <span class="creds-meta">Selected · 2024 to 2026</span>
          </div>
          <div class="cred-shelf">
            <article class="cred-spine google">
              <span class="cred-year">2025</span>
              <h4>5-Day AI Agents Intensive Course</h4>
              <p>Google</p>
            </article>
            <article class="cred-spine aws">
              <span class="cred-year">2025</span>
              <h4>AWS Certified Machine Learning: Specialty Prep</h4>
              <p>LinkedIn</p>
            </article>
            <article class="cred-spine linkedin">
              <span class="cred-year">2024–2025</span>
              <h4>Vertex AI, MCP, Agentic AI, OpenAI API</h4>
              <p>Additional coursework</p>
            </article>
          </div>
          <p class="creds-also">Also completed coursework on Vertex AI MLOps, Model Context Protocol with Agentic AI, Agentic AI for Developers, and Generative AI with the OpenAI API.</p>
        </div>

        <aside class="memo rv" id="for-press">
          <span class="memo-stamp">For press</span>
          <h4 class="press-h">For press, podcasts, and panel intros</h4>
          <p class="press-bio">Tayyub Yaqoob is a UK-based Senior Digital Analyst at 8 Million Stories, where he builds AI-assisted analytics, automation, and measurement systems for digital and analyst teams. He has published technical writing for Cointelegraph and AlphaWire, been cited as an expert source by CCN, and completed three peer reviews for IGI Global.</p>
          <p class="press-contact">
            For interviews, panels, or expert commentary, email <a href={`mailto:${site.email}`}>{site.email}</a>. Headshot and longer bio on request.
          </p>
        </aside>

        <div class="principles-wrap">
          <div class="principles-head">
            <h3>How I work.</h3>
            <span class="principles-note">Field notes · operating principles</span>
          </div>
          <div class="principles-sheet">
            <div class="principles-grid">
              <article class="note-entry">
                <span class="note-index">01</span>
                <h4>Reporting before automation.</h4>
                <p>New automation only lands after the manual version of the same report has been stress-tested across a few cycles.</p>
                <span class="note-ref">See case studies →</span>
              </article>
              <article class="note-entry">
                <span class="note-index">02</span>
                <h4>AI is assistive, not authoritative.</h4>
                <p>LLMs accelerate triage, classification, and summarisation. The analyst still owns the call and the interpretation.</p>
                <span class="note-ref">Human review required</span>
              </article>
              <article class="note-entry">
                <span class="note-index">03</span>
                <h4>Consent and tracking quality matter.</h4>
                <p>Measurement that is technically clever but legally fragile is worse than no measurement.</p>
                <span class="note-ref">LedgerTouch context</span>
              </article>
              <article class="note-entry">
                <span class="note-index">04</span>
                <h4>Documentation travels with the system.</h4>
                <p>Every workflow ships with a written rationale, an owner, and a rollback path.</p>
                <span class="note-ref">Evidence on request</span>
              </article>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
