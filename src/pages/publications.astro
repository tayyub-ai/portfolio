<script is:inline>
(function(){
  const tabs=document.querySelectorAll('.shelf-filter[data-shelf="ct"] .shelf-tab');
  const items=document.querySelectorAll('[data-shelf-grid="ct"] .shelf-item');
  if(!tabs.length)return;
  tabs.forEach(t=>{
    t.addEventListener('click',()=>{
      tabs.forEach(x=>x.classList.remove('on'));
      t.classList.add('on');
      const c=t.dataset.cat;
      items.forEach(it=>{
        const m=c==='all'||(it.dataset.cat||'').split(/\s+/).includes(c);
        it.classList.toggle('dim',!m);
      });
    });
  });
})();
</script>
