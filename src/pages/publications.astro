---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
import {
  liveAlphaWireArticles,
  liveCointelegraphArticles,
  publicationArchive,
} from "../data/publications";

const allArticles = [...liveCointelegraphArticles, ...liveAlphaWireArticles];

const themeOrder = ["Security", "AI agents", "AI trading", "Quantum", "Blockchain", "Fintech", "Payments", "Adoption", "Research workflow", "Business", "Technology"];
const formatOrder = ["Explained", "How to", "Business", "Technology"];
const themeColors: Record<string, string> = {
  "Security": "#c44d2c",
  "AI agents": "#d97757",
  "AI trading": "#c89942",
  "Quantum": "#7a8f5e",
  "Blockchain": "#5d7a4a",
  "Fintech": "#8a5e15",
  "Payments": "#b5763b",
  "Adoption": "#a8835c",
  "Research workflow": "#3d5535",
  "Business": "#c44d2c",
  "Technology": "#d97757",
};

const expertCitations = [
  {
    headline: "What Are AI Agents: Types, Examples & Steps To Build One",
    url: "https://www.ccn.com/education/crypto/ai-agents-how-to-create-based-ai-agent/",
    topic: "Agent wallets and the permission layer",
    quote:
      "The real engineering work on agent wallets now sits at the permission layer, not the model layer. Scoped session keys, time-bound delegations and policy rulebooks that enforce spending caps and counterparty whitelists before any signature is produced are what separate an experimental agent from one that can be trusted with real funds. Revocation, audit logging and human override are no longer safeguards bolted on top, they are core infrastructure.",
  },
  {
    headline: "How AI Crypto Trading Bots Make And Lose Millions Inside The Black Box",
    url: "https://www.ccn.com/education/crypto/ai-crypto-trading-bots-how-they-make-and-lose-millions/",
    topic: "AI trading bots and verifiability",
    quote:
      "The real black box is not the model, it is the gap between what the system did and what the user can verify. A bot can react quickly to noisy data, stale signals or overfitted patterns while still looking reliable, because the execution is automated and the outcome is visible even when the reasoning is not. Any system handling real capital needs tested risk limits, full audit logs of inputs and decisions, and human override paths, with the bot's tool integrations and data feeds treated as part of the attack surface.",
  },
  {
    headline: "AI Hallucinations & Slopsquatting: A Caution for Blockchain Devs",
    url: "https://www.ccn.com/education/crypto/ai-hallucinations-slopsquatting-risk-for-blockchain-devs/",
    topic: "AI-generated code and supply-chain risk",
    quote:
      "The defence here is not careful prompting, it is treating AI suggestions like any other untrusted input. The fact that models confidently generate plausible-sounding package names that do not exist is what makes slopsquatting work, and no amount of better prompting closes that gap. Verifying package provenance, checking how recently a package was published and preferring audited libraries matters more than the prompt that produced the code. AI-generated code should reach production through the same review path as any third-party dependency, not a shorter one.",
  },
];

const igiReviews = [
  {
    title: "CBDCs and Financial Stability",
    year: "2022",
    note: "Macro-impact chapter on central bank digital currencies",
  },
  {
    title: "Blockchain and Consensus for IoT-Based Banking",
    year: "2022",
    note: "Consensus-protocol chapter for IoT banking infrastructure",
  },
  {
    title: "AI-Enabled Agile IoT for FinTech",
    year: "2023",
    note: "Edge-AI and FinTech-architecture chapter",
  },
];

const publicationSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Writing, citations, and peer review",
  url: "https://www.tayyubyaqoob.com/publications",
  description:
    "Technical articles for Cointelegraph and AlphaWire, expert-source citations in CCN, and invited peer review record for IGI Global.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: allArticles.map((article, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "Article",
        headline: article.title,
        url: article.url,
        author: {
          "@id": "https://www.tayyubyaqoob.com/#person",
        },
        publisher: {
          "@type": "Organization",
          name: article.outlet,
        },
      },
    })),
  },
};

const citationSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Expert-source citations in CCN",
  itemListElement: expertCitations.map((citation, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Article",
      headline: citation.headline,
      url: citation.url,
      publisher: {
        "@type": "Organization",
        name: "CCN",
        url: "https://www.ccn.com/",
      },
      mentions: {
        "@id": "https://www.tayyubyaqoob.com/#person",
      },
    },
  })),
};

const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Invited peer-review record for IGI Global",
  itemListElement: igiReviews.map((review, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Chapter",
      name: review.title,
      datePublished: review.year,
      publisher: {
        "@type": "Organization",
        name: "IGI Global",
        url: "https://www.igi-global.com/",
      },
      reviewedBy: {
        "@id": "https://www.tayyubyaqoob.com/#person",
      },
    },
  })),
};
---

<SiteLayout
  title="Publications"
  description="Live article record plus archive continuity for technical writing across Cointelegraph and AlphaWire."
  pathname="/publications"
  crumbs={[{ label: "Home", href: "/" }, { label: "Publications" }]}
  structuredData={[publicationSchema, citationSchema, reviewSchema]}
>
  <style slot="head">
    /* Intro paragraph */
    .pub-intro{max-width:64ch;font-size:17px;line-height:1.7;color:var(--ink-2)}
    .pub-intro b{color:var(--ink);font-weight:600}
    .pub-intro a{color:var(--ink);border-bottom:1px solid var(--line-2);padding-bottom:1px}
    .pub-intro a:hover{color:var(--terra);border-color:var(--terra)}

    /* Cited list (CCN excerpts) */
    .cited-list{display:flex;flex-direction:column;gap:14px;margin-top:8px}
    .cited{display:block;position:relative;background:#fff;border:1px solid var(--line);border-radius:14px;padding:24px 28px;text-decoration:none;color:inherit;transition:transform .35s cubic-bezier(.2,.7,.1,1),box-shadow .35s,border-color .25s}
    .cited::before{content:"";position:absolute;left:0;top:0;width:4px;height:100%;background:var(--terra);border-radius:14px 0 0 14px}
    .cited:hover{transform:translateY(-3px);box-shadow:var(--shadow-2);border-color:var(--line-2)}
    .cited-meta{display:flex;flex-wrap:wrap;gap:14px;font-family:var(--mono);font-size:10.5px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;margin-bottom:10px}
    .cited-meta .cited-outlet{color:var(--terra);font-weight:600}
    .cited-title{font-family:var(--serif);font-weight:400;font-size:clamp(20px,2vw,26px);line-height:1.15;letter-spacing:-.01em;color:var(--ink);margin-bottom:14px}
    .cited-quote{font-family:var(--serif);font-style:italic;font-size:16px;line-height:1.6;color:var(--ink-2);padding:14px 18px;border-left:3px solid var(--line-2);background:var(--bg-soft);border-radius:0 8px 8px 0;margin:0 0 14px}
    .cited-cta{font-family:var(--mono);font-size:11px;letter-spacing:.08em;color:var(--terra);text-transform:uppercase;display:inline-flex;align-items:center;gap:6px;font-weight:600}
    .cited-cta::after{content:"↗";transition:transform .25s}
    .cited:hover .cited-cta::after{transform:translate(2px,-2px)}

    /* IGI peer review list */
    .igi-list{list-style:none;padding:0;margin:8px 0 0;background:#fff;border:1px solid var(--line);border-radius:12px;overflow:hidden}
    .igi-row{display:grid;grid-template-columns:64px 1fr;gap:18px;padding:18px 22px;border-bottom:1px solid var(--line);align-items:baseline;transition:background .2s}
    .igi-row:last-child{border-bottom:0}
    .igi-row:hover{background:var(--bg-soft)}
    .igi-num{font-family:var(--mono);font-size:11px;letter-spacing:.12em;color:var(--muted);font-weight:600}
    .igi-body h4{font-family:var(--serif);font-weight:400;font-size:18px;line-height:1.25;color:var(--ink);letter-spacing:-.005em;margin-bottom:4px}
    .igi-meta{font-size:13px;color:var(--ink-2);line-height:1.5}
    @media (max-width:680px){.igi-row{grid-template-columns:48px 1fr;gap:12px;padding:16px 18px}}


    /* ── Article cards (themed) ── */
    .pub-cards{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-top:18px}
    .pub-card{position:relative;background:#fff;border:1px solid var(--line);border-radius:12px;padding:20px 22px;display:flex;flex-direction:column;gap:8px;text-decoration:none;color:inherit;overflow:hidden;transition:transform .35s cubic-bezier(.2,.7,.1,1),box-shadow .35s,border-color .25s}
    .pub-card::before{content:"";position:absolute;left:0;top:0;width:3px;height:100%;background:var(--terra);transition:width .25s}
    .pub-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-2);border-color:var(--line-2)}
    .pub-card:hover::before{width:5px}
    .pub-card .pub-tag{font-family:var(--mono);font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .pub-card .pub-tag .theme{padding:3px 8px;border-radius:999px;border:1px solid var(--line);background:#fff;color:var(--ink);font-weight:600}
    .pub-card .pub-tag .outlet{color:var(--terra)}
    .pub-card .pub-tag .format{color:var(--ink-2)}
    .pub-card h4{font-family:var(--serif);font-size:18px;font-weight:400;line-height:1.3;letter-spacing:-.005em;color:var(--ink)}
    .pub-card:hover h4{color:var(--terra)}
    .pub-card .cta{margin-top:auto;font-family:var(--mono);font-size:10px;letter-spacing:.08em;color:var(--terra);text-transform:uppercase;padding-top:8px;border-top:1px dashed var(--line);display:flex;justify-content:space-between;align-items:center}
    .pub-card .cta::after{content:"↗";transition:transform .25s}
    .pub-card:hover .cta::after{transform:translate(2px,-2px)}
    @media (max-width:780px){.pub-cards{grid-template-columns:1fr}}

    /* ── Archive card (clean) ── */
    .archive{margin-top:14px;background:#fff;border:1px solid var(--line);border-radius:12px;padding:32px 36px;display:grid;grid-template-columns:1fr auto;gap:24px;align-items:center;box-shadow:var(--shadow-1);transition:transform .35s,box-shadow .35s,border-color .25s}
    .archive:hover{transform:translateY(-2px);box-shadow:var(--shadow-2);border-color:var(--line-2)}
    .archive .lab{font-family:var(--mono);font-size:10px;letter-spacing:.14em;color:var(--terra);text-transform:uppercase;margin-bottom:8px;font-weight:600}
    .archive h3{font-family:var(--serif);font-weight:400;font-size:clamp(24px,2.6vw,32px);line-height:1.1;letter-spacing:-.015em;color:var(--ink)}
    .archive h3 em{font-style:italic;color:var(--terra)}
    .archive p{font-size:14px;color:var(--ink-2);line-height:1.65;margin-top:8px;max-width:54ch}
    .archive .cta{display:inline-flex;align-items:center;gap:6px;padding:10px 18px;border-radius:999px;background:var(--ink);color:#fff;font-family:'Inter',sans-serif;font-weight:600;font-size:13px;text-decoration:none;transition:background .25s,transform .25s;white-space:nowrap}
    .archive .cta:hover{background:var(--terra);transform:translateY(-1px)}
    .archive .cta::after{content:"↗"}
    @media (max-width:780px){.archive{grid-template-columns:1fr;padding:24px 26px}}
  </style>

  <PageHeader
    title="Writing."
    subtitle="Technical articles on AI, crypto-security, and data systems for <b>Cointelegraph</b> and <b>AlphaWire</b>, plus an archive of older Cointelegraph pieces where the publisher has restructured its author pages."
    crumbs={[{ label: "Home", href: "/" }, { label: "Publications" }]}
  />

  <section class="section wrap first" data-screen-label="Intro">
    <p class="pub-intro rv">
      Around <b>35 technical articles</b> for <b>Cointelegraph</b> and <b>AlphaWire</b> between 2022 and 2026, covering AI-driven trading, crypto-security, quantum-resistant systems, and agentic risk. Commentary cited as an expert source by <a href="#cited">CCN</a> across three pieces on AI agents, AI trading bots, and AI-generated code risk. Invited <a href="#peer-review">peer reviewer</a> for IGI Global across three book chapters between 2022 and 2023.
    </p>
  </section>

  <section class="section wrap" id="cited" data-screen-label="Cited">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <h2>Cited in CCN.</h2>
        <p>Three CCN articles that cite my commentary on agent wallets and the permission layer, AI trading-bot verifiability, and supply-chain risk from AI-generated code.</p>
      </div>
      <div class="sec-head-r"></div>
    </div>

    <div class="cited-list rv">
      {expertCitations.map((c) => (
        <a class="cited" href={c.url} target="_blank" rel="noreferrer">
          <div class="cited-meta">
            <span class="cited-outlet">CCN · Education</span>
            <span class="cited-topic">{c.topic}</span>
          </div>
          <h3 class="cited-title">{c.headline}</h3>
          <blockquote class="cited-quote">{c.quote}</blockquote>
          <span class="cited-cta">Read on CCN</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section wrap" id="peer-review" data-screen-label="Peer review">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <h2>Peer review for IGI Global.</h2>
        <p>Three publisher-led chapter reviews between 2022 and 2023 across central bank digital currencies, blockchain consensus in IoT banking, and AI-enabled FinTech architecture.</p>
      </div>
      <div class="sec-head-r"></div>
    </div>

    <ol class="igi-list rv">
      {igiReviews.map((r, i) => (
        <li class="igi-row">
          <span class="igi-num">{String(i + 1).padStart(2, "0")}</span>
          <div class="igi-body">
            <h4>{r.title}</h4>
            <span class="igi-meta">IGI Global · invited reviewer · {r.year} · {r.note}</span>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="section wrap" data-screen-label="Articles">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <h2>Articles.</h2>
      </div>
      <div class="sec-head-r">/ all verified</div>
    </div>

    <div class="pub-cards rv">
      {allArticles.map((article) => (
        <a class="pub-card" href={article.url} target="_blank" rel="noreferrer">
          <div class="pub-tag">
            <span class="theme" style={`color:${themeColors[article.theme] || "var(--terra)"}`}>{article.theme}</span>
            <span class="outlet">{article.outlet}</span>
            <span>·</span>
            <span class="format">{article.format}</span>
          </div>
          <h4>{article.title}</h4>
          <span class="cta">Open article</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section wrap" data-screen-label="Archive">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <h2>Cointelegraph archive.</h2>
      </div>
      <div class="sec-head-r"></div>
    </div>

    <div class="archive rv">
      <div>
        <span class="lab">Archive · publisher restructure</span>
        <h3>Cointelegraph PDF archive.</h3>
        <p>{publicationArchive.description} A PDF record of older Cointelegraph pieces preserved after the publisher restructured its author pages. Where direct URLs remain live they are listed above.</p>
      </div>
      <a class="cta" href={publicationArchive.url} target="_blank" rel="noreferrer">Open PDF</a>
    </div>
  </section>

</SiteLayout>
