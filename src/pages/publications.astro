---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
import {
  liveAlphaWireArticles,
  liveCointelegraphArticles,
  publicationArchive,
} from "../data/publications";

const publicationSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Publications",
  url: "https://www.tayyubyaqoob.com/publications",
  description:
    "Direct live article URLs plus archive continuity proof for publications across Cointelegraph and AlphaWire.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: [...liveCointelegraphArticles, ...liveAlphaWireArticles].map((article, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "Article",
        headline: article.title,
        url: article.url,
        publisher: {
          "@type": "Organization",
          name: article.outlet,
        },
      },
    })),
  },
};
---

<SiteLayout
  title="Publications"
  description="Live article record plus archive continuity for technical writing across Cointelegraph and AlphaWire."
  pathname="/publications"
  crumbs={[{ label: "Home", href: "/" }, { label: "Publications" }]}
  structuredData={[publicationSchema]}
>
  <style slot="head">
    .pub-counter{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:32px}
    .pub-counter .stat{background:#fff;border:1px solid var(--line);border-radius:var(--r-md);padding:18px 20px;display:flex;flex-direction:column;gap:4px;transition:transform .25s,border-color .25s}
    .pub-counter .stat:hover{transform:translateY(-2px);border-color:var(--line-2)}
    .pub-counter .stat .v{font-family:var(--serif);font-size:32px;line-height:1;letter-spacing:-.02em}
    .pub-counter .stat .v em{font-style:italic;color:var(--terra)}
    .pub-counter .stat .k{font-family:var(--mono);font-size:10.5px;color:var(--muted);letter-spacing:.04em;text-transform:uppercase}
    .pub-counter .stat .sub{font-size:12px;color:var(--ink-2);line-height:1.4;margin-top:2px}
    .pub-list{display:flex;flex-direction:column;gap:0;background:#fff;border:1px solid var(--line);border-radius:var(--r-lg);overflow:hidden;box-shadow:var(--shadow-1)}
    .pub-item{display:grid;grid-template-columns:120px 1fr auto;gap:18px;align-items:center;padding:16px 22px;border-bottom:1px solid var(--line);color:inherit;text-decoration:none;transition:background .2s,padding-left .25s cubic-bezier(.2,.7,.1,1)}
    .pub-item:last-child{border-bottom:0}
    .pub-item:hover{background:rgba(196,77,44,.04);padding-left:30px}
    .pub-item .theme{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:.06em;text-transform:uppercase}
    .pub-item .title{font-family:var(--serif);font-size:18px;line-height:1.3;letter-spacing:-.005em;color:var(--ink)}
    .pub-item:hover .title{color:var(--terra)}
    .pub-item .meta{display:flex;gap:8px;align-items:center;justify-content:flex-end;flex-wrap:wrap}
    .pub-item .meta span{font-family:var(--mono);font-size:9.5px;letter-spacing:.08em;text-transform:uppercase;padding:4px 8px;border-radius:999px;border:1px solid var(--line);background:#fff}
    .archive-card{background:linear-gradient(160deg,#fff,var(--bg-soft));border:1px solid var(--line);border-radius:var(--r-lg);padding:24px 26px;box-shadow:var(--shadow-1)}
    .archive-card h3{font-family:var(--serif);font-size:32px;font-weight:400;letter-spacing:-.018em;line-height:1.04;margin-bottom:10px}
    .archive-card h3 em{font-style:italic;color:var(--terra)}
    .archive-card p{font-size:14.5px;color:var(--ink-2);line-height:1.65;max-width:62ch}
    .archive-card a{color:var(--terra);border-bottom:1px solid currentColor}
    @media (max-width:880px){.pub-counter{grid-template-columns:1fr 1fr}.pub-item{grid-template-columns:1fr;gap:8px;padding:16px 18px}.pub-item:hover{padding-left:18px}.pub-item .meta{justify-content:flex-start}}
  </style>

  <PageHeader
    title="Publications and <em>archive record</em>."
    subtitle="This page now separates <b>live article URLs</b> from <b>archival continuity proof</b>. Unstable publisher author-index pages are no longer treated as the primary evidence layer."
    crumbs={[{ label: "Home", href: "/" }, { label: "Publications" }]}
  />

  <section class="section wrap first" data-screen-label="Volume">
    <div class="pub-counter rv">
      <div class="stat"><span class="v">35<em>+</em></span><span class="k">Published technical articles</span><span class="sub">Total body of work across live URLs and archived publication history.</span></div>
      <div class="stat"><span class="v"><em>8</em></span><span class="k">Verified Cointelegraph links</span><span class="sub">Direct URLs confirmed through browser-accessible retrieval on 2026-05-14.</span></div>
      <div class="stat"><span class="v"><em>2</em></span><span class="k">Verified live AlphaWire links</span><span class="sub">Current direct URLs still resolving publicly.</span></div>
      <div class="stat"><span class="v"><em>1</em></span><span class="k">Archive continuity asset</span><span class="sub">PDF record used because publisher structure changed.</span></div>
    </div>
  </section>

  <section class="section wrap" data-screen-label="Cointelegraph">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--terra)"></span>§ Live Cointelegraph record</span>
        <h2>Direct article <em>URLs</em>.</h2>
        <p>The site no longer depends on a publisher author page as the primary proof surface. These are direct article links confirmed through browser-accessible retrieval on 2026-05-14.</p>
      </div>
      <div class="sec-head-r">/ live links only</div>
    </div>

    <div class="pub-list rv">
      {liveCointelegraphArticles.map((article) => (
        <a class="pub-item" href={article.url} target="_blank" rel="noreferrer">
          <span class="theme">{article.theme}</span>
          <span>
            <span class="title">{article.title}</span>
          </span>
          <span class="meta">
            <span>{article.outlet}</span>
            <span>{article.format}</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="section wrap" data-screen-label="AlphaWire">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--ochre)"></span>§ Live AlphaWire record</span>
        <h2>Direct AlphaWire <em>articles</em>.</h2>
        <p>The old author-index path was returning 404 when checked on 2026-05-14, so this page keeps only direct article URLs as public proof.</p>
      </div>
      <div class="sec-head-r">/ no dead author pages</div>
    </div>

    <div class="pub-list rv">
      {liveAlphaWireArticles.map((article) => (
        <a class="pub-item" href={article.url} target="_blank" rel="noreferrer">
          <span class="theme">{article.theme}</span>
          <span>
            <span class="title">{article.title}</span>
          </span>
          <span class="meta">
            <span>{article.outlet}</span>
            <span>{article.format}</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="section wrap" data-screen-label="Archive">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--moss)"></span>§ Historical continuity</span>
        <h2>Archive-backed <em>publication proof</em>.</h2>
      </div>
      <div class="sec-head-r"><a href="/evidence">Evidence route →</a></div>
    </div>

    <div class="archive-card rv">
      <h3>{publicationArchive.title.replace(" archive", "")} <em>archive</em>.</h3>
      <p>{publicationArchive.description} This is not used to pretend the old public profile pages still work. It is used to preserve continuity when a publisher removes or restructures older surfaces.</p>
      <p style="margin-top:14px"><a href={publicationArchive.url}>Open the PDF archive ↗</a></p>
    </div>
  </section>
</SiteLayout>
