---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="Testimonials"
  description="Verbatim client and partner feedback used as supporting proof alongside case studies and evidence documents."
  pathname="/testimonials"
  crumbs={[{ label: "Home", href: "/" }, { label: "Testimonials" }]}
>
  <style slot="head">
    /* ── Quote cards (consistent, clean) ── */
    .quote-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;margin-top:8px}
    @media (max-width:780px){.quote-grid{grid-template-columns:1fr}}

    .qcard{position:relative;background:#fff;border:1px solid var(--line);border-radius:12px;padding:28px 30px;display:flex;flex-direction:column;gap:18px;box-shadow:var(--shadow-1);transition:transform .35s cubic-bezier(.2,.7,.1,1),box-shadow .35s,border-color .25s;overflow:hidden}
    .qcard:hover{transform:translateY(-3px);box-shadow:var(--shadow-2);border-color:var(--line-2)}
    .qcard::before{content:"";position:absolute;left:0;top:0;width:4px;height:100%;background:var(--terra)}
    .qcard.q-2::before{background:var(--ochre)}
    .qcard.q-3::before{background:var(--moss)}
    .qcard.q-4::before{background:var(--coral)}

    .qcard-h{display:flex;justify-content:space-between;align-items:baseline;gap:12px;padding-bottom:14px;border-bottom:1px dashed var(--line)}
    .qcard-h .who{display:flex;flex-direction:column;gap:2px}
    .qcard-h .who b{font-family:'Inter',sans-serif;font-weight:700;font-size:15px;letter-spacing:-.005em;color:var(--ink)}
    .qcard-h .who .role{font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
    .qcard-h .tag{font-family:var(--mono);font-size:10px;letter-spacing:.1em;color:var(--terra);text-transform:uppercase;text-align:right;line-height:1.4}
    .qcard.q-2 .qcard-h .tag{color:#8a5e15}
    .qcard.q-3 .qcard-h .tag{color:var(--moss)}
    .qcard.q-4 .qcard-h .tag{color:var(--coral)}

    .qbody{font-family:var(--serif);font-style:italic;font-size:20px;line-height:1.45;letter-spacing:-.008em;color:var(--ink);position:relative;padding-left:18px}
    .qbody::before{content:"";position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--terra)}
    .qcard.q-2 .qbody::before{background:var(--ochre)}
    .qcard.q-3 .qbody::before{background:var(--moss)}
    .qcard.q-4 .qbody::before{background:var(--coral)}
    .qbody b{font-style:normal;color:var(--ink);font-weight:600;background:linear-gradient(180deg,transparent 65%,rgba(200,153,66,.32) 65%);padding:0 2px}

    .qfoot{display:flex;justify-content:space-between;align-items:center;font-family:var(--mono);font-size:10px;letter-spacing:.08em;color:var(--muted);text-transform:uppercase}
    .qfoot .source{display:inline-flex;align-items:center;gap:5px}
    .qfoot .source::before{content:"";width:6px;height:6px;border-radius:50%;background:currentColor;opacity:.5}

    /* Counter strip */
    .tst-counter{display:flex;flex-wrap:wrap;gap:14px;margin-top:8px}
    .tst-counter .stat{flex:1;min-width:140px;display:flex;flex-direction:column;gap:4px;padding:18px 22px;background:#fff;border:1px solid var(--line);border-radius:12px}
    .tst-counter .stat .v{font-family:var(--serif);font-size:36px;letter-spacing:-.02em;color:var(--ink);line-height:1}
    .tst-counter .stat .v em{font-style:italic;color:var(--terra)}
    .tst-counter .stat .k{font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}

    /* Footer route */
    .qfooter{margin-top:36px;padding:24px 28px;background:var(--bg-soft);border:1px solid var(--line);border-radius:12px;display:flex;justify-content:space-between;align-items:center;gap:18px;flex-wrap:wrap}
    .qfooter .text b{display:block;font-family:var(--serif);font-style:italic;font-size:20px;letter-spacing:-.01em;color:var(--ink);margin-bottom:2px}
    .qfooter .text span{font-size:14px;color:var(--ink-2);line-height:1.55}
    .qfooter .links{display:flex;gap:14px;font-family:var(--mono);font-size:11px;letter-spacing:.06em;color:var(--terra);text-transform:uppercase}
    .qfooter .links a{display:inline-flex;align-items:center;gap:4px}
    .qfooter .links a::after{content:"→"}
  </style>

  <PageHeader
    title="Testimonials and <em>recommendation context</em>."
    subtitle="Verbatim feedback from client and partner contexts. Each quote is reproduced word-for-word from email or stakeholder review."
    crumbs={[{ label: "Home", href: "/" }, { label: "Testimonials" }]}
  />

  <section class="section wrap first" data-screen-label="Counters">
    <div class="tst-counter rv">
      <div class="stat"><span class="v"><em><span data-count="4">0</span></em></span><span class="k">Verbatim quotes</span></div>
      <div class="stat"><span class="v"><span data-count="12">0</span><em>+</em></span><span class="k">Named client programmes</span></div>
      <div class="stat"><span class="v"><span data-count="11">0</span><em>+</em></span><span class="k">Verticals served</span></div>
      <div class="stat"><span class="v">★</span><span class="k">Direct stakeholder feedback</span></div>
    </div>
  </section>

  <section class="section wrap" data-screen-label="Quotes">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--terra)"></span>§ Verbatim record</span>
        <h2>What clients <em>said</em>.</h2>
        <p>Each quote is reproduced unedited from the source. Stakeholder names withheld where the engagement is private.</p>
      </div>
      <div class="sec-head-r">/ unedited</div>
    </div>

    <div class="quote-grid">
      <article class="qcard q-1 rv">
        <header class="qcard-h">
          <div class="who"><b>BBC</b><span class="role">Project stakeholder</span></div>
          <span class="tag">Media · UK</span>
        </header>
        <blockquote class="qbody">The tool is working fully, and we've been able to <b>share the update with wider teams</b>.</blockquote>
        <footer class="qfoot">
          <span class="source">Email · 2026</span>
          <span>Verbatim</span>
        </footer>
      </article>

      <article class="qcard q-2 rv d1">
        <header class="qcard-h">
          <div class="who"><b>General Mills</b><span class="role">Account team · Blue Buffalo</span></div>
          <span class="tag">Consumer · global</span>
        </header>
        <blockquote class="qbody">The feedback was very positive. Overall they are happy with the first go at this. I appreciate all your help and of course <b>passed on high praise of your work</b>.</blockquote>
        <footer class="qfoot">
          <span class="source">Stakeholder review</span>
          <span>Verbatim</span>
        </footer>
      </article>

      <article class="qcard q-3 rv d2">
        <header class="qcard-h">
          <div class="who"><b>Diligent Pharma</b><span class="role">Stakeholder</span></div>
          <span class="tag">Pharma · life sciences</span>
        </header>
        <blockquote class="qbody">Our analytics are <b>in great shape</b> at this point and we're feeling confident about the ways they will help us.</blockquote>
        <footer class="qfoot">
          <span class="source">Stakeholder review</span>
          <span>Verbatim</span>
        </footer>
      </article>

      <article class="qcard q-4 rv d3">
        <header class="qcard-h">
          <div class="who"><b>MRI Management</b><span class="role">Engagement partner</span></div>
          <span class="tag">Property tech · US</span>
        </header>
        <blockquote class="qbody">I really liked working with you and hope we can build a working relationship. <b>I have 3 to 4 clients that require your skills on a routine basis.</b></blockquote>
        <footer class="qfoot">
          <span class="source">Partner conversation</span>
          <span>Verbatim</span>
        </footer>
      </article>
    </div>

    <div class="qfooter rv">
      <div class="text">
        <b>Full engagement context.</b>
        <span>Named programmes, approved deliverables, and recommendation context are catalogued in the evidence index and detailed in the case studies.</span>
      </div>
      <div class="links">
        <a href="/evidence">Evidence index</a>
        <a href="/case-studies">Case studies</a>
      </div>
    </div>
  </section>
</SiteLayout>
