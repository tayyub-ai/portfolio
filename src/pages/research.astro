.igi-record-head h3 em{font-style:italic;color:var(--moss)}
.igi-record-head .igi-pub{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:.06em;text-transform:uppercase;margin-top:4px}
.igi-record-head .igi-stamp{font-family:var(--mono);font-size:9.5px;color:var(--moss);letter-spacing:.12em;text-transform:uppercase;background:#fff;border:1px solid var(--moss);padding:6px 12px;border-radius:3px;transform:rotate(2deg);box-shadow:0 4px 12px -4px rgba(74,93,47,.3);white-space:nowrap}
.igi-table{display:flex;flex-direction:column}
.igi-row{display:grid;grid-template-columns:130px 1fr 110px 110px 140px;gap:20px;padding:18px 28px;border-bottom:1px solid var(--line);align-items:center;transition:background .2s}
.igi-row:last-child{border-bottom:0}
.igi-row:not(.igi-thead):hover{background:rgba(74,93,47,.04)}
.igi-thead{background:#fafaf5;font-family:var(--mono);font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);padding:12px 28px;border-bottom:1px solid var(--line-2)}
.igi-type{font-family:var(--mono);font-size:10px;color:var(--moss);letter-spacing:.08em;text-transform:uppercase;padding:4px 9px;background:var(--sage-soft);border-radius:4px;width:max-content;border:1px solid #cfe0b1}
.igi-title{font-family:var(--serif);font-size:17.5px;line-height:1.35;letter-spacing:-.005em;color:var(--ink);text-wrap:balance}
.igi-title b{font-weight:500;color:var(--ink)}
.igi-title em{font-style:italic;color:var(--moss);font-weight:500}
.igi-date{font-family:var(--mono);font-size:11.5px;color:var(--ink-2);letter-spacing:.02em;display:flex;flex-direction:column;gap:2px}
.igi-date span{font-size:9px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase}
.igi-date b{color:var(--moss);font-weight:600;font-size:12.5px;letter-spacing:.01em}
.igi-co{font-family:var(--mono);font-size:10.5px;color:var(--ink-2);background:var(--bg-soft);padding:5px 10px;border-radius:999px;width:max-content;border:1px solid var(--line)}
.igi-foot{padding:16px 28px;background:#fafaf5;display:flex;justify-content:space-between;align-items:center;font-family:var(--mono);font-size:10.5px;color:var(--muted);letter-spacing:.04em;gap:14px;border-top:1px solid var(--line)}
.igi-foot .igi-seal{color:var(--moss);font-weight:600;text-transform:uppercase;letter-spacing:.08em;display:inline-flex;align-items:center;gap:6px}
.igi-foot .igi-seal::before{content:"★";color:var(--moss)}
@media (max-width:980px){
