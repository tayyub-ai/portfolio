---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
import { publicRepos } from "../data/repos";
---

<SiteLayout
  title="Open Source"
  description="Current public repositories used as supporting technical evidence, presented honestly and without placeholder repo names."
  pathname="/open-source"
  crumbs={[{ label: "Home", href: "/" }, { label: "Open Source" }]}
>
  <style slot="head">
    .repo-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
    .repo-card{background:#fff;border:1px solid var(--line);border-radius:var(--r-lg);padding:24px 26px;display:flex;flex-direction:column;gap:10px;box-shadow:var(--shadow-1);transition:transform .25s,box-shadow .25s,border-color .25s}
    .repo-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-2);border-color:var(--line-2)}
    .repo-card .tag{font-family:var(--mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--terra)}
    .repo-card h3{font-family:var(--serif);font-size:28px;font-weight:400;line-height:1.04;letter-spacing:-.015em}
    .repo-card p{font-size:14px;line-height:1.65;color:var(--ink-2)}
    .repo-tags{display:flex;flex-wrap:wrap;gap:6px}
    .repo-tags span{font-family:var(--mono);font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;padding:4px 8px;border-radius:999px;background:var(--bg-soft);border:1px solid var(--line);color:var(--ink-2)}
    .repo-card a{margin-top:auto;color:var(--terra);border-bottom:1px solid currentColor;width:max-content}
    @media (max-width:880px){.repo-grid{grid-template-columns:1fr}}
  </style>

  <PageHeader
    title="Public <em>repositories</em>."
    subtitle="Most production analytics work is private to clients and agencies. The repositories below are the public-facing pieces: utilities, audit modules, and exploratory work."
    crumbs={[{ label: "Home", href: "/" }, { label: "Open Source" }]}
  />

  <section class="section wrap first" data-screen-label="Repos">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--terra)"></span>§ Current public code</span>
        <h2>Current public <em>repos</em>.</h2>
        <p>Each repository below is live on GitHub and linked directly.</p>
      </div>
      <div class="sec-head-r"><a href="https://github.com/tayyub-ai" target="_blank" rel="noreferrer">GitHub profile ↗</a></div>
    </div>

    <div class="repo-grid">
      {publicRepos.map((repo) => (
        <article class="repo-card rv">
          <span class="tag">Live GitHub repository</span>
          <h3>{repo.name}</h3>
          <p>{repo.description}</p>
          <div class="repo-tags">
            {repo.tags.map((tag) => <span>{tag}</span>)}
          </div>
          <a href={repo.url} target="_blank" rel="noreferrer">Open repository ↗</a>
        </article>
      ))}
    </div>
  </section>
</SiteLayout>
