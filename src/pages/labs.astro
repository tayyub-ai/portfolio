---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
---

<SiteLayout
  title="Labs"
  description="In-development product and tooling work presented honestly as R&D rather than shipped product proof."
  pathname="/labs"
  crumbs={[{ label: "Home", href: "/" }, { label: "Labs" }]}
>
  <PageHeader
    title="Labs and <em>in-development</em> work."
    subtitle="This route is deliberately separated from the case studies. These items matter because they show current product and tooling direction, but they are <b>not presented as shipped proof</b>."
    crumbs={[{ label: "Home", href: "/" }, { label: "Labs" }]}
  />

  <section class="section wrap first" data-screen-label="Labs">
    <div class="sec-head rv">
      <div class="sec-head-l">
        <span class="sec-tag"><span class="dot" style="background:var(--ochre)"></span>§ R&amp;D surface</span>
        <h2>Current <em>labs</em> direction.</h2>
        <p>Useful for understanding where the tooling work is going next, but intentionally kept subordinate to the evidence-backed production work.</p>
      </div>
      <div class="sec-head-r">/ clearly labelled</div>
    </div>

    <div class="prod-bento">
      <article class="product feature rv" data-tilt>
        <span class="status status-dev">◐ In development · founder</span>
        <h3><em>LedgerTouch</em>.</h3>
        <p>Independent analytics product direction focused on measurement QA, consent checks, reporting risk, and stack-level visibility gaps. The proof available today is architecture and scope, not a public launch.</p>
        <div class="product-screen">
          <svg viewBox="0 0 600 340" preserveAspectRatio="xMidYMid meet">
            <rect width="600" height="340" fill="#fff"/>
            <rect x="0" y="0" width="600" height="36" fill="#1a1714"/>
            <g><circle cx="20" cy="18" r="5" fill="#d97757"/><circle cx="38" cy="18" r="5" fill="#c89942"/><circle cx="56" cy="18" r="5" fill="#7a8f5e"/></g>
            <text x="300" y="22" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#85807a">ledgertouch · labs surface · in development</text>
            <rect x="24" y="60" width="552" height="44" rx="8" fill="#fde8df" stroke="#c44d2c"/>
            <text x="40" y="88" font-family="Inter,sans-serif" font-size="14" fill="#c44d2c" font-weight="600">R&amp;D framing only · public proof is architecture, not launch status</text>
            <g font-family="JetBrains Mono,monospace" font-size="11" fill="#3d3833">
              <rect x="24" y="120" width="552" height="36" rx="6" fill="#fff" stroke="#e8e2d2"/><text x="40" y="142">Scope: measurement QA and consent visibility</text>
              <rect x="24" y="162" width="552" height="36" rx="6" fill="#fff" stroke="#e8e2d2"/><text x="40" y="184">Proof available: notes, diagrams, flow definitions</text>
              <rect x="24" y="204" width="552" height="36" rx="6" fill="#fbeec9" stroke="#c89942"/><text x="40" y="226" fill="#8a5e15">Do not treat as shipped product proof</text>
              <rect x="24" y="246" width="552" height="36" rx="6" fill="#e6ecd9" stroke="#7a8f5e"/><text x="40" y="268" fill="#4a5d2f">Useful as innovation context</text>
            </g>
          </svg>
        </div>
        <span class="prod-cta">Architecture and roadmap available in evidence context</span>
      </article>

      <article class="product rv d1" data-tilt>
        <span class="status status-dev">◐ In development</span>
        <h3>GTM audit <em>module</em>.</h3>
        <p>Container audit, tag coverage, duplicate detection, consent-mode mapping, and conversion-tag checks.</p>
        <div class="product-screen">
          <svg viewBox="0 0 400 200" preserveAspectRatio="xMidYMid meet">
            <rect width="400" height="200" fill="#fff"/>
            <g><rect x="20" y="20" width="100" height="50" rx="6" fill="#fbeec9" stroke="#c89942"/><text x="70" y="42" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#8a5e15">GA4 tags</text><text x="70" y="58" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#85807a">coverage</text></g>
            <g><rect x="150" y="20" width="100" height="50" rx="6" fill="#fde8df" stroke="#c44d2c"/><text x="200" y="42" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#c44d2c">duplicates</text><text x="200" y="58" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#85807a">detection</text></g>
            <g><rect x="280" y="20" width="100" height="50" rx="6" fill="#e6ecd9" stroke="#7a8f5e"/><text x="330" y="42" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#4a5d2f">consent</text><text x="330" y="58" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#85807a">mapping</text></g>
          </svg>
        </div>
        <span class="muted">Innovation context, not shipped proof.</span>
      </article>

      <article class="product rv d2" data-tilt>
        <span class="status status-dev">◐ In development</span>
        <h3><em>Consent</em> audit module.</h3>
        <p>CMP detection, consent-mode validation, cookie-behaviour inspection, and regional risk overlays.</p>
        <div class="product-screen">
          <svg viewBox="0 0 400 200" preserveAspectRatio="xMidYMid meet">
            <rect width="400" height="200" fill="#fff"/>
            <g font-family="JetBrains Mono,monospace" font-size="11" fill="#3d3833">
              <rect x="20" y="20" width="170" height="80" rx="8" fill="#fafaf5" stroke="#e8e2d2"/>
              <rect x="210" y="20" width="170" height="80" rx="8" fill="#fafaf5" stroke="#e8e2d2"/>
              <rect x="20" y="120" width="360" height="60" rx="8" fill="#fde8df" stroke="#c44d2c"/>
              <text x="35" y="144" font-weight="600" fill="#c44d2c">Regional consent handling under review</text>
            </g>
          </svg>
        </div>
        <span class="muted">Presented honestly as active R&amp;D.</span>
      </article>
    </div>
  </section>
</SiteLayout>
