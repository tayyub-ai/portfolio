---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
import { site } from "../data/site";
---

<SiteLayout
  title="Contact"
  description="Contact for senior roles, consulting, evidence requests, speaking, recommendation context, or collaboration."
  pathname="/contact"
  crumbs={[{ label: "Home", href: "/" }, { label: "Contact" }]}
  footerTitle="Direct contact."
  footerLead="Replies come from my inbox, usually within 48 hours on weekdays."
>
  <style slot="head">
    .cx-layout{max-width:980px;margin:8px auto 0}
    .cx-sheet{display:grid;grid-template-columns:minmax(0,1.4fr) 280px;gap:0;background:#fffdf8;border:1px solid var(--line);border-radius:18px;overflow:hidden;box-shadow:var(--shadow-1)}
    .cx-after{max-width:980px;margin:24px auto 0;font-size:14px;line-height:1.7;color:var(--ink-2)}
    .cx-after b{color:var(--ink);font-weight:600}

    /* ── Correspondence sheet ── */
    .cxform-wrap{padding:28px 30px 24px;background:#fff}
    .cxform{position:relative;padding:0;overflow:hidden}
    .cxform-h{display:flex;justify-content:space-between;align-items:end;padding-bottom:14px;border-bottom:1px solid var(--line);margin-bottom:22px}
    .cxform-h h3{font-family:var(--serif);font-size:24px;font-weight:400;letter-spacing:-.01em}
    .cxform-h h3 em{font-style:italic;color:var(--terra)}
    .cxform-h .meta{font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase}
    .cxform-h .meta::before{content:"";display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--moss);margin-right:6px;vertical-align:middle;animation:pulse 2s infinite}

    .field-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
    .field{position:relative;display:flex;flex-direction:column;gap:0}
    .field.full{grid-column:span 2}
    .field label{position:absolute;top:18px;left:14px;font-family:var(--mono);font-size:11px;letter-spacing:.04em;color:var(--muted);text-transform:uppercase;pointer-events:none;transition:transform .25s cubic-bezier(.2,.7,.1,1),color .25s,background .25s,padding .25s;background:#fff;padding:0 2px;font-weight:500}
    .field input,.field select,.field textarea{width:100%;padding:18px 14px 8px;border:1px solid var(--line);border-radius:0;background:#fff;font-family:'Inter',sans-serif;font-size:14px;color:var(--ink);transition:border-color .25s,box-shadow .25s;outline:none}
    .field textarea{padding-top:24px;min-height:140px;resize:vertical;line-height:1.5}
    .field input:focus,.field select:focus,.field textarea:focus{border-color:var(--terra);box-shadow:0 0 0 3px rgba(196,77,44,.1)}
    .field input:focus+label,.field input:not(:placeholder-shown)+label,
    .field textarea:focus+label,.field textarea:not(:placeholder-shown)+label{transform:translate(-4px,-22px) scale(.85);color:var(--terra);padding:0 6px}
    .field select+label{transform:translate(-4px,-22px) scale(.85);color:var(--terra);padding:0 6px}
    .field-underline{position:absolute;left:0;right:0;bottom:0;height:2px;background:var(--terra);transform:scaleX(0);transform-origin:left;transition:transform .35s cubic-bezier(.4,0,.2,1);pointer-events:none;border-radius:0 0 8px 8px}
    .field input:focus~.field-underline,.field textarea:focus~.field-underline,.field select:focus~.field-underline{transform:scaleX(1)}

    .field-actions{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-top:18px;padding-top:14px;border-top:1px dashed var(--line)}
    .field-actions .note{font-family:var(--mono);font-size:10px;letter-spacing:.06em;color:var(--muted);text-transform:uppercase;line-height:1.4}
    .field-actions .note b{color:var(--ink);font-family:'Inter',sans-serif;font-size:11px;font-weight:600;letter-spacing:0;text-transform:none;display:block;margin-bottom:2px}
    .submit{position:relative;display:inline-flex;align-items:center;gap:8px;padding:12px 22px;border-radius:999px;background:var(--ink);color:#fff;font-family:'Inter',sans-serif;font-weight:600;font-size:13px;border:0;cursor:pointer;transition:background .25s,transform .25s,box-shadow .25s;overflow:hidden}
    .submit:hover{background:var(--terra);transform:translateY(-1px);box-shadow:0 8px 16px rgba(196,77,44,.25)}
    .submit::after{content:"→";transition:transform .25s}
    .submit:hover::after{transform:translateX(4px)}

    .cx-protocol{padding:28px 24px;background:linear-gradient(180deg,rgba(255,255,255,.82),rgba(244,240,230,.96));border-left:1px solid var(--line);display:flex;flex-direction:column;gap:16px}
    .cx-protocol h4{font-family:var(--mono);font-size:10px;letter-spacing:.16em;color:var(--muted);text-transform:uppercase}
    .cx-protocol p{font-size:13.5px;line-height:1.65;color:var(--ink-2)}
    .cx-protocol ul{list-style:none;display:flex;flex-direction:column;gap:10px}
    .cx-protocol li{font-size:13px;line-height:1.55;color:var(--ink-2);padding-bottom:10px;border-bottom:1px dashed rgba(214,206,187,.92)}
    .cx-protocol li:last-child{padding-bottom:0;border-bottom:0}
    .cx-protocol b{display:block;color:var(--ink);font-weight:600;margin-bottom:3px}

    .cx-sent{display:none;align-items:center;gap:14px;padding:18px 20px;background:#fffdf8;border:1px dashed var(--line-2);border-radius:0;margin-bottom:18px;position:relative;overflow:hidden}
    .cx-sent.show{display:flex}
    .cx-sent::after{content:"RECEIVED";position:absolute;top:14px;right:16px;color:rgba(196,77,44,.32);font-family:var(--mono);font-size:10px;letter-spacing:.18em;transform:rotate(-10deg);text-transform:uppercase}
    .cx-sent .ic{width:36px;height:36px;border-radius:50%;background:var(--moss);color:#fff;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
    .cx-sent .text{flex:1}
    .cx-sent .text b{font-family:'Inter',sans-serif;font-size:14px;font-weight:600;color:var(--ink);display:block}
    .cx-sent .text p{font-size:13px;color:var(--ink-2);line-height:1.5;margin-top:2px}

    @media (max-width:820px){.cx-sheet{grid-template-columns:1fr}.cx-protocol{border-left:0;border-top:1px solid var(--line)}}
    @media (max-width:680px){.field-grid{grid-template-columns:1fr}.field.full{grid-column:auto}.field-actions{flex-direction:column;align-items:flex-start}.cxform-wrap{padding:24px 22px}}

  </style>

  <PageHeader
    title="Contact."
    subtitle="For senior roles, consulting, commentary, panels, and reference checks."
    crumbs={[{ label: "Home", href: "/" }, { label: "Contact" }]}
  />

  <section class="section wrap first" data-screen-label="Contact">
    <div id="contact-sent" class="cx-sent rv">
      <span class="ic">✓</span>
      <div class="text">
        <b>Message received.</b>
        <p>I'll reply from <span style="color:var(--ink);font-weight:600">{site.email}</span> within 48 hours on weekdays.</p>
      </div>
    </div>

    <div class="cx-layout">
      <div class="cx-sheet rv">
        <div class="cxform-wrap">
          <form class="cxform" action={`https://formsubmit.co/${site.email}`} method="POST">
            <input type="hidden" name="_subject" value="New contact via portfolio" />
            <input type="hidden" name="_captcha" value="true" />
            <input type="hidden" name="_template" value="table" />
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

            <header class="cxform-h">
              <h3>Send a message.</h3>
              <span class="meta">Direct correspondence · 2026</span>
            </header>

            <div class="field-grid">
              <div class="field">
                <input id="cf-name" type="text" name="name" required autocomplete="name" placeholder=" " />
                <label for="cf-name">Your name</label>
                <span class="field-underline"></span>
              </div>
              <div class="field">
                <input id="cf-email" type="email" name="email" required autocomplete="email" placeholder=" " />
                <label for="cf-email">Email</label>
                <span class="field-underline"></span>
              </div>
              <div class="field">
                <input id="cf-org" type="text" name="organisation" autocomplete="organization" placeholder=" " />
                <label for="cf-org">Organisation (optional)</label>
                <span class="field-underline"></span>
              </div>
              <div class="field">
                <select id="cf-topic" name="topic" required>
                  <option value="">Senior role / hiring conversation</option>
                  <option>Consulting / analytics systems work</option>
                  <option>Speaking / panel / podcast</option>
                  <option>Publication / expert commentary</option>
                  <option>Other</option>
                </select>
                <label for="cf-topic">Topic</label>
                <span class="field-underline"></span>
              </div>
              <div class="field full">
                <textarea id="cf-message" name="message" required placeholder=" "></textarea>
                <label for="cf-message">Share the context, timeline, and what you need</label>
                <span class="field-underline"></span>
              </div>
            </div>

            <div class="field-actions">
              <div class="note">
                <b>Direct reply only.</b>
                No mailing list, no PR layer. Replies usually within 48 hours on weekdays.
              </div>
              <button type="submit" class="submit">Send message</button>
            </div>
          </form>
        </div>

        <aside class="cx-protocol">
          <h4>Response protocol</h4>
          <p>This page is for roles, consulting, reference checks, speaking, and expert commentary. The goal is a fast direct exchange, not a lead funnel.</p>
          <ul>
            <li><b>Best for</b>Senior role conversations, analytics systems work, publications, panels, and recommendation context.</li>
            <li><b>Reply cadence</b>Usually within 48 hours on weekdays, from <a href={`mailto:${site.email}`}>{site.email}</a>.</li>
            <li><b>If urgent</b>Include timing, decision window, and the kind of evidence or context you need.</li>
          </ul>
        </aside>
      </div>
    </div>

    <p class="cx-after rv d1">
      Prefer email? Write to <b><a href={`mailto:${site.email}`} style="color:inherit;border-bottom:1px solid var(--line-2)">{site.email}</a></b>. Based in Stirling, UK.
    </p>
  </section>

  <script is:inline>
    (function(){
      const params=new URLSearchParams(location.search);
      if(params.get('sent')==='1'){
        const el=document.getElementById('contact-sent');
        if(el){el.classList.add('show');el.scrollIntoView({behavior:'smooth',block:'start'});}
      }
    })();
  </script>
</SiteLayout>
