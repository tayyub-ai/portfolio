---
import PageHeader from "../components/PageHeader.astro";
import SiteLayout from "../components/SiteLayout.astro";
import { site } from "../data/site";
---

<SiteLayout
  title="Contact"
  description="Contact for senior roles, consulting, evidence requests, speaking, recommendation context, or collaboration."
  pathname="/contact"
  crumbs={[{ label: "Home", href: "/" }, { label: "Contact" }]}
  footerTitle="Direct contact."
  footerLead="No PR layer. No newsletter funnel. Just direct contact for the work and the evidence around it."
>
  <style slot="head">
    .contact-wrap{display:grid;grid-template-columns:1.2fr .8fr;gap:22px;align-items:start}
    .contact-form,.contact-card,.contact-sent{background:#fff;border:1px solid var(--line);border-radius:var(--r-lg);box-shadow:var(--shadow-1)}
    .contact-form{padding:24px 26px}
    .contact-side{display:flex;flex-direction:column;gap:12px}
    .contact-card{padding:18px 20px;display:flex;flex-direction:column;gap:8px}
    .contact-card h4{font-family:var(--serif);font-size:22px;font-weight:400;line-height:1.05}
    .contact-card h4 em{font-style:italic;color:var(--terra)}
    .contact-card p{font-size:13.5px;color:var(--ink-2);line-height:1.55}
    .contact-card a{color:var(--terra);border-bottom:1px solid currentColor;width:max-content}
    .row{display:flex;flex-direction:column;gap:8px;margin-bottom:14px}
    .row-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .row label{font-family:var(--mono);font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
    .row input,.row select,.row textarea{width:100%;padding:12px 14px;border-radius:12px;border:1px solid var(--line);background:#fff;font:inherit;color:var(--ink)}
    .row textarea{min-height:180px;resize:vertical}
    .row input:focus,.row select:focus,.row textarea:focus{outline:none;border-color:var(--terra);box-shadow:0 0 0 3px rgba(196,77,44,.12)}
    .actions{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-top:10px}
    .actions .note{font-family:var(--mono);font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
    .actions button{padding:10px 18px;border-radius:999px;background:var(--ink);color:#fff;font-weight:600}
    .actions button:hover{background:var(--terra)}
    .contact-sent{display:flex;gap:14px;padding:16px 18px;margin-bottom:18px;background:linear-gradient(155deg,#fff,var(--sage-soft));border-color:#cfe0b1}
    .contact-sent .ic{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:var(--moss);color:#fff;flex-shrink:0}
    @media (max-width:980px){.contact-wrap{grid-template-columns:1fr}.row-2{grid-template-columns:1fr}.actions{flex-direction:column;align-items:flex-start}}
  </style>

  <PageHeader
    title="Work, evidence, and <em>contact</em>."
    subtitle="For senior-role conversations, consulting, speaking, publication requests, or recommendation context. If you need a closer look at the evidence pack or case-study support material, ask directly."
    crumbs={[{ label: "Home", href: "/" }, { label: "Contact" }]}
  />

  <section class="section wrap first" data-screen-label="Contact">
    <div id="contact-sent" class="contact-sent rv" style="display:none">
      <span class="ic">✓</span>
      <div>
        <b>Message received.</b>
        <p>I’ll reply from <span style="color:var(--ink);font-weight:600">{site.email}</span> within 48 hours on weekdays.</p>
      </div>
    </div>

    <div class="contact-wrap">
      <form class="contact-form rv" action={`https://formsubmit.co/${site.email}`} method="POST">
        <input type="hidden" name="_subject" value="New contact via portfolio" />
        <input type="hidden" name="_captcha" value="true" />
        <input type="hidden" name="_template" value="table" />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="row-2">
          <div class="row">
            <label for="cf-name">Your name</label>
            <input id="cf-name" type="text" name="name" required autocomplete="name" placeholder="Full name" />
          </div>
          <div class="row">
            <label for="cf-email">Email</label>
            <input id="cf-email" type="email" name="email" required autocomplete="email" placeholder="you@company.com" />
          </div>
        </div>

        <div class="row-2">
          <div class="row">
            <label for="cf-org">Organisation</label>
            <input id="cf-org" type="text" name="organisation" autocomplete="organization" placeholder="Optional" />
          </div>
          <div class="row">
            <label for="cf-topic">Topic</label>
            <select id="cf-topic" name="topic">
              <option>Senior role / hiring conversation</option>
              <option>Consulting / analytics systems work</option>
              <option>Request evidence pack / supporting material</option>
              <option>Speaking / panel / podcast</option>
              <option>Publication / expert commentary</option>
              <option>Other</option>
            </select>
          </div>
        </div>

        <div class="row">
          <label for="cf-message">Message</label>
          <textarea id="cf-message" name="message" required placeholder="Share the context, timeline, and what you need from me."></textarea>
        </div>

        <div class="actions">
          <span class="note">Direct reply only. No mailing list.</span>
          <button type="submit">Send message →</button>
        </div>
      </form>

      <aside class="contact-side rv d1">
        <div class="contact-card">
          <h4>Direct <em>email</em>.</h4>
          <p>Prefer email? The form sends to the same inbox.</p>
          <a href={`mailto:${site.email}`}>{site.email} →</a>
        </div>
        <div class="contact-card">
          <h4>Evidence <em>requests</em>.</h4>
          <p>Ask for the evidence pack, case-study support material, archive publication proof, or recommendation context.</p>
          <a href="/evidence">Open evidence route ↗</a>
        </div>
        <div class="contact-card">
          <h4><em>LinkedIn</em>.</h4>
          <p>Useful for profile verification and career context.</p>
          <a href={site.social.linkedin} target="_blank" rel="noreferrer">linkedin.com/in/tayyubyaqoob ↗</a>
        </div>
        <div class="contact-card">
          <h4><em>GitHub</em>.</h4>
          <p>Public repositories used as supporting technical evidence.</p>
          <a href={site.social.github} target="_blank" rel="noreferrer">github.com/tayyub-ai ↗</a>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline>
    (function(){
      const params=new URLSearchParams(location.search);
      if(params.get('sent')==='1'){
        const el=document.getElementById('contact-sent');
        if(el){el.style.display='flex';el.scrollIntoView({behavior:'smooth',block:'start'});}
      }
    })();
  </script>
</SiteLayout>
